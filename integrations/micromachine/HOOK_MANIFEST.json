{
  "integration": "voiStarcraft2 MicroMachine policy modulation",
  "upstream_repository": "https://github.com/RaphaelRoyerRivard/MicroMachine",
  "verified_upstream_commit": "eb893161371dab975a0a7e600f9e250ac03ec1ef",
  "protocol_version": "voi-mm-bridge/v1",
  "blackboard_files": {
    "json": "latest_modulation.json",
    "kv": "latest_modulation.kv",
    "telemetry": "latest_telemetry.json"
  },
  "python_blackboard_emitted_but_not_consumed_by_current_cpp_patch": [
    "strategy.timing_biases.*",
    "strategy.transition_biases.*",
    "economy.gas_worker_target_bias",
    "economy.mineral_saturation_bias",
    "economy.expansion_safety_bias",
    "economy.mule_priority",
    "production.addon_biases.*",
    "production.production_facility_biases.*",
    "production.tech_switch_urgency",
    "combat.pressure_window_frames",
    "combat.siege_position_bias",
    "combat.kite_bias",
    "combat.flank_bias",
    "squad.flank_bias",
    "squad.split_army_bias",
    "squad.proxy_pressure_bias",
    "scope.army_group",
    "scope.unit_classes",
    "scope.duration_seconds",
    "scope.max_units",
    "scope.require_safety_margin",
    "scope.allow_partial_scope",
    "emergency.prioritize_repair",
    "emergency.stop_expansion"
  ],
  "central_polling_hook": {
    "source_path": "src/GameCommander.cpp",
    "function": "GameCommander::onFrame(bool executeMacro)",
    "anchor": "before m_productionManager.onFrame(executeMacro)",
    "reason": "GameCommander calls ProductionManager, ScoutManager, and CombatCommander every frame, so this is the safest single polling point."
  },
  "manager_hooks": [
    {
      "domain": "production",
      "source_path": "src/ProductionManager.cpp",
      "header_path": "src/ProductionManager.h",
      "function": "ProductionManager::onFrame(bool executeMacro)",
      "secondary_function": "ProductionManager::manageBuildOrderQueue()",
      "keys": [
        "production.max_tech_deviation",
        "production.allow_build_order_rewrite",
        "production.production_continuity_bias",
        "tech.unit_biases.TERRAN_SIEGETANK",
        "economy.expand_bias",
        "economy.worker_production_bias"
      ],
      "intended_effect": "Bias queue priority and tech deviation while preserving MicroMachine build execution."
    },
    {
      "domain": "combat",
      "source_path": "src/CombatCommander.cpp",
      "header_path": "src/CombatCommander.h",
      "function": "CombatCommander::onFrame(const std::vector<Unit> & combatUnits)",
      "secondary_function": "CombatCommander::shouldWeStartAttacking()",
      "keys": [
        "combat.aggression",
        "combat.defend_bias",
        "combat.preserve_army_bias",
        "combat.attack_timing_bias",
        "combat.commitment_level",
        "combat.attack_condition_override",
        "combat.retreat_patience_bias",
        "combat.rally_before_attack_bias",
        "scope.min_units",
        "emergency.cancel_attacks",
        "emergency.force_retreat"
      ],
      "intended_effect": "Bias attack/hold/retreat posture without issuing direct unit orders."
    },
    {
      "domain": "scouting",
      "source_path": "src/ScoutManager.cpp",
      "header_path": "src/ScoutManager.h",
      "function": "ScoutManager::onFrame()",
      "secondary_function": "ScoutManager::moveScouts()",
      "keys": [
        "scouting.scout_priority",
        "scouting.risk_tolerance",
        "scouting.scout_cadence_bias",
        "scouting.scan_priority",
        "scouting.hidden_tech_scout_bias",
        "scouting.require_fresh_enemy_observation"
      ],
      "intended_effect": "Bias scout risk and information freshness while ScoutManager keeps movement control."
    },
    {
      "domain": "economy",
      "source_path": "src/WorkerManager.cpp",
      "header_path": "src/WorkerManager.h",
      "function": "WorkerManager::onFrame(bool executeMacro)",
      "secondary_function": "WorkerManager::handleRepairWorkers()",
      "keys": [
        "economy.repair_priority",
        "economy.gas_priority",
        "emergency.pull_workers_for_defense",
        "emergency.evacuate_workers"
      ],
      "intended_effect": "Bias repair/gas/worker-defense policies without directly selecting workers."
    },
    {
      "domain": "workers",
      "source_path": "src/GameCommander.cpp",
      "header_path": "src/GameCommander.h",
      "function": "GameCommander::shouldSuppressRepeatedWorkerCommand(...)",
      "secondary_function": "Unit/Micro command wrapper calls",
      "keys": [
        "workers.repeat_order_guard_frames"
      ],
      "intended_effect": "Suppress repeated identical worker orders inside a bounded frame window without issuing replacement raw unit commands."
    },
    {
      "domain": "combat_analysis",
      "source_path": "src/CombatAnalyzer.cpp",
      "header_path": "src/CombatAnalyzer.h",
      "function": "CombatAnalyzer::onFrame()",
      "secondary_function": "CombatAnalyzer::lowPriorityChecks()",
      "keys": [
        "combat.combat_sim_confidence_margin",
        "combat.engage_threshold_delta",
        "combat.retreat_threshold_delta"
      ],
      "intended_effect": "Bias combat analysis thresholds used by higher-level fight decisions."
    },
    {
      "domain": "squad",
      "source_path": "src/Squad.cpp",
      "header_path": "src/Squad.h",
      "function": "Squad::onFrame()",
      "secondary_function": "Squad::calcTargets()",
      "keys": [
        "squad.main_army_bias",
        "squad.harassment_bias",
        "squad.defense_bias",
        "squad.regroup_bias",
        "squad.drop_bias"
      ],
      "intended_effect": "Bias role allocation/regroup behavior while Squad executes its existing micro managers."
    },
    {
      "domain": "scope",
      "source_path": "src/Squad.cpp",
      "header_path": "src/Squad.h",
      "function": "Squad::calcTargets(bool visibilityFilter)",
      "secondary_function": "CombatCommander::updateAttackSquads()",
      "keys": [
        "scope.location_intent",
        "scope.min_units",
        "squad.contain_bias",
        "squad.reinforce_bias",
        "combat.target_priority_biases.*"
      ],
      "intended_effect": "Bias semantic attack scope, reinforce radius, contain position, and target ordering without raw unit tags."
    }
  ]
}
