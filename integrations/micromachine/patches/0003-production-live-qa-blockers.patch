+{
+	if (!bot.Commander().isVoiPolicyActive()
+		|| bot.Commander().getVoiPolicyString("tactical_task.task_type", "") != "pressure_with_main_army"
+		|| !voiTacticalTaskWithinDuration(bot))
+	{
+		return false;
+	}
+	for (const std::string domain : {"composition_requirements", "unit_roles"})
+	{
+		for (int i = 0; i < 8; ++i)
+		{
+			const std::string prefix = domain + "." + std::to_string(i);
+			if (bot.Commander().getVoiPolicyString(prefix + ".unit_type", "") != requestedType)
+			{
+				continue;
+			}
+			if (domain == "unit_roles"
+				|| bot.Commander().getVoiPolicyInt(prefix + ".count", 0) > 0)
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+bool voiUnitMatchesPolicyRoleToken(const sc2::Unit * unit, const std::string & token)
+{
+	if (unit == nullptr)
+	{
+		return false;
+	}
+	const sc2::UNIT_TYPEID type = unit->unit_type;
+	return (token == "TERRAN_MARINE" && type == sc2::UNIT_TYPEID::TERRAN_MARINE)
+		|| (token == "TERRAN_MARAUDER" && type == sc2::UNIT_TYPEID::TERRAN_MARAUDER)
+		|| (token == "TERRAN_REAPER" && type == sc2::UNIT_TYPEID::TERRAN_REAPER)
+		|| (token == "TERRAN_HELLION" && (type == sc2::UNIT_TYPEID::TERRAN_HELLION || type == sc2::UNIT_TYPEID::TERRAN_HELLIONTANK))
+		|| (token == "TERRAN_CYCLONE" && type == sc2::UNIT_TYPEID::TERRAN_CYCLONE)
+		|| (token == "TERRAN_THOR" && (type == sc2::UNIT_TYPEID::TERRAN_THOR || type == sc2::UNIT_TYPEID::TERRAN_THORAP))
+		|| (token == "TERRAN_SIEGETANK" && (type == sc2::UNIT_TYPEID::TERRAN_SIEGETANK || type == sc2::UNIT_TYPEID::TERRAN_SIEGETANKSIEGED))
+		|| (token == "TERRAN_MEDIVAC" && type == sc2::UNIT_TYPEID::TERRAN_MEDIVAC)
+		|| (token == "TERRAN_VIKINGFIGHTER" && (type == sc2::UNIT_TYPEID::TERRAN_VIKINGFIGHTER || type == sc2::UNIT_TYPEID::TERRAN_VIKINGASSAULT))
+		|| (token == "TERRAN_BANSHEE" && type == sc2::UNIT_TYPEID::TERRAN_BANSHEE)
+		|| (token == "TERRAN_RAVEN" && type == sc2::UNIT_TYPEID::TERRAN_RAVEN)
+		|| (token == "TERRAN_BATTLECRUISER" && type == sc2::UNIT_TYPEID::TERRAN_BATTLECRUISER);
+}
+
+std::string voiPolicyRoleForUnit(CCBot & bot, const sc2::Unit * unit)
+{
+	for (const std::string domain : {"unit_roles", "composition_requirements"})
+	{
+		for (int i = 0; i < 8; ++i)
+		{
+			const std::string prefix = domain + "." + std::to_string(i);
+			const std::string unitType = bot.Commander().getVoiPolicyString(prefix + ".unit_type", "");
+			const std::string role = bot.Commander().getVoiPolicyString(prefix + ".role", "");
+			if (!role.empty() && voiUnitMatchesPolicyRoleToken(unit, unitType))
+			{
+				return role;
+			}
+		}
+	}
+	return "";
+}
+
+bool voiSupportsPolicyKiting(const sc2::Unit * unit)
+{
+	if (unit == nullptr)
+	{
+		return false;
+	}
+	switch ((sc2::UNIT_TYPEID)unit->unit_type)
+	{
+		case sc2::UNIT_TYPEID::TERRAN_MARINE:
+		case sc2::UNIT_TYPEID::TERRAN_MARAUDER:
+		case sc2::UNIT_TYPEID::TERRAN_REAPER:
+		case sc2::UNIT_TYPEID::TERRAN_HELLION:
+		case sc2::UNIT_TYPEID::TERRAN_CYCLONE:
+		case sc2::UNIT_TYPEID::TERRAN_VIKINGFIGHTER:
+		case sc2::UNIT_TYPEID::TERRAN_BANSHEE:
+			return true;
+		default:
+			return false;
+	}
+}
+
+bool voiTankIsNearProduction(CCBot & bot, const sc2::Unit * tank)
+{
+	if (tank == nullptr)
+	{
+		return true;
+	}
+	for (const auto & unitPair : bot.GetAllyUnits())
+	{
+		const Unit & unit = unitPair.second;
+		if (!unit.isValid() || !unit.getType().isBuilding())
+		{
+			continue;
+		}
+		const sc2::UNIT_TYPEID type = unit.getAPIUnitType();
+		const bool producer =
+			type == sc2::UNIT_TYPEID::TERRAN_BARRACKS
+			|| type == sc2::UNIT_TYPEID::TERRAN_BARRACKSFLYING
+			|| type == sc2::UNIT_TYPEID::TERRAN_FACTORY
+			|| type == sc2::UNIT_TYPEID::TERRAN_FACTORYFLYING
+			|| type == sc2::UNIT_TYPEID::TERRAN_STARPORT
+			|| type == sc2::UNIT_TYPEID::TERRAN_STARPORTFLYING;
+		if (producer && Util::DistSq(tank->pos, unit.getPosition()) <= 7.0f * 7.0f)
+		{
+			return true;
+		}
+	}
+	return false;
+}
+
+bool voiOffensiveTankSiegeBlocked(CCBot & bot, Squad * squad, const sc2::Unit * tank)
+{
+	if (!bot.Commander().isVoiPolicyActive()
+		|| squad == nullptr
+		|| squad->getName() != "MainAttack")
+	{
+		return false;
+	}
+	const std::string role = voiTankRole(bot, tank);
+	if (role != "siege_support"
+		&& role != "contain"
+		&& !voiExplicitMainAttackUnitRequested(bot, "TERRAN_SIEGETANK"))
+	{
+		return false;
+	}
+	const BaseLocation * homeBase = bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+	const CCPosition home = homeBase ? homeBase->getPosition() : bot.GetStartLocation();
+	const std::string orderStatus = squad->getSquadOrder().getStatus();
+	return orderStatus == "Producing"
+		|| orderStatus == "Rallying"
+		|| orderStatus == "Retreat"
+		|| Util::DistSq(tank->pos, home) < 12.0f * 12.0f
+		|| voiTankIsNearProduction(bot, tank);
+}
 }
 
