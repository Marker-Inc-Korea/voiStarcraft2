+CCPosition voiForwardRallyPosition(CCBot & bot, const CCPosition & operationTarget)
+{
+	const CCPosition home = voiHomePosition(bot);
+	CCPosition target = operationTarget;
+	if (!voiIsRemoteCombatTarget(bot, target))
+	{
+		target = voiEnemyMainCombatTarget(bot);
+	}
+	const CCPosition directionVector = target - home;
+	const float distance = std::sqrt(
+		directionVector.x * directionVector.x + directionVector.y * directionVector.y);
+	if (distance <= 1.0f)
+	{
+		return home;
+	}
+
+	const CCPosition forward = directionVector / distance;
+	const CCPosition lateral(-forward.y, forward.x);
+	for (float forwardDistance : {18.0f, 15.0f, 12.0f, 9.0f})
+	{
+		for (float lateralDistance : {0.0f, 4.0f, -4.0f, 7.0f, -7.0f})
+		{
+			const CCPosition candidate = home + forward * forwardDistance + lateral * lateralDistance;
+			if (!bot.Map().isValidPosition(candidate)
+				|| !bot.Map().isWalkable(candidate)
+				|| !bot.Map().isConnected(home, candidate)
+				|| voiPositionIsNearProducerFootprint(candidate, bot, 8.0f))
+			{
+				continue;
+			}
+			return candidate;
+		}
+	}
+	return home + forward * std::min(8.0f, distance * 0.25f);
+}
