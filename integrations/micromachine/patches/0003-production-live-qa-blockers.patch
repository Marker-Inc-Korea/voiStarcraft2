+bool voiIsLandOrderForTarget(const sc2::UnitOrder & order, const CCPosition & target)
+{
+	const bool landOrder = order.ability_id == sc2::ABILITY_ID::LAND
+		|| order.ability_id == sc2::ABILITY_ID::LAND_BARRACKS
+		|| order.ability_id == sc2::ABILITY_ID::LAND_FACTORY
+		|| order.ability_id == sc2::ABILITY_ID::LAND_STARPORT;
+	return landOrder && order.target_pos == target;
+}
+
+bool voiIsBuildingMobilityOrder(const sc2::UnitOrder & order)
+{
+	return order.ability_id == sc2::ABILITY_ID::LIFT
+		|| order.ability_id == sc2::ABILITY_ID::LAND
+		|| order.ability_id == sc2::ABILITY_ID::LAND_BARRACKS
+		|| order.ability_id == sc2::ABILITY_ID::LAND_FACTORY
+		|| order.ability_id == sc2::ABILITY_ID::LAND_STARPORT;
+}
+}
+
+bool BuildingManager::tryIssueVoiBuildingMobilityCommand(
+	const Unit & unit,
+	sc2::AbilityID ability,
+	const CCPosition & target,
+	const std::string & owner,
+	uint32_t cooldown)
+{
+	if (!unit.isValid() || !unit.isAlive() || owner.empty())
+	{
+		return false;
+	}
+
+	const sc2::Tag tag = unit.getTag();
+	const auto ownerIt = m_voiMobilityOwner.find(tag);
+	if (ownerIt != m_voiMobilityOwner.end() && ownerIt->second != owner)
+	{
+		return false;
+	}
+	for (const auto & order : unit.getUnitPtr()->orders)
+	{
+		if (voiIsBuildingMobilityOrder(order))
+		{
+			return false;
+		}
+	}
+	if (!unit.getUnitPtr()->orders.empty())
+	{
+		return false;
+	}
+
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	const auto lastIt = m_voiMobilityLastCommandFrame.find(tag);
+	if (lastIt != m_voiMobilityLastCommandFrame.end()
+		&& currentFrame >= lastIt->second
+		&& currentFrame - lastIt->second < cooldown)
+	{
+		return false;
+	}
+
+	if (target != CCPosition())
+	{
+		if (!m_bot.Query()->Placement(ability, target, unit.getUnitPtr()))
+		{
+			return false;
+		}
+		Micro::SmartAbility(unit.getUnitPtr(), ability, target, m_bot);
+	}
+	else
+	{
+		Micro::SmartAbility(unit.getUnitPtr(), ability, m_bot);
+	}
+	m_voiMobilityOwner[tag] = owner;
+	m_voiMobilityLastCommandFrame[tag] = currentFrame;
+	return true;
+}
+
+void BuildingManager::releaseVoiBuildingMobilityOwnershipIfSettled(const Unit & unit)
+{
+	if (!unit.isValid() || !unit.isAlive())
+	{
+		m_voiMobilityOwner.erase(unit.getTag());
+		m_voiMobilityLastCommandFrame.erase(unit.getTag());
+		return;
+	}
+	const sc2::Tag tag = unit.getTag();
+	if (m_voiMobilityOwner.find(tag) == m_voiMobilityOwner.end())
+	{
+		return;
+	}
+	for (const auto & order : unit.getUnitPtr()->orders)
+	{
+		if (voiIsBuildingMobilityOrder(order))
+		{
+			return;
+		}
 	}
+	if (unit.isFlying())
+	{
+		return;
+	}
+	const auto lastIt = m_voiMobilityLastCommandFrame.find(tag);
+	if (lastIt != m_voiMobilityLastCommandFrame.end()
+		&& m_bot.GetCurrentFrame() >= lastIt->second
+		&& m_bot.GetCurrentFrame() - lastIt->second < 64)
+	{
+		return;
+	}
+	m_voiMobilityOwner.erase(tag);
+}
+
+bool BuildingManager::isVoiBuildingMobilityOwned(sc2::Tag tag) const
+{
+	return m_voiMobilityOwner.find(tag) != m_voiMobilityOwner.end();
+}
