+std::string voiTankRole(CCBot & bot, const sc2::Unit * unit)
+{
+	if (unit == nullptr
+		|| (unit->unit_type != sc2::UNIT_TYPEID::TERRAN_SIEGETANK
+			&& unit->unit_type != sc2::UNIT_TYPEID::TERRAN_SIEGETANKSIEGED))
+	{
+		return "";
+	}
+	for (const std::string domain : {"unit_roles", "composition_requirements"})
+	{
+		for (int i = 0; i < 8; ++i)
+		{
+			const std::string prefix = domain + "." + std::to_string(i);
+			const std::string unitType = bot.Commander().getVoiPolicyString(prefix + ".unit_type", "");
+			const std::string role = bot.Commander().getVoiPolicyString(prefix + ".role", "");
+			if (unitType == "TERRAN_SIEGETANK" && !role.empty())
+			{
+				return role;
+			}
+		}
+	}
+	return "";
+}
+
+bool voiTacticalTaskWithinDuration(CCBot & bot)
+{
+	const int durationSeconds = std::max(0, bot.Commander().getVoiPolicyInt("tactical_task.duration_seconds", 0));
+	if (durationSeconds == 0)
+	{
+		return true;
+	}
+	const uint32_t issuedAtFrame = static_cast<uint32_t>(std::max(0, bot.Commander().getVoiPolicyInt("issued_at_frame", 0)));
+	const uint32_t durationFrames = static_cast<uint32_t>(durationSeconds) * 22u;
+	return bot.GetCurrentFrame() <= issuedAtFrame + durationFrames;
+}
