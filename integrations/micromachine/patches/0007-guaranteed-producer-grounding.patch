+bool BuildingManager::isVoiProducerLandingSiteValid(const Building & b, const CCPosition & producerPosition)
+{
+	if (producerPosition == CCPosition()
+		|| !b.builderUnit.isValid()
+		|| !b.builderUnit.isFlying()
+		|| !isVoiProducerFootprintClear(b, producerPosition))
+	{
+		return false;
+	}
+	const sc2::AvailableAbilities availableAbilities = m_bot.Query()->GetAbilitiesForUnit(b.builderUnit.getUnitPtr());
+	return voiResolveLandAbility(m_bot, b.builderUnit, producerPosition, availableAbilities)
+			!= sc2::ABILITY_ID::INVALID
+		|| voiAvailableLandAbility(b.builderUnit, availableAbilities)
+			!= sc2::ABILITY_ID::INVALID;
