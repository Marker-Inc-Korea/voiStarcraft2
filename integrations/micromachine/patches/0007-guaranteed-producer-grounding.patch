+std::vector<sc2::AbilityID> voiLandAbilityCandidatesForProducer(const Unit & producer)
+{
+	const sc2::AbilityID specializedAbility = voiLandAbilityForProducer(producer);
+	if (specializedAbility == sc2::ABILITY_ID::LAND)
+	{
+		return {sc2::ABILITY_ID::LAND};
+	}
+	return {specializedAbility, sc2::ABILITY_ID::LAND};
+}
+
+sc2::AbilityID voiAvailableLandAbility(
+	const Unit & producer,
+	const sc2::AvailableAbilities & availableAbilities)
+{
+	for (const sc2::AbilityID ability : voiLandAbilityCandidatesForProducer(producer))
+	{
+		if (Util::IsAbilityAvailable((sc2::ABILITY_ID)ability, availableAbilities))
+		{
+			return ability;
+		}
+	}
+	return sc2::ABILITY_ID::INVALID;
+}
+
+sc2::AbilityID voiResolveLandAbility(
+	CCBot & bot,
+	const Unit & producer,
+	const CCPosition & target,
+	const sc2::AvailableAbilities & availableAbilities)
+{
+	if (!producer.isValid() || !producer.isAlive() || !producer.isFlying() || target == CCPosition())
+	{
+		return sc2::ABILITY_ID::INVALID;
+	}
+	for (const sc2::AbilityID ability : voiLandAbilityCandidatesForProducer(producer))
+	{
+		if (!Util::IsAbilityAvailable((sc2::ABILITY_ID)ability, availableAbilities))
+		{
+			continue;
+		}
+		if (bot.Query()->Placement(ability, target, producer.getUnitPtr()))
+		{
+			return ability;
+		}
+	}
+	return sc2::ABILITY_ID::INVALID;
+}
