+std::string voiCompositionRequirementLabel(CCBot & bot, int index)
+{
+	const std::string prefix = "composition_requirements." + std::to_string(index);
+	const std::string unitType = bot.Commander().getVoiPolicyString(prefix + ".unit_type", "");
+	const int count = std::max(0, bot.Commander().getVoiPolicyInt(prefix + ".count", 0));
+	const std::string role = bot.Commander().getVoiPolicyString(prefix + ".role", "");
+	if (unitType.empty() || count <= 0)
+	{
+		return "";
+	}
+	return unitType + ":" + std::to_string(count) + (role.empty() ? "" : ":" + role);
+}
+
+std::string voiPressureOperationKey(CCBot & bot)
+{
+	std::string key = bot.Commander().getVoiPolicyString("tactical_task.task_id", "");
+	if (key.empty())
+	{
+		key = bot.Commander().getVoiPolicyString("update_id", "");
+	}
+	for (int i = 0; i < 8; ++i)
+	{
+		const std::string label = voiCompositionRequirementLabel(bot, i);
+		if (!label.empty())
+		{
+			key += "|" + label;
+		}
+	}
+	key += "|min=" + std::to_string(std::max(0, bot.Commander().getVoiPolicyInt("scope.min_units", 0)));
+	key += "|max=" + std::to_string(std::max(0, bot.Commander().getVoiPolicyInt("scope.max_units", 0)));
+	key += "|route=" + bot.Commander().getVoiPolicyString("route_intent.route_type", "");
+	key += "|location=" + bot.Commander().getVoiPolicyString("tactical_task.location_intent", "");
+	return key;
+}
