+bool voiAdaptiveSupportProductionActive(
+	CCBot & bot,
+	const std::string & policyUnitType)
+{
+	// Preserve already-produced adaptive units for squad ownership, but do not
+	// add an optional counter that cannot fit under the completed hard cap.
+	if (bot.GetMaxSupply() < 200)
+	{
+		return true;
+	}
+	for (const auto & entry : voiExactCompositionTypes())
+	{
+		if (entry.first == policyUnitType)
+		{
+			const int freeSupply =
+				std::max(0, bot.GetMaxSupply() - bot.GetCurrentSupply());
+			return freeSupply >= std::max(
+				0,
+				entry.second.getUnitType().supplyRequired());
+		}
+	}
+	return false;
+}
