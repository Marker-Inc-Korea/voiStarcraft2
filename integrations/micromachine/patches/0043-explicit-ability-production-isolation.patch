+bool voiExplicitAbilityCasterPending(CCBot & bot)
+{
+	if (!bot.Commander().isVoiPolicyActive()
+		|| !voiTacticalTaskWithinDuration(bot)
+		|| bot.Commander().getVoiPolicyString(
+			"tactical_task.task_type",
+			"") != "execute_ability")
+	{
+		return false;
+	}
+
+	const std::string ability =
+		bot.Commander().getVoiPolicyString(
+			"tactical_task.ability",
+			"");
+	if (ability.empty() || ability == "tactical_nuke")
+	{
+		return false;
+	}
+
+	const std::string requestedUnitClasses =
+		bot.Commander().getVoiPolicyString(
+			"tactical_task.unit_classes",
+			"");
+	bool hasCasterClass = false;
+	bool casterRepresented = false;
+	const auto observeCaster =
+		[&](
+			const std::string & policyUnitType,
+			const MetaType & type)
+		{
+			if (!voiCommaListContains(
+					requestedUnitClasses,
+					policyUnitType))
+			{
+				return;
+			}
+			hasCasterClass = true;
+			casterRepresented =
+				casterRepresented
+				|| voiRepresentedUnitCount(bot, type) > 0;
+		};
+
+	observeCaster("TERRAN_MARINE", MetaTypeEnum::Marine);
+	observeCaster("TERRAN_MARAUDER", MetaTypeEnum::Marauder);
+	observeCaster("TERRAN_REAPER", MetaTypeEnum::Reaper);
+	observeCaster("TERRAN_GHOST", MetaTypeEnum::Ghost);
+	observeCaster("TERRAN_HELLION", MetaTypeEnum::Hellion);
+	observeCaster("TERRAN_WIDOWMINE", MetaTypeEnum::WidowMine);
+	observeCaster("TERRAN_CYCLONE", MetaTypeEnum::Cyclone);
+	observeCaster("TERRAN_THOR", MetaTypeEnum::Thor);
+	observeCaster("TERRAN_SIEGETANK", MetaTypeEnum::SiegeTank);
+	observeCaster("TERRAN_MEDIVAC", MetaTypeEnum::Medivac);
+	observeCaster("TERRAN_VIKINGFIGHTER", MetaTypeEnum::Viking);
+	observeCaster("TERRAN_LIBERATOR", MetaTypeEnum::Liberator);
+	observeCaster("TERRAN_BANSHEE", MetaTypeEnum::Banshee);
+	observeCaster("TERRAN_RAVEN", MetaTypeEnum::Raven);
+	observeCaster(
+		"TERRAN_BATTLECRUISER",
+		MetaTypeEnum::Battlecruiser);
+	return hasCasterClass && !casterRepresented;
+}
