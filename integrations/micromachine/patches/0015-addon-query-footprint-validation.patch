+bool voiStaticUnitOccupiesTile(const Unit & unit, const CCTilePosition & tile)
+{
+	// Use the same radius-derived bounds as CombatCommander's blocked-tile
+	// map. UnitType::tileWidth() depends on a build ability and is not reliable
+	// for every neutral or special map object.
+	CCTilePosition bottomLeft;
+	CCTilePosition topRight;
+	unit.getBuildingLimits(bottomLeft, topRight);
+	return tile.x >= bottomLeft.x
+		&& tile.x < topRight.x
+		&& tile.y >= bottomLeft.y
+		&& tile.y < topRight.y;
+}
