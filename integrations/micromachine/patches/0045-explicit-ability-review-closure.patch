+bool voiExplicitAbilityBlocksAutonomousAction(
+	const std::string & abilityName,
+	const UnitAction & action)
+{
+	sc2::AbilityID blockedAbility = sc2::AbilityID(0);
+	if (abilityName == "siege_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_UNSIEGE;
+	}
+	else if (abilityName == "unsiege")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_SIEGEMODE;
+	}
+	else if (abilityName == "widow_mine_burrow")
+	{
+		blockedAbility = sc2::ABILITY_ID::BURROWUP_WIDOWMINE;
+	}
+	else if (abilityName == "widow_mine_unburrow")
+	{
+		blockedAbility = sc2::ABILITY_ID::BURROWDOWN_WIDOWMINE;
+	}
+	else if (abilityName == "ghost_cloak")
+	{
+		blockedAbility = sc2::ABILITY_ID::BEHAVIOR_CLOAKOFF_GHOST;
+	}
+	else if (abilityName == "ghost_decloak")
+	{
+		blockedAbility = sc2::ABILITY_ID::BEHAVIOR_CLOAKON_GHOST;
+	}
+	else if (abilityName == "hellbat_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_HELLION;
+	}
+	else if (abilityName == "hellion_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_HELLBAT;
+	}
+	else if (abilityName == "thor_high_impact_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_THOREXPLOSIVEMODE;
+	}
+	else if (abilityName == "thor_explosive_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_THORHIGHIMPACTMODE;
+	}
+	else if (abilityName == "viking_fighter_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_VIKINGASSAULTMODE;
+	}
+	else if (abilityName == "viking_assault_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_VIKINGFIGHTERMODE;
+	}
+	else if (abilityName == "liberator_defender_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_LIBERATORAAMODE;
+	}
+	else if (abilityName == "liberator_fighter_mode")
+	{
+		blockedAbility = sc2::ABILITY_ID::MORPH_LIBERATORAGMODE;
+	}
+	else if (abilityName == "banshee_cloak")
+	{
+		blockedAbility = sc2::ABILITY_ID::BEHAVIOR_CLOAKOFF;
+	}
+	else if (abilityName == "banshee_decloak")
+	{
+		blockedAbility = sc2::ABILITY_ID::BEHAVIOR_CLOAKON;
+	}
+	return blockedAbility != sc2::AbilityID(0)
+		&& action.abilityID == blockedAbility;
+}
