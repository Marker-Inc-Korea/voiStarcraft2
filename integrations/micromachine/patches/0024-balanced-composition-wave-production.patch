+void ProductionManager::refreshVoiCompositionProductionWaveMultiplier()
+{
+	if (!voiContinuousCompositionProductionConfigured(m_bot))
+	{
+		m_voiCompositionProductionOperationKey = "";
+		m_voiCompositionProductionWaveMultiplier = 1;
+		return;
+	}
+
+	std::string operationKey =
+		m_bot.Commander().getVoiPolicyString("update_id", "")
+		+ "|" + std::to_string(std::max(
+			0,
+			m_bot.Commander().getVoiPolicyInt("issued_at_frame", 0)));
+	for (const auto & entry : voiExactCompositionTypes())
+	{
+		const int requested = voiRequestedCompositionCount(m_bot, entry.first);
+		if (requested > 0)
+		{
+			operationKey += "|" + entry.first + ":" + std::to_string(requested);
+		}
+	}
+	if (m_voiCompositionProductionOperationKey != operationKey)
+	{
+		m_voiCompositionProductionOperationKey = operationKey;
+		m_voiCompositionProductionWaveMultiplier = 1;
+	}
+
+	// The latch is monotonic for the operation. Combat losses may require
+	// replacements, but they must not lower the cumulative target and strand
+	// an incomplete reinforcement wave at home.
+	const int observedWaveMultiplier =
+		voiCompositionProductionWaveMultiplier(m_bot);
+	if (observedWaveMultiplier > m_voiCompositionProductionWaveMultiplier)
+	{
+		m_voiCompositionProductionWaveMultiplier = observedWaveMultiplier;
+		Util::Log(
+			__FUNCTION__,
+			"VOI advanced balanced composition production wave multiplier="
+				+ std::to_string(m_voiCompositionProductionWaveMultiplier)
+				+ " operation=" + operationKey,
+			m_bot);
+	}
+}
