+bool voiContinuousCompositionProductionActive(CCBot & bot)
+{
+	if (!voiExactCompositionActive(bot)
+		|| bot.Commander().getVoiPolicyString("tactical_task.task_type", "") != "pressure_with_main_army"
+		|| bot.Commander().getVoiPolicyFloat("production.production_continuity_bias", 0.0f) <= 0.25f)
+	{
+		return false;
+	}
+
+	// Do not leave an oversized unit queued forever once the hard supply cap is
+	// nearly full. Production resumes automatically as combat losses free room.
+	return bot.GetMaxSupply() < 200 || bot.GetCurrentSupply() < 196;
+}
+
+int voiCompositionProductionWaveMultiplier(CCBot & bot)
+{
+	int requestedTotal = 0;
+	int representedTotal = 0;
+	for (const auto & entry : voiExactCompositionTypes())
+	{
+		const int requested = voiRequestedCompositionCount(bot, entry.first);
+		if (requested <= 0)
+		{
+			continue;
+		}
+		requestedTotal += requested;
+		representedTotal += voiRepresentedUnitCount(bot, entry.second);
+	}
+
+	if (requestedTotal <= 0)
+	{
+		return 1;
+	}
+	return std::max(1, representedTotal / requestedTotal + 1);
+}
+
+int voiCompositionProductionTargetCount(CCBot & bot, const std::string & policyUnitType)
+{
+	const int requested = voiRequestedCompositionCount(bot, policyUnitType);
+	if (requested <= 0 || !voiContinuousCompositionProductionActive(bot))
+	{
+		return requested;
+	}
+	return requested * voiCompositionProductionWaveMultiplier(bot);
+}
