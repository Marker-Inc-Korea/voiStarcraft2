+			if (buildNukeIndex < abilityData.size())
+			{
+				const sc2::AbilityData & buildNukeData =
+					abilityData[buildNukeIndex];
+				std::ostringstream abilityDiagnostic;
+				abilityDiagnostic
+					<< "VOI tactical nuke ability data"
+					<< " available=" << buildNukeData.available
+					<< " ability_id="
+					<< static_cast<uint32_t>(buildNukeData.ability_id)
+					<< " link_name=" << buildNukeData.link_name
+					<< " button_name=" << buildNukeData.button_name
+					<< " remaps_to=" << buildNukeData.remaps_to_ability_id
+					<< " remaps_from_count="
+					<< buildNukeData.remaps_from_ability_id.size();
+				Util::Log(__FUNCTION__, abilityDiagnostic.str(), m_bot);
+			}
+		}
+		if (!directSubmissionEligible)
+		{
+			if (shouldLogAvailability)
+			{
+				Util::Log(
+					__FUNCTION__,
+					"VOI tactical nuke direct submission is state-blocked; command not submitted.",
+					m_bot);
+			}
+			return false;
+		}
+		if (!normalAllowsNuke && shouldLogAvailability)
+		{
+			Util::Log(
+				__FUNCTION__,
+				"VOI tactical nuke ability query omission tolerated; state/resource gate permits direct BUILD_NUKE submission.",
+				m_bot);
+		}
+		return true;
+	}
 
 	// quick check if the unit can't do anything it certainly can't build the thing we want
 	if (available_abilities.abilities.empty())
