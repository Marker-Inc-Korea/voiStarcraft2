+
+bool voiTacticalNukeEffectNear(CCBot & bot, const CCPosition & position)
+{
+	const float overlapRadiusSq = (TacticalNukeDamageRadius * 2.0f)
+		* (TacticalNukeDamageRadius * 2.0f);
+	for (const auto & effect : bot.Observation()->GetEffects())
+	{
+		if (effect.effect_id != NukePersistentEffectId)
+		{
+			continue;
+		}
+		for (const auto & effectPosition : effect.positions)
+		{
+			if (Util::DistSq(position, effectPosition) <= overlapRadiusSq)
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+bool voiUnsafeFriendlyUnitNear(
+	CCBot & bot,
+	const CCPosition & position,
+	float radius)
+{
+	const float radiusSq = radius * radius;
+	for (const auto & ally : bot.UnitInfo().getUnits(Players::Self))
+	{
+		if (ally.isValid()
+			&& ally.isAlive()
+			&& Util::DistSq(position, ally.getPosition()) <= radiusSq
+			&& (ally.getType().isBuilding()
+				|| ally.getType().isWorker()))
+		{
+			return true;
+		}
+	}
+	return false;
+}
+
+int voiMobileFriendlyUnitCountNear(
+	CCBot & bot,
+	const CCPosition & position,
+	float radius,
+	uint64_t excludedTag = 0)
+{
+	const float radiusSq = radius * radius;
+	int count = 0;
+	for (const auto & ally : bot.UnitInfo().getUnits(Players::Self))
+	{
+		if (ally.isValid()
+			&& ally.isAlive()
+			&& ally.getTag() != excludedTag
+			&& !ally.getType().isBuilding()
+			&& !ally.getType().isWorker()
+			&& Util::DistSq(position, ally.getPosition()) <= radiusSq)
+		{
+			count++;
+		}
+	}
+	return count;
+}
