+bool voiGhostHasTacticalNukeOrder(CCBot & bot, uint64_t ghostTag)
+{
+	if (ghostTag == 0)
+	{
+		return false;
+	}
+	for (const auto & ally : bot.UnitInfo().getUnits(Players::Self))
+	{
+		const sc2::Unit * unit = ally.getUnitPtr();
+		if (unit == nullptr
+			|| !unit->is_alive
+			|| unit->tag != ghostTag
+			|| unit->unit_type != sc2::UNIT_TYPEID::TERRAN_GHOST)
+		{
+			continue;
+		}
+		for (const auto & order : unit->orders)
+		{
+			if (order.ability_id
+				== sc2::ABILITY_ID::EFFECT_NUKECALLDOWN)
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+int voiTacticalNukePayloadCount(CCBot & bot)
+{
+	sc2::Units ghosts;
+	for (const auto & ally : bot.UnitInfo().getUnits(Players::Self))
+	{
+		const sc2::Unit * unit = ally.getUnitPtr();
+		if (unit != nullptr
+			&& unit->is_alive
+			&& unit->build_progress >= 1.0f
+			&& unit->unit_type == sc2::UNIT_TYPEID::TERRAN_GHOST)
+		{
+			ghosts.push_back(unit);
+		}
+	}
+	if (ghosts.empty())
+	{
+		return 0;
+	}
+
+	int availableGhostCount = 0;
+	for (const auto & abilities : bot.Query()->GetAbilitiesForUnits(ghosts))
+	{
+		if (Util::IsAbilityAvailable(
+			sc2::ABILITY_ID::EFFECT_NUKECALLDOWN,
+			abilities))
+		{
+			availableGhostCount++;
+		}
+	}
+	return availableGhostCount;
+}
