+CCPosition voiTacticalNukeContainmentPosition(
+	CCBot & bot,
+	const CCPosition & target)
+{
+	if (target == CCPosition())
+	{
+		return voiHomePosition(bot);
+	}
+	const float safetyMargin = std::max(
+		0.0f,
+		bot.Commander().getVoiPolicyFloat(
+			"tactical_task.safety_margin",
+			0.0f));
+	const float containmentRadius =
+		TacticalNukeDamageRadius + safetyMargin + 6.0f;
+	const CCPosition targetToHome = voiHomePosition(bot) - target;
+	const float baseAngle = std::atan2(targetToHome.y, targetToHome.x);
+	for (float angleOffset : {
+		0.0f,
+		0.523599f,
+		-0.523599f,
+		1.047198f,
+		-1.047198f,
+		1.570796f,
+		-1.570796f})
+	{
+		const float angle = baseAngle + angleOffset;
+		const CCPosition candidate =
+			target
+				+ CCPosition(std::cos(angle), std::sin(angle))
+					* containmentRadius;
+		if (bot.Map().isValidPosition(candidate)
+			&& bot.Map().isWalkable(candidate)
+			&& bot.Map().isConnected(voiHomePosition(bot), candidate))
+		{
+			return candidate;
+		}
+	}
+	return voiHomePosition(bot);
+}
