+bool voiSelectTacticalNukeTarget(
+	CCBot & bot,
+	const CCPosition & preferredPosition,
+	VoiTacticalNukeTarget & selectedTarget)
+{
+	const uint32_t currentFrame = bot.GetCurrentFrame();
+	const float safetyMargin = std::max(
+		0.0f,
+		bot.Commander().getVoiPolicyFloat("tactical_task.safety_margin", 0.0f));
+	const float friendlyExclusionRadius =
+		TacticalNukeDamageRadius + safetyMargin;
+	bool found = false;
+
+	for (const auto & candidateUnit : bot.UnitInfo().getUnits(Players::Enemy))
+	{
+		const sc2::Unit * candidate = candidateUnit.getUnitPtr();
+		if (candidate == nullptr || !candidate->is_alive || candidate->last_seen_game_loop == 0)
+		{
+			continue;
+		}
+		const uint32_t lastSeenFrame = candidate->last_seen_game_loop;
+		const UnitType candidateType(candidate->unit_type, bot);
+		const uint32_t candidateObservationWindow =
+			candidateType.isBuilding()
+				? TacticalNukeKnownBuildingObservationWindowFrames
+				: TacticalNukeRecentMobileObservationWindowFrames;
+		if (currentFrame < lastSeenFrame
+			|| currentFrame - lastSeenFrame > candidateObservationWindow)
+		{
+			continue;
+		}
+		if (voiUnsafeFriendlyUnitNear(
+				bot,
+				candidate->pos,
+				friendlyExclusionRadius)
+			|| voiTacticalNukeEffectNear(bot, candidate->pos))
+		{
+			continue;
+		}
+
+		int clusterCount = 0;
+		float clusterValue = 0.0f;
+		uint32_t newestObservationFrame = lastSeenFrame;
+		for (const auto & nearbyUnit : bot.UnitInfo().getUnits(Players::Enemy))
+		{
+			const sc2::Unit * nearby = nearbyUnit.getUnitPtr();
+			if (nearby == nullptr || !nearby->is_alive || nearby->last_seen_game_loop == 0)
+			{
+				continue;
+			}
+			const uint32_t nearbyLastSeen = nearby->last_seen_game_loop;
+			const UnitType nearbyType(nearby->unit_type, bot);
+			const uint32_t nearbyObservationWindow =
+				nearbyType.isBuilding()
+					? TacticalNukeKnownBuildingObservationWindowFrames
+					: TacticalNukeRecentMobileObservationWindowFrames;
+			if (currentFrame < nearbyLastSeen
+				|| currentFrame - nearbyLastSeen > nearbyObservationWindow
+				|| Util::DistSq(candidate->pos, nearby->pos)
+					> TacticalNukeDamageRadius * TacticalNukeDamageRadius)
+			{
+				continue;
+			}
+			clusterCount++;
+			newestObservationFrame = std::max(newestObservationFrame, nearbyLastSeen);
+			clusterValue += static_cast<float>(
+				nearbyType.mineralPrice() + nearbyType.gasPrice() * 2);
+			if (nearbyType.isBuilding())
+			{
+				clusterValue += 125.0f;
+			}
+			if (nearbyType.isResourceDepot())
+			{
+				clusterValue += 400.0f;
+			}
+		}
+
+		const bool highValueTarget = candidateType.isBuilding()
+			|| candidateType.isResourceDepot()
+			|| candidateType.mineralPrice() + candidateType.gasPrice() * 2 >= 300;
+		if (clusterCount < 3 && !highValueTarget)
+		{
+			continue;
+		}
+
+		const int mobileFriendlyCount = voiMobileFriendlyUnitCountNear(
+			bot,
+			candidate->pos,
+			friendlyExclusionRadius);
+		float score = clusterValue
+			+ static_cast<float>(clusterCount) * 150.0f
+			- static_cast<float>(mobileFriendlyCount) * 800.0f;
+		if (preferredPosition != CCPosition()
+			&& Util::DistSq(preferredPosition, candidate->pos) <= 6.0f * 6.0f)
+		{
+			score += 5000.0f;
+		}
+		if (!found || score > selectedTarget.score)
+		{
+			found = true;
+			selectedTarget.position = candidate->pos;
+			selectedTarget.observationFrame = newestObservationFrame;
+			selectedTarget.score = score;
+		}
+	}
+	return found;
+}
