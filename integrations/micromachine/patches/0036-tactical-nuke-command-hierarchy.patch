+void CombatCommander::updateVoiTacticalNukeAction()
+{
+	const std::string updateId =
+		m_bot.Commander().getVoiPolicyString("update_id", "");
+	if (updateId != m_voiTacticalNukeUpdateId)
+	{
+		m_voiTacticalNukeUpdateId = updateId;
+		m_lastVoiTacticalNukeStatus = "inactive";
+		m_lastVoiTacticalNukeReason = "No tactical nuke ability task requested";
+		m_lastVoiTacticalNukeGhostTag = 0;
+		m_lastVoiTacticalNukeTarget = CCPosition();
+		m_lastVoiTacticalNukeStagingPosition = CCPosition();
+		m_lastVoiTacticalNukeTargetObservationFrame = 0;
+		m_lastVoiTacticalNukeReservedGhostCount = 0;
+		m_lastVoiTacticalNukeAvailableGhostCount = 0;
+		m_lastVoiTacticalNukeStagingCommandIssuedCount = 0;
+		m_lastVoiTacticalNukeStagingCommandFrame = 0;
+		m_lastVoiTacticalNukeStagingIssuedAction = "";
+		m_lastVoiTacticalNukeCastAttemptedCount = 0;
+		m_lastVoiTacticalNukeCastSubmittedCount = 0;
+		m_lastVoiTacticalNukeCastSubmissionFrame = 0;
+		m_lastVoiTacticalNukeCastSubmittedAction = "";
+		m_lastVoiTacticalNukePayloadCountAtSubmission = -1;
+		m_lastVoiTacticalNukeConfirmationState = "unconfirmed";
+		m_lastVoiTacticalNukeConfirmationCount = 0;
+		m_lastVoiTacticalNukeConfirmationFrame = 0;
+		m_lastVoiTacticalNukeConfirmationEffect = "";
+	}
+
+	if (!voiTacticalNukeTaskRequested(m_bot))
+	{
+		m_lastVoiTacticalNukeStatus = "inactive";
+		m_lastVoiTacticalNukeReason =
+			"No active execute_ability tactical_task.ability=tactical_nuke request";
+		return;
+	}
+	const bool hasExplicitGhostRole =
+		voiHasTacticalNukeGhostRole(m_bot);
+	const uint32_t currentFrame = m_bot.GetGameLoop();
+	if (m_lastVoiTacticalNukeConfirmationCount > 0)
+	{
+		m_lastVoiTacticalNukeStatus = "confirmed";
+		m_lastVoiTacticalNukeReason =
+			"Tactical nuke cast already has SC2 observation confirmation for this update";
+		return;
+	}
+	if (m_lastVoiTacticalNukeCastSubmittedCount > 0)
+	{
+		std::string confirmationEffect;
+		std::string confirmationReason;
+		if (voiGhostHasTacticalNukeOrder(
+				m_bot,
+				m_lastVoiTacticalNukeGhostTag))
+		{
+			confirmationEffect =
+				"ghost_order:EFFECT_NUKECALLDOWN";
+			confirmationReason =
+				"SC2 observation reports the selected Ghost channeling EFFECT_NUKECALLDOWN";
+		}
+		else if (m_lastVoiTacticalNukeTarget != CCPosition()
+			&& voiTacticalNukeEffectNear(
+				m_bot,
+				m_lastVoiTacticalNukeTarget))
+		{
+			confirmationEffect =
+				"persistent_effect:NUKEPERSISTENT";
+			confirmationReason =
+				"SC2 observation reports NUKEPERSISTENT at the submitted target";
+		}
+		else if (m_lastVoiTacticalNukePayloadCountAtSubmission > 0
+			&& voiTacticalNukeGhostAlive(
+				m_bot,
+				m_lastVoiTacticalNukeGhostTag)
+			&& voiTacticalNukePayloadCount(m_bot)
+				< m_lastVoiTacticalNukePayloadCountAtSubmission)
+		{
+			confirmationEffect =
+				"payload_consumed:TERRAN_NUKE";
+			confirmationReason =
+				"SC2 observation reports the submitted tactical nuke payload was consumed";
+		}
+
+		if (!confirmationEffect.empty())
+		{
+			m_lastVoiTacticalNukeConfirmationState = "confirmed";
+			m_lastVoiTacticalNukeConfirmationCount++;
+			m_lastVoiTacticalNukeConfirmationFrame = currentFrame;
+			m_lastVoiTacticalNukeConfirmationEffect =
+				confirmationEffect;
+			m_lastVoiTacticalNukeStatus = "confirmed";
+			m_lastVoiTacticalNukeReason = confirmationReason;
+			return;
+		}
+
+		const bool retryDelayElapsed =
+			currentFrame >= m_lastVoiTacticalNukeCastSubmissionFrame
+			&& currentFrame
+				- m_lastVoiTacticalNukeCastSubmissionFrame
+				>= TacticalNukeConfirmationRetryFrames;
+		if (!retryDelayElapsed)
+		{
+			m_lastVoiTacticalNukeConfirmationState = "pending";
+			m_lastVoiTacticalNukeStatus = "confirming";
+			m_lastVoiTacticalNukeReason =
+				"EFFECT_NUKECALLDOWN was submitted; waiting for Ghost order, NUKEPERSISTENT, or payload-consumption observation";
+			return;
+		}
+		m_lastVoiTacticalNukeConfirmationState = "retryable";
+		m_lastVoiTacticalNukeStatus = "retrying";
+		m_lastVoiTacticalNukeReason =
+			"No SC2 confirmation followed the prior submission; retry is allowed without marking completion";
+	}
+
+	VoiTacticalNukeTarget selectedTarget;
+	if (!voiSelectTacticalNukeTarget(
+			m_bot,
+			m_lastVoiTacticalNukeTarget,
+			selectedTarget))
+	{
+		m_lastVoiTacticalNukeStatus = "waiting_target";
+		m_lastVoiTacticalNukeReason =
+			"Waiting for a safe recently observed high-value or clustered enemy target";
+		m_lastVoiTacticalNukeTarget = CCPosition();
+		m_lastVoiTacticalNukeStagingPosition = CCPosition();
+		m_lastVoiTacticalNukeTargetObservationFrame = 0;
+		return;
+	}
+	m_lastVoiTacticalNukeTarget = selectedTarget.position;
+	m_lastVoiTacticalNukeTargetObservationFrame =
+		selectedTarget.observationFrame;
+
+	float castRange = TacticalNukeCastRange;
+	const auto castRangeIt =
+		m_abilityCastingRanges.find(sc2::ABILITY_ID::EFFECT_NUKECALLDOWN);
+	if (castRangeIt != m_abilityCastingRanges.end()
+		&& castRangeIt->second > 0.0f)
+	{
+		castRange = castRangeIt->second;
+	}
+	const float usableCastRange = std::max(1.0f, castRange - 0.25f);
+	const float usableCastRangeSq = usableCastRange * usableCastRange;
+	const float safetyMargin = std::max(
+		0.0f,
+		m_bot.Commander().getVoiPolicyFloat(
+			"tactical_task.safety_margin",
+			0.0f));
+	const float minimumSafeCastRadius =
+		TacticalNukeDamageRadius + std::max(1.0f, safetyMargin);
+	const float minimumSafeCastRadiusSq =
+		minimumSafeCastRadius * minimumSafeCastRadius;
+
+	const auto findStagingPosition =
+		[&](const sc2::Unit * ghost, CCPosition & stagingPosition, float & stagingScore)
+	{
+		if (ghost == nullptr)
+		{
+			return false;
+		}
+		if (minimumSafeCastRadius >= usableCastRange)
+		{
+			return false;
+		}
+		const float minimumCandidateRadius =
+			std::min(
+				usableCastRange - 0.1f,
+				minimumSafeCastRadius + 0.25f);
+		const float maximumCandidateRadius =
+			std::max(
+				minimumCandidateRadius,
+				usableCastRange - 0.1f);
+		const float preferredStagingRadius =
+			std::min(
+				maximumCandidateRadius,
+				std::max(
+					TacticalNukeDefaultStagingRadius,
+					minimumCandidateRadius));
+		const CCPosition targetToGhost = ghost->pos - selectedTarget.position;
+		const float baseAngle = std::atan2(targetToGhost.y, targetToGhost.x);
+		bool found = false;
+		stagingScore = 0.0f;
+		for (float stagingRadius : {
+			preferredStagingRadius,
+			minimumCandidateRadius,
+			(minimumCandidateRadius + maximumCandidateRadius) * 0.5f,
+			maximumCandidateRadius})
+		{
+			for (int angleIndex = 0; angleIndex < 32; ++angleIndex)
+			{
+				const float angle =
+					baseAngle
+					+ static_cast<float>(angleIndex) * 0.19634954f;
+				const CCPosition candidate =
+					selectedTarget.position
+					+ CCPosition(std::cos(angle), std::sin(angle))
+						* stagingRadius;
+				if (!m_bot.Map().isValidPosition(candidate)
+					|| !m_bot.Map().isWalkable(candidate)
+					|| !m_bot.Map().isConnected(ghost->pos, candidate))
+				{
+					continue;
+				}
+				const float targetDistanceSq =
+					Util::DistSq(candidate, selectedTarget.position);
+				if (targetDistanceSq < minimumSafeCastRadiusSq
+					|| targetDistanceSq > usableCastRangeSq)
+				{
+					continue;
+				}
+				const float influence = std::max(
+					0.0f,
+					getTotalGroundInfluence(Util::GetTilePosition(candidate)));
+				const float travelDistance =
+					Util::Dist(ghost->pos, candidate);
+				const float radiusPenalty =
+					std::abs(stagingRadius - preferredStagingRadius) * 10.0f;
+				const float candidateScore =
+					influence * 100.0f
+					+ travelDistance
+					+ radiusPenalty;
+				if (!found || candidateScore < stagingScore)
+				{
+					found = true;
+					stagingPosition = candidate;
+					stagingScore = candidateScore;
+				}
+			}
+		}
+		return found;
+	};
+
+	const sc2::Unit * selectedGhost = nullptr;
+	CCPosition selectedStagingPosition;
+	float selectedGhostScore = 0.0f;
+	int ghostCount = 0;
+	m_lastVoiTacticalNukeAvailableGhostCount = 0;
+	for (const auto & combatUnit : m_combatUnits)
+	{
+		if (!combatUnit.isValid()
+			|| !combatUnit.isAlive()
+			|| combatUnit.getAPIUnitType()
+				!= sc2::UNIT_TYPEID::TERRAN_GHOST
+			|| !m_squadData.squadExists("NukeOps")
+			|| m_squadData.getUnitSquad(combatUnit)
+				!= &m_squadData.getSquad("NukeOps"))
+		{
+			continue;
+		}
+		ghostCount++;
+		const sc2::Unit * ghost = combatUnit.getUnitPtr();
+		if (!Util::IsAbilityAvailable(
+			sc2::ABILITY_ID::EFFECT_NUKECALLDOWN,
+			ghost,
+			m_unitsAbilities))
+		{
+			continue;
+		}
+		m_lastVoiTacticalNukeAvailableGhostCount++;
+		const float targetDistanceSq =
+			Util::DistSq(ghost->pos, selectedTarget.position);
+		CCPosition stagingPosition = ghost->pos;
+		float ghostScore = targetDistanceSq;
+		if (targetDistanceSq > usableCastRangeSq
+			|| targetDistanceSq < minimumSafeCastRadiusSq)
+		{
+			float stagingScore = 0.0f;
+			if (!findStagingPosition(ghost, stagingPosition, stagingScore))
+			{
+				continue;
+			}
+			ghostScore = stagingScore + 100000.0f;
+		}
+		if (selectedGhost == nullptr || ghostScore < selectedGhostScore)
+		{
+			selectedGhost = ghost;
+			selectedStagingPosition = stagingPosition;
+			selectedGhostScore = ghostScore;
+		}
+	}
+
+	if (ghostCount == 0)
+	{
+		m_lastVoiTacticalNukeStatus = "waiting_ghost";
+		m_lastVoiTacticalNukeReason =
+			"Waiting for ProductionManager to provide a Ghost";
+		m_lastVoiTacticalNukeGhostTag = 0;
+		return;
+	}
+	if (m_lastVoiTacticalNukeAvailableGhostCount == 0)
+	{
+		m_lastVoiTacticalNukeStatus = "waiting_payload";
+		m_lastVoiTacticalNukeReason =
+			"Ghost exists but EFFECT_NUKECALLDOWN is unavailable";
+		m_lastVoiTacticalNukeGhostTag = 0;
+		return;
+	}
+	if (selectedGhost == nullptr)
+	{
+		m_lastVoiTacticalNukeStatus = "refused";
+		m_lastVoiTacticalNukeReason =
+			"No terrain-connected safe cast staging position within tactical nuke range";
+		m_lastVoiTacticalNukeGhostTag = 0;
+		return;
+	}
+
+	m_lastVoiTacticalNukeGhostTag = selectedGhost->tag;
+	const float targetDistanceSq =
+		Util::DistSq(selectedGhost->pos, selectedTarget.position);
+	if (targetDistanceSq > usableCastRangeSq
+		|| targetDistanceSq < minimumSafeCastRadiusSq)
+	{
+		m_lastVoiTacticalNukeStagingPosition = selectedStagingPosition;
+		const UnitAction stagingAction(
+			MicroActionType::Move,
+			selectedStagingPosition,
+			true,
+			0,
+			"VoiTacticalNukeStage",
+			"");
+		PlanAction(selectedGhost, stagingAction);
+		m_lastVoiTacticalNukeStatus = "staging";
+		m_lastVoiTacticalNukeReason = hasExplicitGhostRole
+			? "Role-mapped Ghost is moving to the lowest-risk pathable staging position before cast"
+			: "Canonical tactical_task selected a Ghost and is moving it to the lowest-risk pathable staging position before cast";
+		return;
+	}
+	const float friendlyExclusionRadius =
+		TacticalNukeDamageRadius + safetyMargin;
+	if (voiMobileFriendlyUnitCountNear(
+			m_bot,
+			selectedTarget.position,
+			friendlyExclusionRadius,
+			selectedGhost->tag) > 0)
+	{
+		m_lastVoiTacticalNukeStatus = "clearing_blast_radius";
+		m_lastVoiTacticalNukeReason =
+			"Reserved target is valid; waiting for MainAttack and other mobile allies to clear the blast radius";
+		return;
+	}
+
+	m_lastVoiTacticalNukeStagingPosition = selectedGhost->pos;
+	const UnitAction castAction(
+		MicroActionType::AbilityPosition,
+		sc2::ABILITY_ID::EFFECT_NUKECALLDOWN,
+		selectedTarget.position,
+		true,
+		350,
+		"VoiRoleGhostTacticalNuke",
+		"");
+	if (PlanAction(selectedGhost, castAction))
+	{
+		m_lastVoiTacticalNukeCastAttemptedCount++;
+	}
+	m_lastVoiTacticalNukeStatus = "cast_planned";
+	m_lastVoiTacticalNukeReason = hasExplicitGhostRole
+		? "Role-mapped Ghost is in verified cast range; EFFECT_NUKECALLDOWN is planned for command issue"
+		: "Canonical tactical_task Ghost is in verified cast range; EFFECT_NUKECALLDOWN is planned for command issue";
+}
