+void CombatCommander::updateVoiTacticalNukeSquad()
+{
+	if (!m_squadData.squadExists("NukeOps"))
+	{
+		return;
+	}
+	Squad & nukeOpsSquad = m_squadData.getSquad("NukeOps");
+	nukeOpsSquad.setPriority(TacticalAbilityPriority);
+	m_lastVoiTacticalNukeReservedGhostCount = 0;
+	if (!voiTacticalNukeTaskRequested(m_bot))
+	{
+		std::vector<Unit> unitsToRelease = nukeOpsSquad.getUnits();
+		Squad & idleSquad = m_squadData.getSquad("Idle");
+		for (const auto & unit : unitsToRelease)
+		{
+			m_squadData.assignUnitToSquad(unit, idleSquad);
+		}
+		return;
+	}
+
+	Unit selectedGhost;
+	for (const auto & combatUnit : m_combatUnits)
+	{
+		if (!combatUnit.isValid()
+			|| !combatUnit.isAlive()
+			|| combatUnit.getAPIUnitType()
+				!= sc2::UNIT_TYPEID::TERRAN_GHOST)
+		{
+			continue;
+		}
+		if (combatUnit.getTag() == m_lastVoiTacticalNukeGhostTag)
+		{
+			selectedGhost = combatUnit;
+			break;
+		}
+		if (!selectedGhost.isValid()
+			|| (Util::IsAbilityAvailable(
+					sc2::ABILITY_ID::EFFECT_NUKECALLDOWN,
+					combatUnit.getUnitPtr(),
+					m_unitsAbilities)
+				&& !Util::IsAbilityAvailable(
+					sc2::ABILITY_ID::EFFECT_NUKECALLDOWN,
+					selectedGhost.getUnitPtr(),
+					m_unitsAbilities)))
+		{
+			selectedGhost = combatUnit;
+		}
+	}
+
+	std::vector<Unit> unitsToRelease;
+	for (const auto & unit : nukeOpsSquad.getUnits())
+	{
+		if (!selectedGhost.isValid()
+			|| unit.getTag() != selectedGhost.getTag())
+		{
+			unitsToRelease.push_back(unit);
+		}
+	}
+	Squad & idleSquad = m_squadData.getSquad("Idle");
+	for (const auto & unit : unitsToRelease)
+	{
+		m_squadData.assignUnitToSquad(unit, idleSquad);
+	}
+	if (!selectedGhost.isValid())
+	{
+		return;
+	}
+	if (m_squadData.getUnitSquad(selectedGhost) != &nukeOpsSquad)
+	{
+		m_squadData.assignUnitToSquad(selectedGhost, nukeOpsSquad);
+	}
+	m_lastVoiTacticalNukeReservedGhostCount = 1;
+	m_lastVoiUnitRole = "execute_ability";
+	m_lastVoiUnitRoleUnitType = "TERRAN_GHOST";
+	m_lastVoiUnitRoleUnitTag = selectedGhost.getTag();
+	m_lastVoiUnitRolePolicy = "tactical_nuke";
+	m_lastVoiUnitRoleStatus = "reserved";
+	m_lastVoiUnitRoleReason =
+		"Ghost is exclusively reserved in NukeOps and removed from ordinary attack/scout ownership";
+	m_lastVoiUnitRoleAbility = "tactical_nuke";
+	m_lastVoiUnitRoleIssuedAction = "";
+	m_lastVoiUnitRoleAvailableCount = 1;
+	m_lastVoiUnitRoleAttemptedCount = 0;
+	m_lastVoiUnitRoleExecutedCount = 0;
+	m_lastVoiUnitRoleFrame = m_bot.GetCurrentFrame();
+	nukeOpsSquad.setSquadOrder(SquadOrder(
+		SquadOrderTypes::Idle,
+		selectedGhost.getPosition(),
+		DefaultOrderRadius,
+		"Tactical nuke Ghost reserved"));
+}
