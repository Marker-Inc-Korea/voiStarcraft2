+
+void ProductionManager::refreshVoiTacticalNukePayloadSubmission()
+{
+	if (m_lastVoiTacticalNukePayloadStatus != "submitted")
+	{
+		return;
+	}
+
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	for (const auto & ghostAcademy :
+		m_bot.GetAllyUnits(sc2::UNIT_TYPEID::TERRAN_GHOSTACADEMY))
+	{
+		const sc2::Unit * academyUnit = ghostAcademy.getUnitPtr();
+		if (academyUnit == nullptr
+			|| !academyUnit->is_alive
+			|| academyUnit->tag != m_lastVoiTacticalNukePayloadProducerTag)
+		{
+			continue;
+		}
+		for (const auto & order : academyUnit->orders)
+		{
+			if (order.ability_id != sc2::ABILITY_ID::BUILD_NUKE)
+			{
+				continue;
+			}
+			m_lastVoiTacticalNukePayloadStatus = "accepted";
+			m_voiTacticalNukePayloadAcceptedCount++;
+			m_lastVoiTacticalNukePayloadAcceptedFrame = currentFrame;
+			recordVoiActualProductionCommand(
+				MetaTypeEnum::Nuke,
+				"build_nuke_accepted");
+			Util::Log(
+				__FUNCTION__,
+				"VOI tactical nuke payload command accepted by SC2 observation producer_tag="
+					+ std::to_string(m_lastVoiTacticalNukePayloadProducerTag)
+					+ " order=BUILD_NUKE.",
+				m_bot);
+			return;
+		}
+	}
+
+	constexpr uint32_t NukePayloadAcceptanceObservationFrames = 8;
+	if (currentFrame < m_lastVoiTacticalNukePayloadSubmissionFrame
+		|| currentFrame - m_lastVoiTacticalNukePayloadSubmissionFrame
+			< NukePayloadAcceptanceObservationFrames)
+	{
+		return;
