+bool voiTacticalNukeTaskRequested(CCBot & bot)
+{
+	return bot.Commander().isVoiPolicyActive()
+		&& voiTacticalTaskWithinDuration(bot)
+		&& bot.Commander().getVoiPolicyString("tactical_task.task_type", "") == "execute_ability"
+		&& bot.Commander().getVoiPolicyString("tactical_task.ability", "") == "tactical_nuke";
