+
+bool voiResolveTacticalNukeTargetAnchor(
+	CCBot & bot,
+	const std::string & locationIntent,
+	CCPosition & anchor,
+	float & radius)
+{
+	if (locationIntent == "enemy_main"
+		|| locationIntent == "enemy_base"
+		|| locationIntent == "enemy_start"
+		|| locationIntent == "enemy_start_location")
+	{
+		anchor = voiEnemyMainCombatTarget(bot);
+		radius = TacticalNukeEnemyMainIntentRadius;
+		const CCPosition observedTarget = voiObservedEnemyCombatTarget(bot);
+		if (observedTarget != CCPosition()
+			&& (anchor == CCPosition()
+				|| Util::Dist(anchor, observedTarget) <= radius))
+		{
+			anchor = observedTarget;
+		}
+		return true;
+	}
+	if (locationIntent == "enemy_natural"
+		|| locationIntent == "contain_enemy_natural"
+		|| locationIntent == "enemy_front")
+	{
+		anchor = voiEnemyNaturalCombatTarget(bot);
+		radius = TacticalNukeEnemyNaturalIntentRadius;
+		return true;
+	}
+	anchor = CCPosition();
+	radius = 0.0f;
+	return false;
 }
 
