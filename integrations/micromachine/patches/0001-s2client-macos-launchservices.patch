+class BootstrapProbe final : public sc2::Agent {
+public:
+    BootstrapProbe(std::string output_path, std::string map_file, int max_frame)
+        : output_path_(std::move(output_path))
+        , map_file_(std::move(map_file))
+        , max_frame_(max_frame) {
+    }
+
+    void OnGameStart() final {
+        saw_game_start_ = true;
+        capture("game_start");
+    }
+
+    void OnStep() final {
+        capture("step");
+        if (resource_depot_count_ > 0 && self_worker_count_ > 0) {
+            done_ = true;
+            failure_code_.clear();
+            return;
+        }
+        if (latest_frame_ >= static_cast<uint32_t>(max_frame_)) {
+            done_ = true;
+            failure_code_ = "bootstrap_no_start_units";
+        }
+    }
+
+    bool done() const {
+        return done_;
+    }
+
+    bool ok() const {
+        return failure_code_.empty() && resource_depot_count_ > 0 && self_worker_count_ > 0;
+    }
+
+    int exit_code() const {
+        return ok() ? 0 : 3;
+    }
+
+    void set_failure(const std::string& code) {
+        failure_code_ = code;
+        done_ = true;
+    }
+
