+        }
+        out << ",\n";
+        out << "  \"map_file\": \"" << json_escape(map_file_) << "\",\n";
+        out << "  \"saw_game_start\": " << (saw_game_start_ ? "true" : "false") << ",\n";
+        out << "  \"last_capture_phase\": \"" << json_escape(last_capture_phase_) << "\",\n";
+        out << "  \"latest_frame\": " << latest_frame_ << ",\n";
+        out << "  \"max_frame\": " << max_frame_ << ",\n";
+        out << "  \"player_id\": " << player_id_ << ",\n";
