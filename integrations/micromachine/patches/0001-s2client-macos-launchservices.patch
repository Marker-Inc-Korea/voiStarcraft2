+
+bool is_raw_terran_worker(int type) {
+    return type == static_cast<int>(sc2::UNIT_TYPEID::TERRAN_SCV);
+}
+
+bool is_raw_terran_resource_depot(int type) {
+    return type == static_cast<int>(sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER)
