+static bool VoiUseCreateGameMapData() {
+    const char* value = std::getenv("VOI_SC2_CREATEGAME_MAP_DATA");
+    return value != nullptr && std::string(value) == "1";
+}
+
+static void VoiAttachCreateGameMapData(SC2APIProtocol::LocalMap* local_map, const std::string& path) {
+    if (!VoiUseCreateGameMapData()) {
+        return;
+    }
+
+    std::ifstream file(path, std::ios::binary);
+    if (!file) {
+        std::cerr << "VOI_SC2_CREATEGAME_MAP_DATA failed to open map bytes: " << path << std::endl;
+        return;
+    }
+    file.seekg(0, std::ios::end);
+    const std::streamoff size = file.tellg();
+    if (size <= 0) {
+        std::cerr << "VOI_SC2_CREATEGAME_MAP_DATA rejected empty map bytes: " << path << std::endl;
+        return;
+    }
+    std::string data(static_cast<std::size_t>(size), '\0');
+    file.seekg(0, std::ios::beg);
+    file.read(&data[0], size);
+    if (!file) {
+        std::cerr << "VOI_SC2_CREATEGAME_MAP_DATA failed while reading map bytes: " << path << std::endl;
+        return;
+    }
+    local_map->set_map_data(data);
+    std::cerr << "VOI_SC2_CREATEGAME_MAP_DATA attached " << data.size() << " map bytes from " << path << std::endl;
+}
