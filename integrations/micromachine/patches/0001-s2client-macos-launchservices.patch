+            }
+            out << "{\"tag\": " << sample.tag
+                << ", \"type\": " << sample.type
+                << ", \"alliance\": " << sample.alliance
+                << ", \"owner\": " << sample.owner
+                << ", \"x\": " << sample.x
+                << ", \"y\": " << sample.y
+                << ", \"z\": " << sample.z
+                << ", \"build_progress\": " << sample.build_progress
+                << "}";
+        }
+        out << "],\n";
+        out << "  \"raw_observation_present\": " << (raw_observation_present_ ? "true" : "false") << ",\n";
+        out << "  \"raw_total_unit_count\": " << raw_total_unit_count_ << ",\n";
+        out << "  \"raw_self_count\": " << raw_self_count_ << ",\n";
+        out << "  \"raw_self_worker_count\": " << raw_self_worker_count_ << ",\n";
+        out << "  \"raw_resource_depot_count\": " << raw_resource_depot_count_ << ",\n";
+        out << "  \"raw_neutral_count\": " << raw_neutral_count_ << ",\n";
+        out << "  \"raw_enemy_count\": " << raw_enemy_count_ << ",\n";
+        out << "  \"raw_type_counts\": {";
+        bool first_raw_type = true;
+        for (const auto& item : raw_type_counts_) {
+            if (!first_raw_type) {
+                out << ", ";
+            }
+            first_raw_type = false;
+            out << "\"" << item.first << "\": " << item.second;
+        }
+        out << "},\n";
+        out << "  \"raw_sample_units\": [";
+        for (std::size_t i = 0; i < raw_sample_units_.size(); ++i) {
+            const UnitSample& sample = raw_sample_units_[i];
+            if (i != 0) {
+                out << ", ";
+            }
+            out << "{\"tag\": " << sample.tag
+                << ", \"type\": " << sample.type
+                << ", \"alliance\": " << sample.alliance
+                << ", \"owner\": " << sample.owner
+                << ", \"x\": " << sample.x
+                << ", \"y\": " << sample.y
+                << ", \"z\": " << sample.z
+                << ", \"build_progress\": " << sample.build_progress
+                << "}";
+        }
+        out << "]\n";
+        out << "}\n";
+    }
+
+private:
+    void capture(const std::string& phase) {
+        const sc2::ObservationInterface* obs = Observation();
+        if (obs == nullptr) {
+            return;
+        }
+
+        last_capture_phase_ = phase;
+        latest_frame_ = obs->GetGameLoop();
+        player_id_ = obs->GetPlayerID();
+        food_workers_ = obs->GetFoodWorkers();
+        food_cap_ = obs->GetFoodCap();
+        minerals_ = obs->GetMinerals();
+        vespene_ = obs->GetVespene();
+
+        const sc2::Point3D start = obs->GetStartLocation();
+        start_x_ = start.x;
+        start_y_ = start.y;
+        start_z_ = start.z;
+
+        total_unit_count_ = 0;
+        self_count_ = 0;
+        self_worker_count_ = 0;
+        resource_depot_count_ = 0;
+        neutral_count_ = 0;
+        enemy_count_ = 0;
+        type_counts_.clear();
+        sample_units_.clear();
+        raw_observation_present_ = false;
+        raw_total_unit_count_ = 0;
+        raw_self_count_ = 0;
+        raw_self_worker_count_ = 0;
+        raw_resource_depot_count_ = 0;
+        raw_neutral_count_ = 0;
+        raw_enemy_count_ = 0;
+        raw_type_counts_.clear();
+        raw_sample_units_.clear();
+
+        const sc2::Units units = obs->GetUnits();
+        total_unit_count_ = static_cast<int>(units.size());
+        for (const sc2::Unit* unit : units) {
+            if (unit == nullptr) {
+                continue;
+            }
+            const int type = static_cast<int>(unit->unit_type);
+            type_counts_[type] += 1;
+            if (sample_units_.size() < 24) {
+                sample_units_.push_back(UnitSample{
+                    unit->tag,
+                    type,
+                    static_cast<int>(unit->alliance),
+                    unit->owner,
+                    unit->pos.x,
+                    unit->pos.y,
+                    unit->pos.z,
+                    unit->build_progress,
+                });
+            }
+
+            if (unit->alliance == sc2::Unit::Alliance::Self) {
+                ++self_count_;
+                if (is_terran_worker(unit->unit_type)) {
+                    ++self_worker_count_;
+                }
+                if (is_terran_resource_depot(unit->unit_type)) {
+                    ++resource_depot_count_;
+                }
+            } else if (unit->alliance == sc2::Unit::Alliance::Neutral) {
+                ++neutral_count_;
+            } else if (unit->alliance == sc2::Unit::Alliance::Enemy) {
+                ++enemy_count_;
+            }
+        }
+
+        const SC2APIProtocol::Observation* raw_observation = obs->GetRawObservation();
+        if (raw_observation == nullptr || !raw_observation->has_raw_data()) {
+            return;
+        }
+
+        raw_observation_present_ = true;
+        const SC2APIProtocol::ObservationRaw& raw_data = raw_observation->raw_data();
+        raw_total_unit_count_ = raw_data.units_size();
+        for (int i = 0; i < raw_data.units_size(); ++i) {
+            const SC2APIProtocol::Unit& unit = raw_data.units(i);
+            const int type = static_cast<int>(unit.unit_type());
+            const int alliance = static_cast<int>(unit.alliance());
+            raw_type_counts_[type] += 1;
+            if (raw_sample_units_.size() < 24) {
+                raw_sample_units_.push_back(UnitSample{
+                    unit.tag(),
+                    type,
+                    alliance,
+                    unit.owner(),
+                    unit.pos().x(),
+                    unit.pos().y(),
+                    unit.pos().z(),
+                    unit.build_progress(),
+                });
+            }
+
+            if (unit.alliance() == SC2APIProtocol::Self) {
+                ++raw_self_count_;
+                if (is_raw_terran_worker(type)) {
+                    ++raw_self_worker_count_;
+                }
+                if (is_raw_terran_resource_depot(type)) {
+                    ++raw_resource_depot_count_;
+                }
+            } else if (unit.alliance() == SC2APIProtocol::Neutral) {
+                ++raw_neutral_count_;
+            } else if (unit.alliance() == SC2APIProtocol::Enemy) {
+                ++raw_enemy_count_;
+            }
+        }
+    }
+
+    std::string output_path_;
+    std::string map_file_;
+    int max_frame_;
+    bool saw_game_start_ = false;
+    bool done_ = false;
+    std::string failure_code_ = "probe_not_started";
+    std::string last_capture_phase_ = "none";
+    uint32_t latest_frame_ = 0;
+    uint32_t player_id_ = 0;
+    int total_unit_count_ = 0;
+    int self_count_ = 0;
+    int self_worker_count_ = 0;
+    int resource_depot_count_ = 0;
+    int neutral_count_ = 0;
+    int enemy_count_ = 0;
+    int food_workers_ = 0;
+    int food_cap_ = 0;
+    int minerals_ = 0;
+    int vespene_ = 0;
+    float start_x_ = 0.0f;
+    float start_y_ = 0.0f;
+    float start_z_ = 0.0f;
+    std::map<int, int> type_counts_;
+    std::vector<UnitSample> sample_units_;
+    bool raw_observation_present_ = false;
+    int raw_total_unit_count_ = 0;
+    int raw_self_count_ = 0;
+    int raw_self_worker_count_ = 0;
+    int raw_resource_depot_count_ = 0;
+    int raw_neutral_count_ = 0;
+    int raw_enemy_count_ = 0;
+    std::map<int, int> raw_type_counts_;
+    std::vector<UnitSample> raw_sample_units_;
+};
+
+}  // namespace
+
+int main(int argc, char* argv[]) {
+    const std::string output_path = getenv_or("PROBE_OUTPUT", "/private/tmp/voi-mm-bootstrap-probe/probe_report.json");
+    const std::string map_file = getenv_or("MAP_FILE", "AcropolisLE.SC2Map");
+    const int max_frame = getenv_int("PROBE_MAX_FRAME", 1200);
+    const int step_size = getenv_int("PROBE_STEP_SIZE", 1);
+    const int timeout_ms = getenv_int("SC2_ATTACH_TIMEOUT_MS", 120000);
+    const int port_start = getenv_int("SC2_PORT_START", 8168);
+    const sc2::Race enemy_race = parse_race(getenv_or("PROBE_ENEMY_RACE", "Zerg"), sc2::Race::Zerg);
+    const sc2::Difficulty enemy_difficulty = parse_difficulty(getenv_int("PROBE_ENEMY_DIFFICULTY", 1));
+
+    BootstrapProbe probe(output_path, map_file, max_frame);
+    sc2::Coordinator coordinator;
+    if (!coordinator.LoadSettings(argc, argv)) {
+        probe.set_failure("load_settings_failed");
+        probe.write_report();
+        return 2;
+    }
+
+    coordinator.SetRealtime(false);
+    coordinator.SetStepSize(step_size);
+    coordinator.SetTimeoutMS(static_cast<uint32_t>(timeout_ms));
+    coordinator.SetPortStart(port_start);
+    coordinator.SetParticipants({
+        sc2::CreateParticipant(sc2::Race::Terran, &probe),
+        sc2::CreateComputer(enemy_race, enemy_difficulty),
+    });
+
+    const char* voi_extra_args = std::getenv("VOI_SC2_EXTRA_ARGS");
+    if (voi_extra_args != nullptr && voi_extra_args[0] != '\0') {
+        std::istringstream extra_args(voi_extra_args);
+        std::string arg;
+        while (extra_args >> arg) {
+            coordinator.AddCommandLine(arg);
+        }
+    }
+
+    std::cout << "VOI bootstrap probe starting Terran VS " << race_name(enemy_race)
+              << " on " << map_file << std::endl;
+    coordinator.LaunchStarcraft();
+    if (!coordinator.StartGame(map_file)) {
+        probe.set_failure("start_game_failed");
+        probe.write_report();
+        return 2;
+    }
+
+    while (!probe.done() && coordinator.Update()) {
+    }
+
+    if (!probe.done()) {
+        probe.set_failure("coordinator_stopped_before_probe_complete");
+    }
+    coordinator.LeaveGame();
+    probe.write_report();
+    return probe.exit_code();
+}
