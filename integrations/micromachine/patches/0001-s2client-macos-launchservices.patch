+        out << "  \"food_workers\": " << food_workers_ << ",\n";
+        out << "  \"food_cap\": " << food_cap_ << ",\n";
+        out << "  \"minerals\": " << minerals_ << ",\n";
+        out << "  \"vespene\": " << vespene_ << ",\n";
+        out << "  \"start_location\": {\"x\": " << start_x_ << ", \"y\": " << start_y_ << ", \"z\": " << start_z_ << "},\n";
+        out << "  \"type_counts\": {";
+        bool first_type = true;
+        for (const auto& item : type_counts_) {
