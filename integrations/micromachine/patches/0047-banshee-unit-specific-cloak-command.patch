+bool voiIsAbilityAvailableForCommand(
+	sc2::AbilityID abilityId,
+	const sc2::Unit * unit,
+	const std::vector<sc2::AvailableAbilities> & availableAbilities)
+{
+	const auto commandAbility =
+		static_cast<sc2::ABILITY_ID>(abilityId);
+	if (Util::IsAbilityAvailable(
+		commandAbility,
+		unit,
+		availableAbilities))
+	{
+		return true;
+	}
+	// SC2 ability queries may expose the generic remap while UnitCommand
+	// requires the Banshee-specific executable ability.
+	if (commandAbility
+		== sc2::ABILITY_ID::BEHAVIOR_CLOAKON_BANSHEE)
+	{
+		return Util::IsAbilityAvailable(
+			sc2::ABILITY_ID::BEHAVIOR_CLOAKON,
+			unit,
+			availableAbilities);
+	}
+	if (commandAbility
+		== sc2::ABILITY_ID::BEHAVIOR_CLOAKOFF_BANSHEE)
+	{
+		return Util::IsAbilityAvailable(
+			sc2::ABILITY_ID::BEHAVIOR_CLOAKOFF,
+			unit,
+			availableAbilities);
+	}
+	return false;
+}
