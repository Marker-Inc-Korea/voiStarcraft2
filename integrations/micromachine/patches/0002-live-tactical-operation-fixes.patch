+bool BuildingManager::isVoiAddonFootprintClear(const Building & b, const CCPosition & producerPosition)
+{
+	for (int x = 2; x <= 3; ++x)
+	{
+		for (int y = -1; y <= 0; ++y)
+		{
+			const CCPosition addonTile = producerPosition + CCPosition(static_cast<float>(x), static_cast<float>(y));
+			if (!getBuildingPlacer().buildable(b.type, addonTile.x, addonTile.y, true))
+			{
+				return false;
+			}
+		}
+	}
+
+	const CCPosition addonCenter = producerPosition + CCPosition(2.5f, -0.5f);
+	for (const auto & unit : m_bot.GetUnits())
+	{
+		if (!unit.isValid()
+			|| !unit.isAlive()
+			|| unit.isFlying()
+			|| unit.getTag() == b.builderUnit.getTag())
+		{
+			continue;
+		}
+		if (Util::Dist(addonCenter, unit.getPosition()) <= 1.0f + unit.getUnitPtr()->radius)
+		{
+			return false;
+		}
+	}
+	return true;
+}
+
+bool BuildingManager::isVoiAddonLandingSiteValid(const Building & b, const CCPosition & producerPosition)
+{
+	if (producerPosition == CCPosition() || !b.builderUnit.isValid())
+	{
+		return false;
+	}
+	sc2::AbilityID landAbility = sc2::ABILITY_ID::LAND;
+	switch ((sc2::UNIT_TYPEID)b.builderUnit.getAPIUnitType())
+	{
+		case sc2::UNIT_TYPEID::TERRAN_BARRACKS:
+		case sc2::UNIT_TYPEID::TERRAN_BARRACKSFLYING:
+			landAbility = sc2::ABILITY_ID::LAND_BARRACKS;
+			break;
+		case sc2::UNIT_TYPEID::TERRAN_FACTORY:
+		case sc2::UNIT_TYPEID::TERRAN_FACTORYFLYING:
+			landAbility = sc2::ABILITY_ID::LAND_FACTORY;
+			break;
+		case sc2::UNIT_TYPEID::TERRAN_STARPORT:
+		case sc2::UNIT_TYPEID::TERRAN_STARPORTFLYING:
+			landAbility = sc2::ABILITY_ID::LAND_STARPORT;
+			break;
+		default:
+			break;
+	}
+	const sc2::Unit * queryUnit = b.builderUnit.isFlying() ? b.builderUnit.getUnitPtr() : nullptr;
+	if (!m_bot.Query()->Placement(landAbility, producerPosition, queryUnit))
+	{
+		return false;
+	}
+	return isVoiAddonFootprintClear(b, producerPosition);
+}
+
+CCPosition BuildingManager::findVoiAddonLandingSite(const Building & b)
+{
+	const CCPosition origin = b.builderUnit.getPosition();
+	std::vector<CCPosition> candidates;
+	candidates.push_back(origin - CCPosition(2.0f, 0.0f));
+	for (float radius = 4.0f; radius <= 20.0f; radius += 4.0f)
+	{
+		candidates.push_back(origin + CCPosition(-radius, 0.0f));
+		candidates.push_back(origin + CCPosition(radius, 0.0f));
+		candidates.push_back(origin + CCPosition(0.0f, -radius));
+		candidates.push_back(origin + CCPosition(0.0f, radius));
+		candidates.push_back(origin + CCPosition(-radius, -radius));
+		candidates.push_back(origin + CCPosition(-radius, radius));
+		candidates.push_back(origin + CCPosition(radius, -radius));
+		candidates.push_back(origin + CCPosition(radius, radius));
+	}
+
+	const auto tempBuilding = Building(b.builderUnit.getType(), Util::GetTilePosition(origin));
+	const CCTilePosition nearbyTile = getBuildingPlacer().getBuildLocationNear(tempBuilding, false, true, true);
+	if (nearbyTile != CCTilePosition())
+	{
+		candidates.push_back(Util::GetPosition(nearbyTile));
+	}
+
+	for (const CCPosition & candidate : candidates)
+	{
+		if (isVoiAddonLandingSiteValid(b, candidate))
+		{
+			return candidate;
+		}
+	}
+	return CCPosition();
+}
+
+bool BuildingManager::handleVoiAddonTask(Building & b)
+{
+	if (!b.builderUnit.isValid() || !b.builderUnit.isCompleted())
+	{
+		return true;
+	}
+
+	const sc2::Tag producerTag = b.builderUnit.getTag();
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	const uint32_t commandCooldown = 64;
+	auto relocationIt = m_addonRelocations.find(producerTag);
+
+	if (b.builderUnit.getAddonTag() != 0)
+	{
+		m_addonRelocations.erase(producerTag);
+		m_addonLastCommandFrame.erase(producerTag);
+		return true;
+	}
+	if (b.builderUnit.isProducingAddon())
+	{
+		return true;
+	}
+
+	if (b.builderUnit.isFlying())
+	{
+		// A flying producer without our relocation state belongs to damage/proxy logic.
+		if (relocationIt == m_addonRelocations.end())
+		{
+			return true;
+		}
+
+		AddonRelocationState & state = relocationIt->second;
+		state.phase = AddonRelocationPhase::Flying;
+		if (!b.builderUnit.getUnitPtr()->orders.empty())
+		{
+			const auto & order = b.builderUnit.getUnitPtr()->orders[0];
+			if ((order.ability_id == sc2::ABILITY_ID::LAND || order.ability_id == sc2::ABILITY_ID::LAND_BARRACKS || order.ability_id == sc2::ABILITY_ID::LAND_FACTORY || order.ability_id == sc2::ABILITY_ID::LAND_STARPORT) && order.target_pos == state.target)
+			{
+				state.phase = AddonRelocationPhase::LandIssued;
+				return true;
+			}
+			if (order.ability_id == sc2::ABILITY_ID::LIFT)
+			{
+				return true;
+			}
+		}
+		if (currentFrame >= state.lastCommandFrame
+			&& currentFrame - state.lastCommandFrame < commandCooldown)
+		{
+			return true;
+		}
+
+		if (state.landAttempts >= 4 || !isVoiAddonLandingSiteValid(b, state.target))
+		{
+			const CCPosition replacement = findVoiAddonLandingSite(b);
+			if (replacement == CCPosition())
+			{
+				state.lastCommandFrame = currentFrame;
+				Util::Log(__FUNCTION__, "VOI addon relocation is waiting for a valid producer plus addon landing footprint.", m_bot);
+				return true;
+			}
+			state.target = replacement;
+			state.landAttempts = 0;
+		}
+
+		Micro::SmartAbility(b.builderUnit.getUnitPtr(), sc2::ABILITY_ID::LAND, state.target, m_bot);
+		state.phase = AddonRelocationPhase::LandIssued;
+		state.lastCommandFrame = currentFrame;
+		state.landAttempts++;
+		Util::Log(__FUNCTION__, "VOI addon relocation issued one LAND command after placement validation.", m_bot);
+		return true;
+	}
+
+	if (relocationIt != m_addonRelocations.end())
+	{
+		AddonRelocationState & state = relocationIt->second;
+		const std::vector<sc2::UNIT_TYPEID> flyingTypes = {
+			sc2::UNIT_TYPEID::TERRAN_BARRACKSFLYING,
+			sc2::UNIT_TYPEID::TERRAN_FACTORYFLYING,
+			sc2::UNIT_TYPEID::TERRAN_STARPORTFLYING
+		};
+		if (Util::Contains(b.builderUnit.getAPIUnitType(), flyingTypes))
+		{
+			return true;
+		}
+		if (Util::DistSq(b.builderUnit.getPosition(), state.target) > 2.25f)
+		{
+			Util::Log(__FUNCTION__, "VOI addon producer landed outside the reserved relocation target; resetting relocation ownership.", m_bot);
+			m_addonRelocations.erase(relocationIt);
+		}
+		else
+		{
+			state.phase = AddonRelocationPhase::LandedStable;
+			if (state.stableSinceFrame == 0)
+			{
+				state.stableSinceFrame = currentFrame;
+				return true;
+			}
+			if (currentFrame >= state.stableSinceFrame && currentFrame - state.stableSinceFrame < 24)
+			{
+				return true;
+			}
+			m_addonRelocations.erase(relocationIt);
+		}
+	}
+
+	const bool hasResources =
+		m_bot.GetMinerals() >= b.type.mineralPrice()
+		&& m_bot.GetGas() >= b.type.gasPrice();
+	if (!hasResources || b.builderUnit.isTraining())
+	{
+		return true;
+	}
+
+	if (isVoiAddonFootprintClear(b, b.builderUnit.getPosition()))
+	{
+		const auto lastCommand = m_addonLastCommandFrame.find(producerTag);
+		if (lastCommand != m_addonLastCommandFrame.end()
+			&& currentFrame >= lastCommand->second
+			&& currentFrame - lastCommand->second < 96)
+		{
+			return true;
+		}
+		Micro::SmartAbility(b.builderUnit.getUnitPtr(), m_bot.Data(b.type).buildAbility, m_bot);
+		m_bot.Commander().Production().recordVoiActualProductionCommand(b.type, "addon_build_command");
+		m_addonLastCommandFrame[producerTag] = currentFrame;
+		m_buildAddonCommandFrame[b.builderUnit.getUnitPtr()] = currentFrame;
+		b.lastOrderFrame = currentFrame;
+		b.buildCommandGiven = true;
+		Util::Log(__FUNCTION__, "VOI addon command issued without lifting a valid grounded producer.", m_bot);
+		return true;
+	}
+
+	const CCPosition landingTarget = findVoiAddonLandingSite(b);
+	if (landingTarget == CCPosition())
+	{
+		Util::Log(__FUNCTION__, "VOI addon relocation refused to lift because no producer plus addon footprint passed placement validation.", m_bot);
+		return true;
+	}
+
+	AddonRelocationState state;
+	state.phase = AddonRelocationPhase::LiftIssued;
+	state.target = landingTarget;
+	state.lastCommandFrame = currentFrame;
+	state.liftAttempts = 1;
+	m_addonRelocations[producerTag] = state;
+	Micro::SmartAbility(b.builderUnit.getUnitPtr(), sc2::ABILITY_ID::LIFT, m_bot);
+	Util::Log(__FUNCTION__, "VOI addon relocation acquired producer ownership and issued one LIFT command.", m_bot);
+	return true;
+}
