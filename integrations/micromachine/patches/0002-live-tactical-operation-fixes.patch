+int voiCountUnitsNearPosition(const std::vector<Unit> & units, const CCPosition & position, float radius)
+{
+	int count = 0;
+	const float radiusSq = radius * radius;
+	for (const auto & unit : units)
+	{
+		if (unit.isValid() && Util::DistSq(unit.getPosition(), position) <= radiusSq)
+		{
+			++count;
+		}
+	}
+	return count;
+}
+
+bool voiHasVisibleEnemyNearSquad(const std::vector<Unit> & units, CCBot & bot, float radius)
+{
+	const float radiusSq = radius * radius;
+	for (const auto & enemy : bot.GetKnownEnemyUnits())
+	{
+		if (!enemy.isValid() || !enemy.isAlive() || !enemy.isVisible())
+		{
+			continue;
+		}
+		for (const auto & unit : units)
+		{
+			if (unit.isValid() && Util::DistSq(unit, enemy) <= radiusSq)
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+bool voiTankIsNearProducerFootprint(const sc2::Unit * tank, CCBot & bot)
+{
+	if (tank == nullptr)
+	{
+		return true;
+	}
+	for (const auto & unitPair : bot.GetAllyUnits())
+	{
+		const Unit & unit = unitPair.second;
+		if (!unit.isValid() || !unit.getType().isBuilding())
+		{
+			continue;
+		}
+		const sc2::UNIT_TYPEID type = unit.getAPIUnitType();
+		const bool productionBuilding =
+			type == sc2::UNIT_TYPEID::TERRAN_BARRACKS
+			|| type == sc2::UNIT_TYPEID::TERRAN_BARRACKSFLYING
+			|| type == sc2::UNIT_TYPEID::TERRAN_FACTORY
+			|| type == sc2::UNIT_TYPEID::TERRAN_FACTORYFLYING
+			|| type == sc2::UNIT_TYPEID::TERRAN_STARPORT
+			|| type == sc2::UNIT_TYPEID::TERRAN_STARPORTFLYING;
+		if (productionBuilding && Util::DistSq(tank->pos, unit.getPosition()) <= 7.0f * 7.0f)
+		{
+			return true;
+		}
+	}
+	return false;
+}
