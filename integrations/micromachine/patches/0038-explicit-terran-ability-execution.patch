+void CombatCommander::updateVoiExplicitAbilityAction()
+{
+	const std::string updateId =
+		m_bot.Commander().getVoiPolicyString("update_id", "");
+	if (updateId != m_voiExplicitAbilityUpdateId)
+	{
+		m_voiExplicitAbilityUpdateId = updateId;
+		m_lastVoiExplicitAbilityName = "";
+		m_lastVoiExplicitAbilityStatus = "inactive";
+		m_lastVoiExplicitAbilityReason =
+			"No explicit ability task requested";
+		m_lastVoiExplicitAbilityActorTag = 0;
+		m_lastVoiExplicitAbilityActorType = "";
+		m_lastVoiExplicitAbilityTargetTag = 0;
+		m_lastVoiExplicitAbilityTargetPosition = CCPosition();
+		m_lastVoiExplicitAbilityAvailableCasterCount = 0;
+		m_lastVoiExplicitAbilityPlannedCount = 0;
+		m_lastVoiExplicitAbilitySubmittedCount = 0;
+		m_lastVoiExplicitAbilityFrame = 0;
+		m_lastVoiExplicitAbilityAction = "";
+	}
+
+	const std::string taskType =
+		m_bot.Commander().getVoiPolicyString(
+			"tactical_task.task_type",
+			"");
+	const std::string abilityName =
+		m_bot.Commander().getVoiPolicyString(
+			"tactical_task.ability",
+			"");
+	m_lastVoiExplicitAbilityName = abilityName;
+	if (!m_bot.Commander().isVoiPolicyActive()
+		|| !voiTacticalTaskWithinDuration(m_bot)
+		|| taskType != "execute_ability"
+		|| abilityName.empty()
+		|| abilityName == "tactical_nuke")
+	{
+		m_lastVoiExplicitAbilityStatus = "inactive";
+		m_lastVoiExplicitAbilityReason =
+			"No active non-nuke execute_ability request";
+		return;
+	}
+	if (m_lastVoiExplicitAbilitySubmittedCount > 0)
+	{
+		m_lastVoiExplicitAbilityStatus = "completed";
+		m_lastVoiExplicitAbilityReason =
+			"Explicit ability reached the SC2 command issue path for this update";
+		return;
+	}
+
+	VoiExplicitAbilitySpec spec;
+	if (!voiResolveExplicitAbilitySpec(abilityName, spec))
+	{
+		m_lastVoiExplicitAbilityStatus = "refused";
+		m_lastVoiExplicitAbilityReason =
+			"Unsupported tactical_task.ability";
+		return;
+	}
+
+	const std::string requestedUnitClasses =
+		m_bot.Commander().getVoiPolicyString(
+			"tactical_task.unit_classes",
+			"");
+	std::vector<const sc2::Unit *> availableCasters;
+	int matchingCasterCount = 0;
+	for (const auto & combatUnit : m_combatUnits)
+	{
+		if (!combatUnit.isValid()
+			|| !combatUnit.isAlive()
+			|| !voiUnitMatchesCompositionList(
+				combatUnit,
+				requestedUnitClasses))
+		{
+			continue;
+		}
+		matchingCasterCount++;
+		const sc2::Unit * unit = combatUnit.getUnitPtr();
+		if (Util::IsAbilityAvailable(
+			spec.abilityId,
+			unit,
+			m_unitsAbilities))
+		{
+			availableCasters.push_back(unit);
+		}
+	}
+	m_lastVoiExplicitAbilityAvailableCasterCount =
+		static_cast<int>(availableCasters.size());
+	if (matchingCasterCount == 0)
+	{
+		m_lastVoiExplicitAbilityStatus = "waiting_caster";
+		m_lastVoiExplicitAbilityReason =
+			"Waiting for ProductionManager to provide a matching caster";
+		return;
+	}
+	if (availableCasters.empty())
+	{
+		m_lastVoiExplicitAbilityStatus = "waiting_ability";
+		m_lastVoiExplicitAbilityReason =
+			"Matching caster exists but the requested ability is unavailable";
+		return;
+	}
+
+	const auto abilityRange =
+		[&](float fallback)
+		{
+			const auto rangeIt =
+				m_abilityCastingRanges.find(spec.abilityId);
+			return rangeIt != m_abilityCastingRanges.end()
+				&& rangeIt->second > 0.0f
+				? rangeIt->second
+				: fallback;
+		};
+	const auto bestVisibleEnemy =
+		[&](
+			const sc2::Unit * caster,
+			float fallbackRange,
+			bool groundOnly = false)
+		{
+			const sc2::Unit * bestTarget = nullptr;
+			float bestScore = 0.0f;
+			const float baseRange = abilityRange(fallbackRange);
+			for (const auto & enemyUnit :
+				m_bot.UnitInfo().getUnits(Players::Enemy))
+			{
+				const sc2::Unit * enemy = enemyUnit.getUnitPtr();
+				if (!voiIsVisibleLiveEnemy(enemy)
+					|| enemyUnit.getType().isBuilding())
+				{
+					continue;
+				}
+				if (groundOnly && enemy->is_flying)
+				{
+					continue;
+				}
+				if (abilityName == "interference_matrix"
+					&& !enemyUnit.isMechanical())
+				{
+					continue;
+				}
+				const float range =
+					baseRange + caster->radius + enemy->radius;
+				const float distanceSq =
+					Util::DistSq(caster->pos, enemy->pos);
+				if (distanceSq > range * range)
+				{
+					continue;
+				}
+				const float score =
+					(voiIsHighValueTarget(enemy) ? 100000.0f : 0.0f)
+					+ enemy->health_max
+					+ enemy->shield_max
+					+ enemy->energy
+					- distanceSq;
+				if (bestTarget == nullptr || score > bestScore)
+				{
+					bestTarget = enemy;
+					bestScore = score;
+				}
+			}
+			return bestTarget;
+		};
+	const auto bestHealTarget =
+		[&](const sc2::Unit * caster)
+		{
+			const sc2::Unit * bestTarget = nullptr;
+			float bestScore = 0.0f;
+			const float baseRange = abilityRange(4.0f);
+			for (const auto & allyUnit :
+				m_bot.UnitInfo().getUnits(Players::Self))
+			{
+				const sc2::Unit * ally = allyUnit.getUnitPtr();
+				if (ally == nullptr
+					|| !ally->is_alive
+					|| ally->tag == caster->tag
+					|| ally->health <= 0.0f
+					|| ally->health >= ally->health_max
+					|| allyUnit.getType().isBuilding()
+					|| allyUnit.getType().isWorker()
+					|| !allyUnit.isBiological())
+				{
+					continue;
+				}
+				const float range =
+					baseRange + caster->radius + ally->radius;
+				const float distanceSq =
+					Util::DistSq(caster->pos, ally->pos);
+				if (distanceSq > range * range)
+				{
+					continue;
+				}
+				const float score =
+					(ally->health_max - ally->health) * 100.0f
+					- distanceSq;
+				if (bestTarget == nullptr || score > bestScore)
+				{
+					bestTarget = ally;
+					bestScore = score;
+				}
+			}
+			return bestTarget;
+		};
+	const auto bestLoadTarget =
+		[&](const sc2::Unit * caster)
+		{
+			const sc2::Unit * bestTarget = nullptr;
+			float bestScore = 0.0f;
+			const float baseRange = abilityRange(5.0f);
+			for (const auto & allyUnit :
+				m_bot.UnitInfo().getUnits(Players::Self))
+			{
+				const sc2::Unit * ally = allyUnit.getUnitPtr();
+				if (ally == nullptr
+					|| !ally->is_alive
+					|| ally->tag == caster->tag
+					|| ally->is_flying
+					|| allyUnit.getType().isBuilding()
+					|| allyUnit.getType().isWorker())
+				{
+					continue;
+				}
+				const float range =
+					baseRange + caster->radius + ally->radius;
+				const float distanceSq =
+					Util::DistSq(caster->pos, ally->pos);
+				if (distanceSq > range * range)
+				{
+					continue;
+				}
+				const float score =
+					ally->health_max
+					+ ally->shield_max
+					- distanceSq;
+				if (bestTarget == nullptr || score > bestScore)
+				{
+					bestTarget = ally;
+					bestScore = score;
+				}
+			}
+			return bestTarget;
+		};
+	const auto bestYamatoTarget =
+		[&](const sc2::Unit * caster)
+		{
+			const sc2::Unit * bestTarget = nullptr;
+			float bestScore = 0.0f;
+			for (const auto & enemyUnit :
+				m_bot.UnitInfo().getUnits(Players::Enemy))
+			{
+				const sc2::Unit * enemy = enemyUnit.getUnitPtr();
+				if (!voiCanTargetYamato(caster, enemy))
+				{
+					continue;
+				}
+				const float score =
+					(voiIsHighValueTarget(enemy) ? 100000.0f : 0.0f)
+					+ enemy->health
+					+ enemy->shield
+					- Util::DistSq(caster->pos, enemy->pos);
+				if (bestTarget == nullptr || score > bestScore)
+				{
+					bestTarget = enemy;
+					bestScore = score;
+				}
+			}
+			return bestTarget;
+		};
+	const auto strategicPosition =
+		[&]()
+		{
+			const std::string locationIntent =
+				m_bot.Commander().getVoiPolicyString(
+					"tactical_task.location_intent",
+					"");
+			if (locationIntent == "home")
+			{
+				return voiHomePosition(m_bot);
+			}
+			if (locationIntent == "natural")
+			{
+				const BaseLocation * natural =
+					m_bot.Bases().getPlayerNat(Players::Self);
+				return natural
+					? natural->getDepotPosition()
+					: voiHomePosition(m_bot);
+			}
+			const CCPosition observedTarget =
+				voiObservedEnemyCombatTarget(m_bot);
+			if (locationIntent.empty()
+				|| locationIntent == "last_seen_enemy_army")
+			{
+				return observedTarget;
+			}
+			return voiResolveCombatLocationIntent(
+				m_bot,
+				locationIntent,
+				observedTarget);
+		};
+
+	const sc2::Unit * selectedCaster = nullptr;
+	const sc2::Unit * selectedTarget = nullptr;
+	CCPosition selectedPosition;
+	for (const sc2::Unit * caster : availableCasters)
+	{
+		const sc2::Unit * candidateTarget = nullptr;
+		CCPosition candidatePosition;
+		bool targetResolved = true;
+		switch (spec.targetKind)
+		{
+			case VoiExplicitAbilityTargetKind::None:
+				break;
+			case VoiExplicitAbilityTargetKind::EnemyPosition:
+				candidateTarget =
+					bestVisibleEnemy(caster, 5.0f);
+				if (candidateTarget != nullptr)
+				{
+					candidatePosition = candidateTarget->pos;
+				}
+				else
+				{
+					targetResolved = false;
+				}
+				break;
+			case VoiExplicitAbilityTargetKind::EnemyUnit:
+				candidateTarget =
+					bestVisibleEnemy(
+						caster,
+						abilityName == "lock_on"
+							? 7.0f
+							: (abilityName == "interference_matrix"
+								? 9.0f
+								: 10.0f));
+				targetResolved = candidateTarget != nullptr;
+				break;
+			case VoiExplicitAbilityTargetKind::FriendlyUnit:
+				candidateTarget = bestHealTarget(caster);
+				targetResolved = candidateTarget != nullptr;
+				break;
+			case VoiExplicitAbilityTargetKind::FriendlyPassenger:
+				candidateTarget = bestLoadTarget(caster);
+				targetResolved = candidateTarget != nullptr;
+				break;
+			case VoiExplicitAbilityTargetKind::StrategicPosition:
+				candidatePosition = strategicPosition();
+				targetResolved =
+					candidatePosition != CCPosition()
+					&& m_bot.Map().isValidPosition(candidatePosition);
+				break;
+			case VoiExplicitAbilityTargetKind::GhostEmp:
+				targetResolved =
+					voiBestGhostEmpPosition(
+						m_bot,
+						caster,
+						candidatePosition);
+				break;
+			case VoiExplicitAbilityTargetKind::GhostSnipe:
+				candidateTarget =
+					voiBestGhostSnipeTarget(m_bot, caster);
+				targetResolved = candidateTarget != nullptr;
+				break;
+			case VoiExplicitAbilityTargetKind::YamatoTarget:
+				candidateTarget = bestYamatoTarget(caster);
+				targetResolved = candidateTarget != nullptr;
+				break;
+			case VoiExplicitAbilityTargetKind::LiberatorDefenderPosition:
+				candidateTarget =
+					bestVisibleEnemy(caster, 5.0f, true);
+				if (candidateTarget != nullptr)
+				{
+					candidatePosition = candidateTarget->pos;
+				}
+				else
+				{
+					targetResolved = false;
