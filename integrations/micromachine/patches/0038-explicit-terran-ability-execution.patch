+		spec = { sc2::ABILITY_ID::MORPH_HELLBAT, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "hellion_mode")
+	{
+		spec = { sc2::ABILITY_ID::MORPH_HELLION, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "thor_high_impact_mode")
+	{
+		spec = { sc2::ABILITY_ID::MORPH_THORHIGHIMPACTMODE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "thor_explosive_mode")
+	{
+		spec = { sc2::ABILITY_ID::MORPH_THOREXPLOSIVEMODE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "medivac_afterburners")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_MEDIVACIGNITEAFTERBURNERS, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "medivac_heal")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_HEAL, VoiExplicitAbilityTargetKind::FriendlyUnit };
+	}
+	else if (abilityName == "medivac_load")
+	{
+		spec = { sc2::ABILITY_ID::LOAD_MEDIVAC, VoiExplicitAbilityTargetKind::FriendlyPassenger };
+	}
+	else if (abilityName == "medivac_unload_all")
+	{
+		spec = { sc2::ABILITY_ID::UNLOADALLAT_MEDIVAC, VoiExplicitAbilityTargetKind::CasterPosition };
+	}
+	else if (abilityName == "viking_fighter_mode")
+	{
+		spec = { sc2::ABILITY_ID::MORPH_VIKINGFIGHTERMODE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "viking_assault_mode")
+	{
+		spec = { sc2::ABILITY_ID::MORPH_VIKINGASSAULTMODE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "liberator_defender_mode")
+	{
