+	else if (abilityName == "interference_matrix")
+	{
+		spec = { VoiRavenInterferenceMatrixAbility, VoiExplicitAbilityTargetKind::EnemyUnit };
+	}
+	else if (abilityName == "anti_armor_missile")
+	{
+		spec = { VoiRavenAntiArmorMissileAbility, VoiExplicitAbilityTargetKind::EnemyUnit };
+	}
+	else if (abilityName == "yamato")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_YAMATOGUN, VoiExplicitAbilityTargetKind::YamatoTarget };
+	}
+	else if (abilityName == "tactical_jump")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_TACTICALJUMP, VoiExplicitAbilityTargetKind::StrategicPosition };
+	}
+	else
+	{
+		return false;
+	}
+	return true;
+}
