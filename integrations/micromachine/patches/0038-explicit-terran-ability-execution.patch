+bool voiResolveExplicitAbilitySpec(
+	const std::string & abilityName,
+	VoiExplicitAbilitySpec & spec)
+{
+	if (abilityName == "stimpack")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_STIM, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "marine_stimpack")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_STIM_MARINE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "marauder_stimpack")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_STIM_MARAUDER, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "kd8_charge")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_KD8CHARGE, VoiExplicitAbilityTargetKind::EnemyPosition };
+	}
+	else if (abilityName == "emp")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_EMP, VoiExplicitAbilityTargetKind::GhostEmp };
+	}
+	else if (abilityName == "snipe")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_GHOSTSNIPE, VoiExplicitAbilityTargetKind::GhostSnipe };
+	}
+	else if (abilityName == "ghost_cloak")
+	{
+		spec = { sc2::ABILITY_ID::BEHAVIOR_CLOAKON_GHOST, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "ghost_decloak")
+	{
+		spec = { sc2::ABILITY_ID::BEHAVIOR_CLOAKOFF_GHOST, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "widow_mine_burrow")
+	{
+		spec = { sc2::ABILITY_ID::BURROWDOWN_WIDOWMINE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "widow_mine_unburrow")
+	{
+		spec = { sc2::ABILITY_ID::BURROWUP_WIDOWMINE, VoiExplicitAbilityTargetKind::None };
+	}
+	else if (abilityName == "lock_on")
+	{
+		spec = { sc2::ABILITY_ID::EFFECT_LOCKON, VoiExplicitAbilityTargetKind::EnemyUnit };
+	}
+	else if (abilityName == "siege_mode")
