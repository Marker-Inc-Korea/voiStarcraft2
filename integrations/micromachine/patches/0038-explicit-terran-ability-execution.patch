+	m_lastVoiExplicitAbilityAction =
+		voiActionEvidence(action);
+	m_lastVoiExplicitAbilityStatus = "planned";
+	m_lastVoiExplicitAbilityReason =
+		"Resolved caster and target; prioritized UnitAction is ready for SC2 command issue";
