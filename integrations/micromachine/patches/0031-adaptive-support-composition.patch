+int voiObservedAdaptiveSupportTargetCount(CCBot & bot, const std::string & policyUnitType)
+{
+	if (!voiContinuousCompositionProductionConfigured(bot))
+	{
+		return 0;
+	}
+
+	const int enemyAirSupply = std::max(0, bot.Analyzer().opponentAirSupply);
+	const int enemyGroundSupply = std::max(0, bot.Analyzer().opponentGroundSupply);
+	const int enemyLightGroundCount = std::max(0, bot.Analyzer().getEnemyLightGroundUnitCount());
+	const bool enemyHasAir =
+		bot.Analyzer().enemyHasCombatAirUnit()
+		|| bot.Strategy().shouldProduceAntiAirOffense()
+		|| enemyAirSupply >= 6;
+	const bool enemyHasHighTechAir =
+		bot.Strategy().enemyHasProtossHighTechAir()
+		|| enemyAirSupply >= 16;
+	const bool enemyHasInvisible =
+		bot.Strategy().enemyCurrentlyHasInvisible()
+		|| bot.Strategy().enemyHasBurrowingUpgrade();
+	const bool enemyHasMassLight =
+		bot.Strategy().enemyHasMassZerglings()
+		|| enemyLightGroundCount >= 8;
+	const bool enemyHasArmored =
+		bot.Strategy().enemyHasSeveralArmoredUnits();
+	const bool enemyGroundHeavy =
+		enemyGroundSupply >= std::max(10, enemyAirSupply * 2);
+
+	const auto representedCount = [&](const MetaType & type)
+	{
+		return voiRepresentedUnitCount(bot, type);
+	};
+	const int bioCount =
+		representedCount(MetaTypeEnum::Marine)
+		+ representedCount(MetaTypeEnum::Marauder)
+		+ representedCount(MetaTypeEnum::Ghost);
+
+	if (policyUnitType == "TERRAN_RAVEN" && enemyHasInvisible)
+	{
+		return 1;
+	}
+	if (policyUnitType == "TERRAN_VIKINGFIGHTER" && enemyHasAir)
+	{
+		return std::min(6, std::max(2, (enemyAirSupply + 2) / 3));
+	}
+	if (policyUnitType == "TERRAN_THOR" && enemyHasHighTechAir)
+	{
+		return 1;
+	}
+	if (policyUnitType == "TERRAN_HELLION" && enemyHasMassLight)
+	{
+		return std::min(6, std::max(2, (enemyLightGroundCount + 2) / 3));
+	}
+	if (policyUnitType == "TERRAN_WIDOWMINE"
+		&& enemyHasMassLight
+		&& bot.GetCurrentFrame() >= 22u * 5u * 60u)
+	{
+		return 2;
+	}
+	if (policyUnitType == "TERRAN_MARAUDER" && enemyHasArmored)
+	{
+		return 4;
+	}
+	if (policyUnitType == "TERRAN_CYCLONE" && enemyHasArmored)
+	{
+		return 2;
+	}
+	if (policyUnitType == "TERRAN_MEDIVAC" && bioCount >= 8)
+	{
+		return std::min(3, std::max(1, (bioCount + 7) / 8));
+	}
+	if (policyUnitType == "TERRAN_LIBERATOR"
+		&& enemyGroundHeavy
+		&& bot.GetCurrentFrame() >= 22u * 6u * 60u)
+	{
+		return 2;
+	}
+	if (policyUnitType == "TERRAN_BANSHEE"
+		&& bot.Commander().getVoiPolicyString("strategy.doctrine", "") == "worker_line_harassment"
+		&& !bot.Strategy().enemyHasFlyingDetector())
+	{
+		return 2;
+	}
+	if (policyUnitType == "TERRAN_BATTLECRUISER"
+		&& bot.GetCurrentFrame() >= 22u * 12u * 60u
+		&& bot.GetFreeMinerals() >= 1200
+		&& bot.GetFreeGas() >= 800
+		&& enemyAirSupply + enemyGroundSupply >= 40)
+	{
+		return 1;
+	}
+	return 0;
 }
 
