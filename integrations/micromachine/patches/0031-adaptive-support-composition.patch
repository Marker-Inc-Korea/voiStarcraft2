+int ProductionManager::getVoiAdaptiveSupportTargetCount(
+	const std::string & policyUnitType) const
+{
+	const auto target = m_voiAdaptiveSupportTargets.find(policyUnitType);
+	return target == m_voiAdaptiveSupportTargets.end()
+		? 0
+		: std::max(0, target->second);
