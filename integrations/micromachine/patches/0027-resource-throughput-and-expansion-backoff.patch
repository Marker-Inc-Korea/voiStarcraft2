+int WorkerManager::getCompletedRefineryCount() const
+{
+	int completedRefineries = 0;
+	for (const auto & unit : m_bot.UnitInfo().getUnits(Players::Self))
+	{
+		if (unit.isValid()
+			&& unit.isCompleted()
+			&& unit.getType().isRefinery())
+		{
+			completedRefineries++;
+		}
+	}
+	return completedRefineries;
+}
+
+int WorkerManager::getTotalGasWorkersTarget() const
+{
+	return getCompletedRefineryCount() * gasWorkersTarget;
+}
