+bool ProductionManager::isVoiExplicitExpandCommandCenterRequested() const
+{
+	if (!m_bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const std::string tacticalTaskType =
+		m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const std::string tacticalProductionTargets =
+		m_bot.Commander().getVoiPolicyString("tactical_task.production_targets", "");
+	const std::string buildingTaskType =
+		m_bot.Commander().getVoiPolicyString("building_tasks.0.building_type", "");
+	return (tacticalTaskType == "expand_or_land_command_center"
+			&& voiTacticalTaskWithinDuration(m_bot))
+		|| m_bot.Commander().getVoiPolicyString("strategy.doctrine", "") == "expand_macro"
+		|| voiCommaListContains(tacticalProductionTargets, "TERRAN_COMMANDCENTER")
+		|| buildingTaskType == "TERRAN_COMMANDCENTER";
+}
+
+bool ProductionManager::isVoiPassiveExpandCommandCenterQuarantined() const
+{
+	if (isVoiExplicitExpandCommandCenterRequested())
+	{
+		return false;
+	}
+
+	const auto unitType = sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER;
+	const auto retryCountIt = m_placementRetryCount.find(unitType);
+	return retryCountIt != m_placementRetryCount.end()
+		&& retryCountIt->second >= 3
+		&& isPlacementRetryCoolingDown(MetaTypeEnum::CommandCenter);
+}
