+int voiRequestedCompositionCount(CCBot & bot, const std::string & policyUnitType)
+{
+	for (int i = 0; i < 32; ++i)
+	{
+		const std::string prefix = "composition_requirements." + std::to_string(i);
+		const std::string requestedUnitType = bot.Commander().getVoiPolicyString(prefix + ".unit_type", "");
+		if (requestedUnitType.empty())
+		{
+			break;
+		}
+		if (requestedUnitType == policyUnitType)
+		{
+			return std::max(0, bot.Commander().getVoiPolicyInt(prefix + ".count", 0));
+		}
+	}
+	return 0;
+}
+
+int voiRepresentedUnitCount(CCBot & bot, const MetaType & type)
+{
+	if (!type.isUnit())
+	{
+		return 0;
+	}
+	int represented = static_cast<int>(bot.UnitInfo().getUnitTypeCount(Players::Self, type.getUnitType(), false, true, true));
+	const sc2::AbilityID buildAbility = bot.Data(type.getUnitType()).buildAbility;
+	for (const auto & producer : bot.GetUnits())
+	{
+		if (!producer.isValid() || !producer.isAlive() || producer.getPlayer() != Players::Self)
+		{
+			continue;
+		}
+		for (const auto & order : producer.getUnitPtr()->orders)
+		{
+			if (order.ability_id == buildAbility)
+			{
+				represented++;
+			}
+		}
+	}
+	return represented;
+}
