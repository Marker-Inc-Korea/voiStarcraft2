+bool BuildingManager::isVoiProducerFootprintClear(const Building & b, const CCPosition & producerPosition)
+{
+	for (int x = -1; x <= 1; ++x)
+	{
+		for (int y = -1; y <= 1; ++y)
+		{
+			const CCPosition producerTile = producerPosition + CCPosition(static_cast<float>(x), static_cast<float>(y));
+			if (!getBuildingPlacer().buildable(
+				b.builderUnit.getType(),
+				static_cast<int>(producerTile.x),
+				static_cast<int>(producerTile.y),
+				true))
+			{
+				return false;
+			}
+		}
+	}
+
+	for (const auto & unit : m_bot.GetUnits())
+	{
+		if (!unit.isValid()
+			|| !unit.isAlive()
+			|| unit.isFlying()
+			|| unit.getTag() == b.builderUnit.getTag())
+		{
+			continue;
+		}
+		if (Util::Dist(producerPosition, unit.getPosition()) <= 2.15f + unit.getUnitPtr()->radius)
+		{
+			return false;
+		}
+	}
+	return true;
+}
