+CCPosition BuildingManager::findVoiProducerLandingSite(const Building & b)
+{
+	const CCPosition origin = b.builderUnit.getPosition();
+	std::vector<CCPosition> candidates;
+	for (float radius = 4.0f; radius <= 24.0f; radius += 4.0f)
+	{
+		candidates.push_back(origin + CCPosition(-radius, 0.0f));
+		candidates.push_back(origin + CCPosition(radius, 0.0f));
+		candidates.push_back(origin + CCPosition(0.0f, -radius));
+		candidates.push_back(origin + CCPosition(0.0f, radius));
+		candidates.push_back(origin + CCPosition(-radius, -radius));
+		candidates.push_back(origin + CCPosition(-radius, radius));
+		candidates.push_back(origin + CCPosition(radius, -radius));
+		candidates.push_back(origin + CCPosition(radius, radius));
+	}
+	if (candidates.empty())
+	{
+		return CCPosition();
+	}
+
+	const size_t queryBudget = 8;
+	const size_t startIndex = ((m_bot.GetCurrentFrame() / 64u) * queryBudget) % candidates.size();
+	size_t queryChecks = 0;
+	const sc2::AbilityID landAbility = voiLandAbilityForProducer(b.builderUnit);
+	for (size_t offset = 0; offset < candidates.size(); ++offset)
+	{
+		const CCPosition & candidate = candidates[(startIndex + offset) % candidates.size()];
+		if (!isVoiProducerFootprintClear(b, candidate))
+		{
+			continue;
+		}
+		if (queryChecks++ >= queryBudget)
+		{
+			break;
+		}
+		if (m_bot.Query()->Placement(landAbility, candidate, b.builderUnit.getUnitPtr()))
+		{
+			return candidate;
+		}
+	}
+	return CCPosition();
+}
