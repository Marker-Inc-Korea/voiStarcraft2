+{
+	std::stringstream ss;
+	ss << action.description << "|squad=" << action.squad << "|type=" << static_cast<int>(action.microActionType);
+	if (action.position != CCPosition())
+	{
+		ss << "|x=" << action.position.x << "|y=" << action.position.y;
+	}
+	if (action.target != nullptr)
+	{
+		ss << "|target=" << action.target->tag;
