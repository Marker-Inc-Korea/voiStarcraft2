+void WorkerData::sendIdleWorkerToIdleSpot(const Unit & worker, bool force)
+{
+	if (!worker.isValid() || !worker.isAlive())
+		return;
+	const auto & occupiedBases = m_bot.Bases().getOccupiedBaseLocations(Players::Self);
+	if (!occupiedBases.empty())
+	{
+		auto base = *occupiedBases.begin();
+		if (base && (force || Util::DistSq(worker.getPosition(), base->getDepotPosition()) > 40))
+		{
+			if (force || worker.getUnitPtr()->orders.size() == 0)
+			{
+				CCTilePosition mainPos = base->getDepotTilePosition();
+				CCTilePosition ressourcesCenterPos = base->getTurretPosition();
+				CCTilePosition idlePos = CCTilePosition(mainPos.x + (mainPos.x - ressourcesCenterPos.x), mainPos.y + (mainPos.y - ressourcesCenterPos.y));
+				const bool idleSpotIsUseful = Util::DistSq(worker.getPosition(), idlePos) > 1.0f;
+				const bool depotFallbackIsUseful = Util::DistSq(worker.getPosition(), base->getDepotPosition()) > 1.0f;
+				if (m_bot.Map().isValidTile(idlePos) && idleSpotIsUseful)
+				{
+					m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_recovery_idle_spot");
+					worker.move(idlePos);
+				}
+				else if (m_bot.Map().isValidPosition(base->getDepotPosition()) && depotFallbackIsUseful)
+				{
+					m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_recovery_depot_fallback");
+					worker.move(base->getDepotPosition());
+				}
+				return;
+			}
+		}
+	}
+	else
+	{
+		//If all else fail, just cancel current order.
+		worker.stop();
+	}
+}
+
+void WorkerData::sendIdleWorkerToMiningSpot(const Unit & worker, bool force)
+{
+	if (!worker.isValid() || !worker.isAlive() || !worker.getType().isWorker())
+	{
+		return;
+	}
+	if (!force && !worker.getUnitPtr()->orders.empty())
+	{
+		const auto abilityId = worker.getUnitPtr()->orders[0].ability_id;
+		if (abilityId == sc2::ABILITY_ID::HARVEST_GATHER || abilityId == sc2::ABILITY_ID::HARVEST_RETURN)
+		{
+			return;
+		}
+	}
+	if (worker.getType().isMule() || isActivelyReturningCargo(worker))
+	{
+		return;
+	}
+	if (!m_idleMineralTarget.isValid() || !Util::PathFinding::IsPathToGoalSafe(worker.getUnitPtr(), m_idleMineralTarget.getPosition(), false, m_bot))
+	{
+		const Unit fallbackMineral = GetBestMineralInList(m_bot.GetUnits(), worker.getPosition(), true);
+		if (fallbackMineral.isValid())
+		{
+			bool alreadyTargetingFallbackMineral = false;
+			if (!worker.getUnitPtr()->orders.empty())
+			{
+				const auto & order = worker.getUnitPtr()->orders[0];
+				alreadyTargetingFallbackMineral = order.target_unit_tag == fallbackMineral.getTag()
+					|| Util::DistSq(CCPosition(order.target_pos), fallbackMineral.getPosition()) <= 4.0f;
+			}
+			if (!alreadyTargetingFallbackMineral)
+			{
+				m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_mining_fallback_mineral");
+				worker.rightClick(fallbackMineral);
+			}
+			return;
+		}
+		sendIdleWorkerToIdleSpot(worker, force);
+	}
+	else
+	{
+		if (worker.getUnitPtr()->orders.empty() || worker.getUnitPtr()->orders[0].ability_id != sc2::ABILITY_ID::HARVEST_GATHER || Util::DistSq(worker.getPosition(), m_idleMineralTarget.getPosition()) > 75)
+		{
+			//mine mineral walls
+			bool hasWallMineralToMine = false;
+			for (auto & base : m_bot.Bases().getOccupiedBaseLocations(Players::Self))
+			{
+				for (auto neutral : m_bot.GetNeutralUnits())
+				{
+					if (!neutral.second.getType().isMineralWallPatch())
+						continue;
+					if (Util::DistSq(base->getPosition(), neutral.second.getPosition()) < 625)//Mine all wall within 25 tiles of one of our bases
+					{
+						hasWallMineralToMine = true;
+						bool alreadyTargetingWallMineral = false;
+						if (!worker.getUnitPtr()->orders.empty())
+						{
+							const auto & order = worker.getUnitPtr()->orders[0];
+							alreadyTargetingWallMineral = order.target_unit_tag == neutral.second.getTag()
+								|| Util::DistSq(CCPosition(order.target_pos), neutral.second.getPosition()) <= 4.0f;
+						}
+						if (!alreadyTargetingWallMineral)
+						{
+							m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_mining_wall_mineral");
+							worker.rightClick(neutral.second);
+						}
+						break;
+					}
+				}
+				if (hasWallMineralToMine)
+				{
+					break;
+				}
+			}
+
+			if (!hasWallMineralToMine)
+			{
+				if (Util::DistSq(worker.getPosition(), m_idleMineralTarget.getPosition()) < 30)//When the mineral is visible, just click it.
+				{
+					auto mineral = m_bot.Buildings().getClosestMineral(m_idleMineralTarget.getPosition());
+					if (mineral)
+					{
+						bool alreadyTargetingVisibleMineral = false;
+						if (!worker.getUnitPtr()->orders.empty())
+						{
+							const auto & order = worker.getUnitPtr()->orders[0];
+							alreadyTargetingVisibleMineral = order.target_unit_tag == mineral->tag
+								|| Util::DistSq(CCPosition(order.target_pos), CCPosition(mineral->pos)) <= 4.0f;
+						}
+						if (!alreadyTargetingVisibleMineral)
+						{
+							m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_mining_visible_mineral");
+							worker.rightClick(mineral);
+						}
+					}
+					else if (Util::DistSq(worker.getPosition(), m_idleMineralTarget.getPosition()) > 1.0f)
+					{
+						m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_mining_target_position");
+						worker.rightClick(m_idleMineralTarget.getPosition());
+					}
+				}
+				else if (Util::DistSq(worker.getPosition(), m_idleMineralTarget.getPosition()) > 1.0f)
+				{
+					bool alreadyMovingToIdleMineralTarget = false;
+					if (!worker.getUnitPtr()->orders.empty())
+					{
+						const auto & order = worker.getUnitPtr()->orders[0];
+						const auto abilityId = order.ability_id.ToType();
+						alreadyMovingToIdleMineralTarget = (abilityId == sc2::ABILITY_ID::MOVE || abilityId == sc2::ABILITY_ID::SMART)
+							&& order.target_unit_tag == 0
+							&& Util::DistSq(CCPosition(order.target_pos), m_idleMineralTarget.getPosition()) <= 4.0f;
+					}
+					if (!alreadyMovingToIdleMineralTarget)
+					{
+						m_bot.Commander().setVoiWorkerCommandReason(worker, "idle_mining_target_position");
+						worker.rightClick(m_idleMineralTarget.getPosition());
+					}
+				}
+			}
+		}
+	}
+}
