+	const int orbitals = m_bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::OrbitalCommand.getUnitType(), false, true);
+	const int barracks = m_bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Barracks.getUnitType(), false, true, true);
+	if (barracks == 0)
+	{
+		return;
+	}
+	if (m_bot.Buildings().isBeingBuilt(MetaTypeEnum::CommandCenter.getUnitType()))
+	{
+		return;
+	}
+	if (commandCenters + orbitals >= 2)
+	{
+		return;
+	}
+
+	m_queue.removeAllOfType(MetaTypeEnum::CommandCenter);
+	const float supplyBufferBias = std::max(
+		m_bot.Commander().getVoiPolicyFloat("production.queue_biases.TERRAN_SUPPLYDEPOT", 0.0f),
+		m_bot.Commander().getVoiPolicyFloat("economy.supply_buffer_bias", 0.0f));
+	const float workerProductionBias = m_bot.Commander().getVoiPolicyFloat("economy.worker_production_bias", 0.0f);
+	const float marineBias = std::max(
+		m_bot.Commander().getVoiPolicyFloat("production.queue_biases.TERRAN_MARINE", 0.0f),
+		m_bot.Commander().getVoiPolicyFloat("tech.unit_biases.TERRAN_MARINE", 0.0f));
+	const int supplyWithQueuedProviders = m_bot.GetMaxSupply() + m_bot.Buildings().countBeingBuilt(supplyProvider) * 8;
+	const bool standingProductionNeedsRoom =
+		std::max({ supplyBufferBias, workerProductionBias, marineBias }) > 0.25f
+		&& supplyWithQueuedProviders - m_bot.GetCurrentSupply() <= 6;
+	m_queue.queueAsHighestPriority(MetaTypeEnum::CommandCenter, !standingProductionNeedsRoom);
+	if (m_bot.GetCurrentFrame() - m_lastVoiExpandReserveLogFrame >= 224)
+	{
+		m_lastVoiExpandReserveLogFrame = m_bot.GetCurrentFrame();
+		Util::Log(__FUNCTION__, "VOI prioritized expand_macro CommandCenter minerals=" + std::to_string(m_bot.GetFreeMinerals()) + " blocking=" + std::to_string(!standingProductionNeedsRoom), m_bot);
+	}
+}
+
+bool ProductionManager::queueVoiDoctrineItem(const MetaType & type, const std::string & action, bool highestPriority, bool blocking)
+{
+	if (m_queue.contains(type))
+	{
+		const std::string doctrine = m_bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+		const std::string canonicalItemName = voiCanonicalProductionItemName(type.getName());
+		const bool blocksDoctrineProgress =
+			highestPriority
+			|| voiDoctrineRequestsTechTransition(m_bot, type)
+			|| (!canonicalItemName.empty() && voiDoctrineExpectsActualItem(doctrine, canonicalItemName));
+		if (blocksDoctrineProgress)
+		{
+			if (highestPriority || blocking)
+			{
+				m_queue.removeAllOfType(type);
+				m_queue.queueAsHighestPriority(type, blocking);
+				recordVoiDoctrineConsumption(type, action, "queued_existing");
+				return true;
+			}
+			recordVoiDoctrineConsumption(type, action, "queued_existing");
+			return true;
+		}
+		return false;
+	}
+	if (type.isBuilding() && isPlacementRetryCoolingDown(type))
+	{
+		recordVoiDoctrineConsumption(type, action, "blocked_placement_retry_cooldown");
+		return false;
+	}
+	if (!hasRequired(type, true) || !hasProducer(type, true))
+	{
+		recordVoiDoctrineConsumption(type, action, "blocked_missing_prerequisite_or_producer");
+		return false;
+	}
+
+	if (highestPriority)
+	{
+		m_queue.queueAsHighestPriority(type, blocking);
+	}
+	else
+	{
+		m_queue.queueItem(MM::BuildOrderItem(type, 2, blocking));
+	}
+	recordVoiDoctrineConsumption(type, action, "queued");
+	Util::Log(__FUNCTION__, "voi doctrine action=" + action + " queued item=" + type.getName() + " doctrine=" + m_lastVoiDoctrine, m_bot);
+	return true;
+}
+
+void ProductionManager::recordVoiDoctrineConsumption(const MetaType & type, const std::string & action, const std::string & evidence)
+{
+	m_lastVoiDoctrineFrame = m_bot.GetCurrentFrame();
+	m_lastVoiDoctrineAction = action;
+	m_lastVoiDoctrineQueueItem = type.getName();
+	m_lastVoiDoctrineEvidence = evidence.empty() ? "unknown" : evidence;
+	m_lastVoiDoctrineUpdateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+	Util::Log(__FUNCTION__, "voi doctrine consumed action=" + action + " item=" + type.getName() + " evidence=" + m_lastVoiDoctrineEvidence + " doctrine=" + m_lastVoiDoctrine, m_bot);
+}
+
+bool ProductionManager::queueSupplyProviderRecovery(const std::string & reason)
+{
+	if (m_bot.GetMaxSupply() >= 200)
+	{
+		m_lastVoiSupplyRecoveryStatus = "max_supply";
+		m_lastVoiSupplyRecoveryReason = reason;
+		m_lastVoiSupplyRecoveryFrame = m_bot.GetCurrentFrame();
+		return false;
+	}
+
+	m_lastVoiSupplyRecoveryFrame = m_bot.GetCurrentFrame();
+	m_lastVoiSupplyRecoveryReason = reason;
+	m_lastVoiSupplyProviderUnderConstructionCount = m_bot.Buildings().countBeingBuilt(supplyProvider);
+	if (m_lastVoiSupplyProviderUnderConstructionCount > 0)
+	{
+		constexpr uint32_t staleSupplyProviderCommandFrames = 672;
+		const uint32_t currentFrame = m_bot.GetCurrentFrame();
+		const bool freshSupplyProviderCommand =
+			m_lastVoiSupplyProviderCommandFrame > 0 &&
+			currentFrame >= m_lastVoiSupplyProviderCommandFrame &&
+			currentFrame - m_lastVoiSupplyProviderCommandFrame < staleSupplyProviderCommandFrames;
+		if (freshSupplyProviderCommand)
+		{
+			m_lastVoiSupplyRecoveryStatus = "waiting_existing_under_construction";
+			Util::Log(__FUNCTION__, "Supply provider recovery waiting for existing construction reason=" + reason + " count=" + std::to_string(m_lastVoiSupplyProviderUnderConstructionCount), m_bot);
+			return true;
+		}
+
+		m_lastVoiSupplyRecoveryStatus = "stale_existing_under_construction_requeued";
+		Util::Log(__FUNCTION__,
+			"Supply provider recovery found stale existing construction; queuing another provider reason=" + reason +
+			" count=" + std::to_string(m_lastVoiSupplyProviderUnderConstructionCount) +
+			" last_command_frame=" + std::to_string(m_lastVoiSupplyProviderCommandFrame),
+			m_bot);
+	}
+
+	if (!hasRequired(supplyProviderType, true) || !hasProducer(supplyProviderType, true))
+	{
+		m_lastVoiSupplyRecoveryStatus = "blocked_missing_requirement_or_producer";
+		Util::Log(__FUNCTION__, "Supply provider recovery blocked by missing requirement or producer reason=" + reason, m_bot);
+		return true;
+	}
+
+	if (supplyProviderType.isUnit())
+	{
+		const auto apiType = supplyProviderType.getUnitType().getAPIUnitType();
+		m_nextPlacementRetryFrame.erase(apiType);
+		m_placementRetryCount.erase(apiType);
+	}
+
+	const bool hadExistingQueueItem = m_queue.contains(supplyProviderType);
+	if (hadExistingQueueItem)
+	{
+		m_queue.removeAllOfType(supplyProviderType);
+	}
+	m_queue.queueAsHighestPriority(supplyProviderType, false);
+	m_voiSupplyRecoveryQueuedCount++;
+	m_lastVoiSupplyRecoveryStatus = hadExistingQueueItem ? "promoted_existing_queue" : "queued";
+	recordVoiDoctrineConsumption(supplyProviderType, "supply_recovery", hadExistingQueueItem ? "queued_existing" : "queued");
+	Util::Log(__FUNCTION__, "Supply provider recovery queued after supply block. status=" + m_lastVoiSupplyRecoveryStatus + " reason=" + reason, m_bot);
+	return true;
+}
+
+bool ProductionManager::shouldRecordVoiActualProductionCommand(const std::string & itemName) const
+{
+	if (!m_bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+	const std::string updateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+	if (updateId.empty() || updateId != m_lastVoiDoctrineUpdateId)
+	{
+		return false;
+	}
+	const std::string canonicalItemName = voiCanonicalProductionItemName(itemName);
+	if (!canonicalItemName.empty() && canonicalItemName == m_lastVoiDoctrineQueueItem)
+	{
+		return true;
+	}
+	const std::string doctrine = m_bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	return !canonicalItemName.empty() && voiDoctrineExpectsActualItem(doctrine, canonicalItemName);
+}
+
+bool ProductionManager::shouldUseVoiDirectAddonCommand(const UnitType & type) const
+{
+	if (!m_bot.Commander().isVoiPolicyActive() || !type.isAddon())
+	{
+		return false;
+	}
+
+	const std::string canonicalItemName = voiCanonicalProductionItemName(type.getName());
+	if (canonicalItemName.empty())
+	{
+		return false;
+	}
+
+	const std::string updateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+	const std::string doctrine = m_bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	return (!updateId.empty() && updateId == m_lastVoiDoctrineUpdateId && canonicalItemName == m_lastVoiDoctrineQueueItem)
+		|| voiDoctrineExpectsActualItem(doctrine, canonicalItemName);
+}
+
+void ProductionManager::recordVoiActualProductionCommand(const MetaType & type, const std::string & kind)
+{
+	const std::string itemName = voiCanonicalProductionItemName(type.getName());
+	const std::string commandKind = kind.empty() ? "unit_command" : kind;
+	if (itemName == "SupplyDepot")
+	{
+		m_lastVoiSupplyProviderCommandFrame = m_bot.GetCurrentFrame();
+		m_lastVoiSupplyProviderCommandKind = commandKind;
+		m_lastVoiSupplyProviderCommandUpdateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+		m_lastVoiSupplyProviderUnderConstructionCount = m_bot.Buildings().countBeingBuilt(supplyProvider);
+		m_lastVoiSupplyRecoveryStatus = "command_issued";
+		Util::Log(__FUNCTION__, "voi supply provider command kind=" + commandKind + " update_id=" + m_lastVoiSupplyProviderCommandUpdateId, m_bot);
+	}
+	if (!shouldRecordVoiActualProductionCommand(itemName))
+	{
+		return;
+	}
+	m_lastVoiProductionCommandFrame = m_bot.GetCurrentFrame();
+	m_voiProductionCommandIssuedCount++;
+	m_lastVoiProductionCommandItem = itemName;
+	m_lastVoiProductionCommandKind = commandKind;
+	m_lastVoiProductionCommandUpdateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+	if (!m_lastVoiProductionCommandUpdateId.empty() &&
+		m_lastVoiProductionCommandUpdateId == m_lastVoiDoctrineUpdateId)
+	{
+		m_lastVoiDoctrineFrame = m_lastVoiProductionCommandFrame;
+		m_lastVoiDoctrineQueueItem = itemName;
+		m_lastVoiDoctrineEvidence = "command_issued";
+	}
+	Util::Log(__FUNCTION__, "voi actual production command kind=" + m_lastVoiProductionCommandKind + " item=" + itemName + " update_id=" + m_lastVoiProductionCommandUpdateId, m_bot);
+}
