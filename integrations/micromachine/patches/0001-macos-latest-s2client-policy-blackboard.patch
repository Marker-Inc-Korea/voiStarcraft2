+float voiDistanceSqToSegment(const CCPosition & point, const CCPosition & start, const CCPosition & end)
+{
+	const float dx = end.x - start.x;
+	const float dy = end.y - start.y;
+	const float lengthSq = dx * dx + dy * dy;
+	if (lengthSq <= 0.001f)
+	{
+		return Util::DistSq(point, start);
+	}
+	const float t = std::max(0.0f, std::min(1.0f, ((point.x - start.x) * dx + (point.y - start.y) * dy) / lengthSq));
+	const CCPosition projection(start.x + t * dx, start.y + t * dy);
+	return Util::DistSq(point, projection);
+}
+
+CCPosition getVoiNearbyResourceCenter(CCBot & bot, const Unit & depot, int & resourceCount)
+{
+	CCPosition center(0.0f, 0.0f);
+	resourceCount = 0;
+	for (auto & unit : bot.GetUnits())
+	{
+		if (!unit.isValid() || !unit.isAlive() || (!unit.getType().isMineral() && !unit.getType().isGeyser()))
+		{
+			continue;
+		}
+		if (Util::DistSq(unit.getPosition(), depot.getPosition()) > 18.0f * 18.0f)
+		{
+			continue;
+		}
+		center.x += unit.getPosition().x;
+		center.y += unit.getPosition().y;
+		resourceCount++;
+	}
+	if (resourceCount > 0)
+	{
+		center.x /= static_cast<float>(resourceCount);
+		center.y /= static_cast<float>(resourceCount);
+	}
+	return center;
+}
+
+bool isVoiDepotFlowProtectedPlacement(CCBot & bot, const UnitType & type, const std::vector<CCTilePosition> & tiles)
+{
+	if (!isVoiMacroStructureType(type) || type.isResourceDepot() || type.isRefinery() || type.isAddon())
+	{
+		return false;
+	}
+	for (const auto & depot : bot.GetAllyUnits(Util::GetResourceDepotType().getAPIUnitType()))
+	{
+		if (!depot.isValid() || !depot.isAlive() || depot.isFlying())
+		{
+			continue;
+		}
+		int resourceCount = 0;
+		const CCPosition resourceCenter = getVoiNearbyResourceCenter(bot, depot, resourceCount);
+		for (const auto & tile : tiles)
+		{
+			const CCPosition tileCenter(static_cast<float>(tile.x) + 0.5f, static_cast<float>(tile.y) + 0.5f);
+			if (Util::DistSq(tileCenter, depot.getPosition()) <= 7.25f * 7.25f)
+			{
+				return true;
+			}
+			if (resourceCount > 0 && voiDistanceSqToSegment(tileCenter, depot.getPosition(), resourceCenter) <= 3.25f * 3.25f)
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
