+		case sc2::UNIT_TYPEID::NEUTRAL_PURIFIERRICHMINERALFIELD750:
+			std::cout << "Unit type " << m_type << " has no mineral but is a mineral field" << std::endl;
+			return true;
+		default:
+			return false;
+	}
+}
