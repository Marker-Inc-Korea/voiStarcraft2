+std::string getConfiguredExecutableDirectory(int argc, char* argv[])
+{
+	for (int i = 1; i + 1 < argc; ++i)
+	{
+		const std::string arg = argv[i] == nullptr ? "" : argv[i];
+		if (arg != "-e")
+		{
+			continue;
+		}
+
+		const std::string executable = argv[i + 1] == nullptr ? "" : argv[i + 1];
+		const std::string versionsMarker = "/Versions/";
+		const std::string::size_type versions = executable.find(versionsMarker);
+		if (versions != std::string::npos)
+		{
+			return executable.substr(0, versions);
+		}
+
+		const std::string::size_type slash = executable.find_last_of("/\\");
+		if (slash != std::string::npos)
+		{
+			return executable.substr(0, slash);
+		}
+	}
+
+	return "";
+}
