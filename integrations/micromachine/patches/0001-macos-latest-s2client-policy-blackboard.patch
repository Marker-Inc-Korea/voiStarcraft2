+bool CombatCommander::shouldWeStartAttacking()
+{
+    //return m_bot.Strategy().getCurrentStrategy().m_attackCondition.eval();
+	if (m_bot.Commander().getVoiPolicyBool("emergency.force_retreat", false)
+		|| m_bot.Commander().getVoiPolicyBool("emergency.cancel_attacks", false))
+	{
+		return false;
+	}
+	const float defendBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("combat.defend_bias", 0.0f));
+	const float aggression = m_bot.Commander().getVoiPolicyFloat("combat.aggression", 0.0f);
+	const float attackTimingBias = m_bot.Commander().getVoiPolicyFloat("combat.attack_timing_bias", 0.0f);
+	const float commitmentLevel = m_bot.Commander().getVoiPolicyFloat("combat.commitment_level", 0.0f);
+	const std::string attackOverride = m_bot.Commander().getVoiPolicyString("combat.attack_condition_override", "normal");
+	if (attackOverride == "never")
+	{
+		return false;
+	}
+	if (defendBias >= 0.9f && aggression <= 0.0f)
+	{
+		return false;
+	}
+	if ((attackOverride == "earlier_if_safe" || attackOverride == "force_when_threshold_met")
+		&& aggression + attackTimingBias + commitmentLevel > 0.5f)
+	{
+		return true;
+	}
+	return true;
+}
