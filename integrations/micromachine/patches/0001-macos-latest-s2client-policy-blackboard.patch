+void ProductionManager::enforceBarracksProductionContinuity()
+{
+	if (m_bot.GetSelfRace() != CCRace::Terran)
+	{
+		return;
+	}
+	const float continuityBias = m_bot.Commander().getVoiPolicyFloat("production.production_continuity_bias", 0.0f);
+	if (continuityBias <= -0.75f)
+	{
+		return;
+	}
+	const int startFrame = std::max(2016, static_cast<int>(4032 - std::max(0.0f, continuityBias) * 1344));
+	const int continuityCooldown = std::max(56, static_cast<int>(112 - std::max(0.0f, continuityBias) * 56 + std::max(0.0f, -continuityBias) * 112));
+	if (m_bot.GetCurrentFrame() < startFrame)
+	{
+		return;
+	}
+	if (m_bot.GetCurrentFrame() - m_lastBarracksContinuityFrame < continuityCooldown)
+	{
+		return;
+	}
+	if (m_bot.GetFreeMinerals() < MetaTypeEnum::Marine.getUnitType().mineralPrice())
+	{
+		return;
+	}
+	if (m_bot.GetMaxSupply() - m_bot.GetCurrentSupply() < MetaTypeEnum::Marine.getUnitType().supplyRequired())
+	{
+		if (!m_queue.contains(supplyProviderType) && m_bot.Buildings().countBeingBuilt(supplyProvider) == 0 && m_bot.GetMaxSupply() < 200 && !isPlacementRetryCoolingDown(supplyProviderType))
+		{
+			m_queue.queueAsHighestPriority(supplyProviderType, false);
+			Util::Log(__FUNCTION__, "continuity queued supply provider before Marine fallback.", m_bot);
+		}
+		return;
+	}
+
+	for (auto & barracks : m_bot.GetAllyUnits(sc2::UNIT_TYPEID::TERRAN_BARRACKS))
+	{
+		if (!barracks.isValid() || !barracks.isCompleted() || barracks.isFlying())
+		{
+			continue;
+		}
+
+		bool barracksProductionOrderInFlight = false;
+		bool barracksUnitTrainingOrderInFlight = false;
+		for (const auto & order : barracks.getUnitPtr()->orders)
+		{
+			switch ((sc2::ABILITY_ID)order.ability_id)
+			{
+				case sc2::ABILITY_ID::TRAIN_MARINE:
+				case sc2::ABILITY_ID::TRAIN_MARAUDER:
+				case sc2::ABILITY_ID::TRAIN_REAPER:
+				case sc2::ABILITY_ID::TRAIN_GHOST:
+					barracksUnitTrainingOrderInFlight = true;
+					barracksProductionOrderInFlight = true;
+					break;
+				case sc2::ABILITY_ID::BUILD_TECHLAB:
+				case sc2::ABILITY_ID::BUILD_TECHLAB_BARRACKS:
+				case sc2::ABILITY_ID::BUILD_REACTOR:
+				case sc2::ABILITY_ID::BUILD_REACTOR_BARRACKS:
+					barracksProductionOrderInFlight = true;
+					break;
+				default:
+					break;
+			}
+			if (barracksProductionOrderInFlight)
+			{
+				break;
+			}
+		}
+		if (barracksProductionOrderInFlight)
+		{
+			if (barracksUnitTrainingOrderInFlight && m_bot.GetCurrentFrame() - m_lastBarracksContinuityAcceptedFrame >= 112)
+			{
+				m_lastBarracksContinuityAcceptedFrame = m_bot.GetCurrentFrame();
+				Util::Log(__FUNCTION__, "continuity accepted unit training order=Marine", m_bot);
+			}
+			continue;
+		}
+		const bool abilityQueryAllowsMarine = canMakeNow(barracks, MetaTypeEnum::Marine);
+		if (!abilityQueryAllowsMarine)
+		{
+			Util::Log(__FUNCTION__, "Marine continuity ability query failed; trying direct train on idle completed barracks.", m_bot);
+		}
+		barracks.train(MetaTypeEnum::Marine.getUnitType());
+		m_lastBarracksContinuityFrame = m_bot.GetCurrentFrame();
+		Util::Log(__FUNCTION__, "continuity train command item=Marine", m_bot);
+		return;
+	}
+}
