+
+void CCBot::maybeSeedVoiBootstrapStart()
+{
+	if (m_voiBootstrapSeedIssued)
+	{
+		return;
+	}
+	const char * enabled = std::getenv("VOI_SC2_BOOTSTRAP_SELF_UNITS");
+	if (enabled == nullptr || std::string(enabled) != "1")
+	{
+		return;
+	}
+	if (Observation()->GetPlayerID() == 0)
+	{
+		return;
+	}
+	for (const auto * unit : Observation()->GetUnits())
+	{
+		if (unit->alliance == sc2::Unit::Self || unit->alliance == sc2::Unit::Ally)
+		{
+			return;
+		}
+	}
+
+	const auto camera = Observation()->GetCameraPos();
+	const sc2::Point2D base(camera.x, camera.y);
+	const uint32_t playerId = Observation()->GetPlayerID();
+	Debug()->DebugCreateUnit(sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER, base, playerId, 1);
+	Debug()->DebugCreateUnit(sc2::UNIT_TYPEID::TERRAN_SCV, sc2::Point2D(base.x + 4.0f, base.y), playerId, 6);
+	for (int i = 0; i < 8; ++i)
+	{
+		const float x = base.x + 7.0f + static_cast<float>(i % 4) * 1.5f;
+		const float y = base.y - 4.0f + static_cast<float>(i / 4) * 1.5f;
+		Debug()->DebugCreateUnit(sc2::UNIT_TYPEID::NEUTRAL_MINERALFIELD, sc2::Point2D(x, y), 0, 1);
+	}
+	Debug()->DebugCreateUnit(sc2::UNIT_TYPEID::NEUTRAL_VESPENEGEYSER, sc2::Point2D(base.x - 5.0f, base.y + 5.0f), 0, 1);
+	Debug()->DebugCreateUnit(sc2::UNIT_TYPEID::NEUTRAL_VESPENEGEYSER, sc2::Point2D(base.x + 5.0f, base.y + 5.0f), 0, 1);
+	Debug()->SendDebug();
+	m_voiBootstrapSeedIssued = true;
+}
+
+bool CCBot::isInitialObservationReady() const
+{
+	const auto & gameInfo = Observation()->GetGameInfo();
+	if (gameInfo.width <= 0 || gameInfo.height <= 0 || gameInfo.enemy_start_locations.empty())
+	{
+		return false;
+	}
+
+	size_t selfDepotCount = 0;
+	size_t neutralResourceCount = 0;
+	for (const auto * unit : Observation()->GetUnits())
+	{
+		if (unit->alliance == sc2::Unit::Self || unit->alliance == sc2::Unit::Ally)
+		{
+			if (unit->unit_type == sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER
+				|| unit->unit_type == sc2::UNIT_TYPEID::TERRAN_ORBITALCOMMAND
+				|| unit->unit_type == sc2::UNIT_TYPEID::TERRAN_PLANETARYFORTRESS
+				|| unit->unit_type == sc2::UNIT_TYPEID::PROTOSS_NEXUS
+				|| unit->unit_type == sc2::UNIT_TYPEID::ZERG_HATCHERY
+				|| unit->unit_type == sc2::UNIT_TYPEID::ZERG_LAIR
+				|| unit->unit_type == sc2::UNIT_TYPEID::ZERG_HIVE)
+			{
+				++selfDepotCount;
+			}
+		}
+		else if (unit->alliance == sc2::Unit::Neutral)
+		{
+			if (unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_MINERALFIELD
+				|| unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_MINERALFIELD750
+				|| unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_RICHMINERALFIELD
+				|| unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_RICHMINERALFIELD750
+				|| unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_VESPENEGEYSER
+				|| unit->unit_type == sc2::UNIT_TYPEID::NEUTRAL_RICHVESPENEGEYSER)
+			{
+				++neutralResourceCount;
+			}
+		}
+	}
+	return selfDepotCount > 0 && neutralResourceCount >= 6;
+}
