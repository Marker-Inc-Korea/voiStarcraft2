+Unit WorkerData::updateWorkerDepot(const Unit & worker, const Unit & mineral)
+{
+	if (!worker.isValid() || !mineral.isValid())
+	{
+		return Unit();
+	}
+	auto base = m_bot.Bases().getBaseContainingPosition(mineral.getPosition());
+	if (base)
+	{
+		auto & depot = base->getResourceDepot();
+		if (depot.isValid() && depot.isCompleted() && !depot.isFlying())
+		{
+			m_workerDepotMap[worker] = depot;
+			return depot;
+		}
+	}
+	auto existingDepot = getWorkerDepot(worker);
+	if (existingDepot.isValid() && existingDepot.isCompleted() && !existingDepot.isFlying())
+	{
+		return existingDepot;
+	}
+
+	Unit closestDepot;
+	double closestDistance = 1000000000.0;
+	for (auto & unit : m_bot.UnitInfo().getUnits(Players::Self))
+	{
+		if (!unit.isValid() || !unit.getType().isResourceDepot() || !unit.isCompleted() || unit.isFlying())
+		{
+			continue;
+		}
+		const double distance = Util::DistSq(unit.getPosition(), mineral.getPosition());
+		if (!closestDepot.isValid() || distance < closestDistance)
+		{
+			closestDepot = unit;
+			closestDistance = distance;
+		}
+	}
+	if (closestDepot.isValid())
+	{
+		m_workerDepotMap[worker] = closestDepot;
+		return closestDepot;
+	}
+	return Unit();
+}
