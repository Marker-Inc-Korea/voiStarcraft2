+bool ProductionManager::isImportantProductionBuildingIdle(bool underConstructionConsideredIdle, bool constructingAddonConsideredIdle)
+{
+	return getIdleImportantProductionBuildingTypes(underConstructionConsideredIdle, constructingAddonConsideredIdle).size() > 0;
+}
+
+bool ProductionManager::isVoiExpandMacroActive() const
+{
+	if (!m_bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const std::string doctrine = m_bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	if (m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "") == "expand_or_land_command_center"
+		&& voiTacticalTaskWithinDuration(m_bot))
+	{
+		return true;
+	}
+	if (doctrine == "expand_macro")
+	{
+		return true;
+	}
+
+	const float commandCenterBias = std::max(
+		m_bot.Commander().getVoiPolicyFloat("production.queue_biases.TERRAN_COMMANDCENTER", 0.0f),
+		m_bot.Commander().getVoiPolicyFloat("economy.expand_bias", 0.0f));
+	const float macroBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.macro", 0.0f);
+	return std::max(commandCenterBias, macroBias) > 0.45f;
+}
+
+bool ProductionManager::shouldReserveForVoiExpandCommandCenter() const
+{
+	if (!isVoiExpandMacroActive() || !m_queue.contains(MetaTypeEnum::CommandCenter))
+	{
+		return false;
+	}
+
+	const int commandCenters = m_bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::CommandCenter.getUnitType(), false, true);
+	const int orbitals = m_bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::OrbitalCommand.getUnitType(), false, true);
+	const int barracks = m_bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Barracks.getUnitType(), false, true, true);
+	if (barracks == 0)
+	{
+		return false;
+	}
+	if (m_bot.Buildings().isBeingBuilt(MetaTypeEnum::CommandCenter.getUnitType()))
+	{
+		return false;
+	}
+	if (commandCenters + orbitals >= 2)
+	{
+		return false;
+	}
+
+	return m_bot.GetFreeMinerals() < MetaTypeEnum::CommandCenter.getUnitType().mineralPrice();
+}
