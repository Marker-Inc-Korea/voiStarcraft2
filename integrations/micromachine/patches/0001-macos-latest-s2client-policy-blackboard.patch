+		if (!worker.isValid() || !worker.isAlive())
+        {
+			if (liveWorkerTags.find(worker.getTag()) != liveWorkerTags.end())
+			{
+				continue;
+			}
+            workersDestroyed.push_back(worker);
+        }
+    }
+
+    for (auto & worker : workersDestroyed)
+    {
+        workerDestroyed(worker);		
+    }
+}
+
+void WorkerData::updateIdleMineralTarget()
+{
+	BaseLocation* closestBase = nullptr;
+	// Choose our base in which we are building a resource depot
+	auto & allyBases = m_bot.Bases().getOccupiedBaseLocations(Players::Self);
+	for (auto base : allyBases)
+	{
+		if (base && !base->isUnderAttack() && (!base->getResourceDepot().isValid() || !base->getResourceDepot().isCompleted()) && base->getMinerals().size() != 0)
+		{
+			if (m_bot.Strategy().wasProxyStartingStrategy())
+			{
+				auto groundDistance = base->getGroundDistance(m_bot.Buildings().getProxyLocation());
+				if (groundDistance <= 15)
+					continue;
+			}
+			closestBase = base;
+			break;
+		}
+	}
+
+	// If we have none, choose the next expansion
+	if (!closestBase)
+	{
+		closestBase = m_bot.Bases().getNextExpansion(Players::Self, false, false, true);
+	}
+	// If that base is not occupied by the enemy and does not have a completed resource depot, we find the mineral patch to mine from
+	if (closestBase && !closestBase->isUnderAttack() && !closestBase->isOccupiedByPlayer(Players::Enemy) && (!closestBase->getResourceDepot().isValid() || !closestBase->getResourceDepot().isCompleted()))
+	{
+		const BaseLocation * homeBase = m_bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+		if (homeBase->getResourceDepot().isValid())
+		{
+			m_idleMineralTarget = GetBestMineralInList(closestBase->getMinerals(), homeBase->getResourceDepot(), false);
+			//closestBase->updateMineral(m_idleMineralTarget);
+		}
+	}
+}
+
+void WorkerData::workerDestroyed(const Unit & unit)//deadWorker
+{
+    clearPreviousJob(unit);
+    m_workers.erase(unit);
+    m_proxyWorkers.erase(unit);
+	m_workerMineralMap.erase(unit);
+	m_workerLastSeenFrame.erase(unit.getTag());
+	m_pendingMineralAssignmentTarget.erase(unit.getTag());
+	m_pendingMineralAssignmentFrame.erase(unit.getTag());
+
+	for (auto & building : m_workerRepairing)
+	{
+		if (building.second.find(unit) != building.second.end())
+		{
+			//worker is no longer repairing
+			building.second.erase(unit);
+		}
+	}
+
+	for (auto & mineralWorker : m_mineralWorkersMap)
+	{
+		mineralWorker.second.remove(unit.getTag());
+	}	
+}
+
+void WorkerData::updateWorker(const Unit & unit)
+{
+	m_workerLastSeenFrame[unit.getTag()] = m_bot.GetCurrentFrame();
+    auto workerIt = m_workers.find(unit);
+    if (workerIt == m_workers.end())
+    {
+        m_workers.insert(unit);
+        m_workerJobMap[unit] = WorkerJobs::None;
+        m_workerJobCount[WorkerJobs::None]++;
+    }
+	else
+	{
+		// SC2 observations refresh Unit wrappers every frame. Keep set entries on
+		// the latest wrapper while preserving tag-keyed job maps.
+		if (workerIt->getUnitPtr() != unit.getUnitPtr())
+		{
+			m_workers.erase(workerIt);
+			m_workers.insert(unit);
+		}
+		auto refreshWorkerSet = [&unit](std::set<Unit> & units) {
+			auto it = units.find(unit);
+			if (it != units.end() && it->getUnitPtr() != unit.getUnitPtr())
+			{
+				units.erase(it);
+				units.insert(unit);
+			}
+		};
+		refreshWorkerSet(m_proxyWorkers);
+		refreshWorkerSet(m_idleWorkers);
+		refreshWorkerSet(m_mineralWorkers);
+	}
+}
+
+void WorkerData::setWorkerJob(const Unit & worker, int job, Unit jobUnit)
+{
+	if (job == WorkerJobs::Minerals)
+	{
+		auto currentJob = m_workerJobMap.find(worker);
+		auto currentDepot = m_workerDepotMap.find(worker);
+		auto currentMineral = m_workerMineralMap.find(worker);
+		if (currentJob != m_workerJobMap.end()
+			&& currentJob->second == WorkerJobs::Minerals
+			&& currentDepot != m_workerDepotMap.end()
+			&& currentDepot->second.isValid()
+			&& jobUnit.isValid()
+			&& currentDepot->second.getTag() == jobUnit.getTag()
+			&& currentMineral != m_workerMineralMap.end()
+			&& currentMineral->second.isValid()
+			&& currentMineral->second.isAlive()
+			&& currentMineral->second.getType().isMineral())
+		{
+			// Root fix for repeated SCV mineral commands: keeping the same
+			// mineral job must not re-emit a SMART command and interrupt work.
+			return;
+		}
+	}
+
+	if (job == WorkerJobs::Gas)
+	{
+		auto currentJob = m_workerJobMap.find(worker);
+		auto currentRefinery = m_workerRefineryMap.find(worker);
+		if (currentJob != m_workerJobMap.end()
+			&& currentJob->second == WorkerJobs::Gas
+			&& currentRefinery != m_workerRefineryMap.end()
+			&& currentRefinery->second.isValid()
+			&& jobUnit.isValid()
+			&& currentRefinery->second.getTag() == jobUnit.getTag())
+		{
+			bool alreadyHarvestingTarget = false;
+			if (!worker.getUnitPtr()->orders.empty())
+			{
+				const auto & order = worker.getUnitPtr()->orders[0];
+				alreadyHarvestingTarget = order.target_unit_tag == jobUnit.getTag()
+					&& (order.ability_id == sc2::ABILITY_ID::SMART
+						|| order.ability_id == sc2::ABILITY_ID::HARVEST_GATHER
+						|| order.ability_id == sc2::ABILITY_ID::HARVEST_RETURN);
+			}
+			if (alreadyHarvestingTarget || isWorkerAssignedToRefinery(worker, jobUnit))
+			{
+				return;
+			}
+		}
+	}
+
+	if (job == WorkerJobs::Repair)
+	{
+		auto currentJob = m_workerJobMap.find(worker);
+		auto currentRepairTarget = m_workerRepairTarget.find(worker);
+		if (currentJob != m_workerJobMap.end()
+			&& currentJob->second == WorkerJobs::Repair
+			&& currentRepairTarget != m_workerRepairTarget.end()
+			&& currentRepairTarget->second.isValid()
+			&& jobUnit.isValid()
+			&& currentRepairTarget->second.getTag() == jobUnit.getTag())
+		{
+			bool alreadyRepairingTarget = false;
+			if (!worker.getUnitPtr()->orders.empty())
+			{
+				const auto & order = worker.getUnitPtr()->orders[0];
+				alreadyRepairingTarget = order.target_unit_tag == jobUnit.getTag()
+					&& (order.ability_id == sc2::ABILITY_ID::SMART
+						|| order.ability_id == sc2::ABILITY_ID::EFFECT_REPAIR);
+			}
+			if (alreadyRepairingTarget)
+			{
+				return;
+			}
+		}
+	}
+
+	clearPreviousJob(worker);
+    m_workerJobMap[worker] = job;
+    m_workerJobCount[job]++;
+
+	//Handle starting a job
+    if (job == WorkerJobs::Minerals)
+    {
+        // if we haven't assigned anything to this depot yet, set its worker count to 0
+        if (m_depotWorkerCount.find(jobUnit) == m_depotWorkerCount.end())
+        {
+            m_depotWorkerCount[jobUnit] = 0;
+        }
+
+        // add the worker to our set of depots
+        m_depots.insert(jobUnit);
+
+        // increase the worker count of this depot
+		if (worker.getAPIUnitType() != sc2::UNIT_TYPEID::TERRAN_MULE)
+		{
+			m_workerDepotMap[worker] = jobUnit;
+			m_depotWorkerCount[jobUnit]++;
+		}
+
+        // find the mineral to mine and mine it
+		if (m_bot.GetCurrentFrame() == 0)
+		{		
+		}
+		else
+		{
+			Unit mineralToMine;
+			auto assignedMineral = m_workerMineralMap.find(worker);
+			if (assignedMineral != m_workerMineralMap.end()
+				&& assignedMineral->second.isValid()
+				&& assignedMineral->second.isAlive()
+				&& assignedMineral->second.getType().isMineral())
+			{
+				mineralToMine = assignedMineral->second;
+			}
+			else
+			{
+				mineralToMine = getMineralToMine(jobUnit, worker.getPosition());
+			}
+			if (!mineralToMine.isValid())
+			{
+				//Try other bases
+				for (auto base : m_bot.Bases().getOccupiedBaseLocations(Players::Self))
+				{
+					const Unit & depot = base->getResourceDepot();
+					if (!depot.isValid() || jobUnit.getTag() == depot.getTag())
+						continue;
+					mineralToMine = getMineralToMine(depot, worker.getPosition());
+					if (mineralToMine.isValid())
+					{
+						break;
+					}
+				}
+			}
+
+			if (mineralToMine.isValid())
+			{
+				bool alreadyHarvestingTarget = false;
+				bool alreadyInMineralCycle = false;
+				if (!worker.getUnitPtr()->orders.empty())
+				{
+					const auto & order = worker.getUnitPtr()->orders[0];
+					alreadyHarvestingTarget = order.target_unit_tag == mineralToMine.getTag()
+						&& (order.ability_id == sc2::ABILITY_ID::SMART
+							|| order.ability_id == sc2::ABILITY_ID::HARVEST_GATHER
+							|| order.ability_id == sc2::ABILITY_ID::HARVEST_RETURN);
+					alreadyInMineralCycle = alreadyHarvestingTarget
+						|| order.ability_id == sc2::ABILITY_ID::HARVEST_RETURN
+						|| (order.ability_id == sc2::ABILITY_ID::HARVEST_GATHER && order.target_unit_tag != 0);
+				}
+				const uint32_t currentFrame = m_bot.GetCurrentFrame();
+				const auto pendingTarget = m_pendingMineralAssignmentTarget.find(worker.getTag());
+				const auto pendingFrame = m_pendingMineralAssignmentFrame.find(worker.getTag());
+				const bool recentlyAssignedSameMineral = pendingTarget != m_pendingMineralAssignmentTarget.end()
+					&& pendingFrame != m_pendingMineralAssignmentFrame.end()
+					&& pendingTarget->second == mineralToMine.getTag()
+					&& currentFrame >= pendingFrame->second
+					&& currentFrame - pendingFrame->second < 96;
+				if (!alreadyInMineralCycle && !recentlyAssignedSameMineral)
+				{
+					m_bot.Commander().setVoiWorkerCommandReason(worker, "mineral_assignment");
+					worker.rightClick(mineralToMine);
+					m_pendingMineralAssignmentTarget[worker.getTag()] = mineralToMine.getTag();
+					m_pendingMineralAssignmentFrame[worker.getTag()] = currentFrame;
+				}
+
+				if (!worker.getType().isMule())
+				{
+					m_workerMineralMap[worker] = mineralToMine;
+					auto & assignedWorkers = m_mineralWorkersMap[mineralToMine];
+					if (std::find(assignedWorkers.begin(), assignedWorkers.end(), worker.getTag()) == assignedWorkers.end())
+					{
+						assignedWorkers.push_back(worker.getTag());
+					}
+				}
+			}
+			else
+			{
+				//No minerals to mine on the map, A-move the enemy base
+				worker.attackMove(m_bot.Bases().getPlayerStartingBaseLocation(Players::Enemy)->getPosition());
+			}
+		}
+
+		m_mineralWorkers.insert(worker);
+    }
+    else if (job == WorkerJobs::Gas)
+    {
+		BOT_ASSERT(jobUnit.getType().isRefinery(), "JobUnit should be refinery");
+		BOT_ASSERT(worker.getType().isWorker(), "Unit should be worker");
+        // if we haven't assigned any workers to this refinery yet set count to 0
+        if (m_refineryWorkerCount.find(jobUnit) == m_refineryWorkerCount.end())
+        {
+            m_refineryWorkerCount[jobUnit] = 0;
+        }
+
+        // increase the count of workers assigned to this refinery
+        m_refineryWorkerCount[jobUnit] += 1;
+        m_workerRefineryMap[worker] = jobUnit;
+		m_refineryWorkerMap[jobUnit].push_back(worker);
+		m_workerRefineryTagMap[worker.getTag()] = jobUnit.getTag();
+		m_refineryWorkerTags[jobUnit.getTag()].insert(worker.getTag());
+		
+        // right click the refinery to start harvesting
+		m_bot.Commander().setVoiWorkerCommandReason(worker, "gas_assignment");
+        worker.rightClick(jobUnit);
+    }
+    else if (job == WorkerJobs::Repair)
+    {
+        worker.repair(jobUnit);
+        m_workerRepairing[jobUnit].insert(worker);
+        m_workerRepairTarget[worker] = jobUnit;
+    }
+    else if (job == WorkerJobs::Scout)
+    {
+
+    }
+    else if (job == WorkerJobs::Build)
+    {
+		if (jobUnit.isValid() && jobUnit.getBuildProgress() < 1.f)
+			worker.rightClick(jobUnit);	// We want to send the SCV to continue the building
+    }
+	else if (job == WorkerJobs::Idle)
+	{//Must not call stop().
+		if (!isProxyWorker(worker))
+		{
+			m_idleWorkers.insert(worker);
+		}
+	}
+}
+
+void WorkerData::clearPreviousJob(const Unit & unit)
+{
+    auto previousJobIt = m_workerJobMap.find(unit);
+	if (previousJobIt == m_workerJobMap.end())
+	{
+		return;
+	}
+	const int previousJob = previousJobIt->second;
+	if (m_workerJobCount[previousJob] > 0)
+	{
+		m_workerJobCount[previousJob]--;
+	}
+
+    if (previousJob == WorkerJobs::Minerals)
+    {
+        // remove one worker from the count of the depot this worker was assigned to
+		// increase the worker count of this depot
+		if (unit.getAPIUnitType() != sc2::UNIT_TYPEID::TERRAN_MULE)
+		{
+			m_depotWorkerCount[m_workerDepotMap[unit]]--;
+			m_workerDepotMap.erase(unit);
+
+			if (m_workerMineralMap.find(unit) != m_workerMineralMap.end())
+			{
+				m_mineralWorkersMap[m_workerMineralMap[unit]].remove(unit.getTag());
+			}
+			m_workerMineralMap.erase(unit);
+			m_mineralWorkers.erase(unit);
+		}
+    }
+    else if (previousJob == WorkerJobs::Gas)
+    {
+		auto refineryIt = m_workerRefineryMap.find(unit);
+		if (refineryIt != m_workerRefineryMap.end())
+		{
+			auto countIt = m_refineryWorkerCount.find(refineryIt->second);
+			if (countIt != m_refineryWorkerCount.end() && countIt->second > 0)
+			{
+				countIt->second--;
+			}
+			auto tagsIt = m_refineryWorkerTags.find(refineryIt->second.getTag());
+			if (tagsIt != m_refineryWorkerTags.end())
+			{
+				tagsIt->second.erase(unit.getTag());
+			}
+			m_workerRefineryMap.erase(refineryIt);
+		}
+		m_workerRefineryTagMap.erase(unit.getTag());
+		for (auto & refinery : m_refineryWorkerMap)
+		{
+			auto it = std::find(refinery.second.begin(), refinery.second.end(), unit);
+			if (it != refinery.second.end()) {
+				refinery.second.erase(it);
+			}
+		}
+    }
+    else if (previousJob == WorkerJobs::Build)
+    {
+		Micro::SmartAbility(unit.getUnitPtr(), sc2::ABILITY_ID::STOP, m_bot);
+		Micro::SmartAbility(unit.getUnitPtr(), sc2::ABILITY_ID::HALT_TERRANBUILD, m_bot);
+		auto building = m_bot.Buildings().getBuildingOfBuilder(unit);
+		if (building != Building() && (!building.buildingUnit.isValid() || building.buildingUnit.getBuildProgress() < 1.f))
+			m_bot.Buildings().getBuildingRef(building).unassign();
+    }
+    else if (previousJob == WorkerJobs::Repair)
+    {
+		
+    }
+	else if (previousJob == WorkerJobs::Idle)
+	{
+		m_idleWorkers.erase(unit);
+	}
+    else if (previousJob == WorkerJobs::Move)
+    {
+
+    }
+	else if (previousJob == WorkerJobs::None)//Only affects newly spawned workers
+	{
+
+	}
+
+    m_workerJobMap.erase(unit);
+}
