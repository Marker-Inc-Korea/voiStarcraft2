+void CombatCommander::clearCorrosiveBiles()
+{
+	for (auto it = m_cachedBiles.begin(); it != m_cachedBiles.end();)
+	{
+		if (m_bot.GetCurrentFrame() >= it->second + 22.4f)
+			it = m_cachedBiles.erase(it);
+		else
+			it++;
+	}
+}
