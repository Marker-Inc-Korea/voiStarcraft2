+bool canTrustDelayedBootstrapPlacement(CCBot & bot, const UnitType & type)
+{
+	if (!bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const auto apiType = type.getAPIUnitType();
+	if (apiType == sc2::UNIT_TYPEID::TERRAN_BARRACKS)
