+CCPosition ScoutManager::getEnemyBasePerimeterScoutPosition(const BaseLocation * enemyBaseLocation)
+{
+    if (enemyBaseLocation == nullptr)
+    {
+        return m_bot.Map().center();
+    }
+
+    const CCPosition center = enemyBaseLocation->getPosition();
+    const std::vector<CCPosition> offsets = {
+        CCPosition(14.0f, 0.0f),
+        CCPosition(10.0f, 10.0f),
+        CCPosition(0.0f, 14.0f),
+        CCPosition(-10.0f, 10.0f),
+        CCPosition(-14.0f, 0.0f),
+        CCPosition(-10.0f, -10.0f),
+        CCPosition(0.0f, -14.0f),
+        CCPosition(10.0f, -10.0f),
+        CCPosition(20.0f, 0.0f),
+        CCPosition(0.0f, 20.0f),
+        CCPosition(-20.0f, 0.0f),
+        CCPosition(0.0f, -20.0f),
+    };
+
+    const uint32_t currentFrame = m_bot.GetGameLoop();
+    if (currentFrame >= m_lastEnemyBaseScoutWaypointFrame &&
+        currentFrame - m_lastEnemyBaseScoutWaypointFrame >= 224)
+    {
+        m_enemyBaseScoutWaypointIndex++;
+        m_lastEnemyBaseScoutWaypointFrame = currentFrame;
+    }
+
+    for (size_t i = 0; i < offsets.size(); ++i)
+    {
+        const size_t index = (m_enemyBaseScoutWaypointIndex + i) % offsets.size();
+        const CCPosition candidate = center + offsets[index];
+        const CCTilePosition tile = Util::GetTilePosition(candidate);
+        if (m_bot.Map().isValidTile(tile) && m_bot.Map().isWalkable(tile))
+        {
+            m_enemyBaseScoutWaypointIndex = index;
+            return candidate;
+        }
+    }
+
+    return center;
+}
