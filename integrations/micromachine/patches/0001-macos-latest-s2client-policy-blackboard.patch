+
+void ProductionManager::refreshVoiDoctrinePolicyBaseline(const std::string & updateId)
+{
+	if (updateId.empty() || updateId == m_voiDoctrineBaselineUpdateId)
+	{
+		return;
+	}
+
+	m_voiDoctrineBaselineUpdateId = updateId;
+	m_voiDoctrineBaselineFrame = m_bot.GetCurrentFrame();
+	m_voiDoctrineQueueBaseline.clear();
+	m_voiDoctrineUnitCountBaseline.clear();
+	m_lastVoiDoctrineFrame = 0;
+	m_lastVoiDoctrineAction = "none";
+	m_lastVoiDoctrineQueueItem = "none";
+	m_lastVoiDoctrineEvidence = "none";
+	m_lastVoiDoctrineUpdateId = "";
+	m_lastVoiProductionCommandFrame = 0;
+	m_voiProductionCommandIssuedCount = 0;
+	m_lastVoiProductionCommandItem = "none";
+	m_lastVoiProductionCommandKind = "none";
+	m_lastVoiProductionCommandUpdateId = "";
+	m_lastVoiSupplyBlockFrame = 0;
+	m_lastVoiSupplyRecoveryFrame = 0;
+	m_voiSupplyRecoveryQueuedCount = 0;
+	m_lastVoiSupplyProviderCommandFrame = 0;
+	m_lastVoiSupplyProviderUnderConstructionCount = 0;
+	m_lastVoiSupplyRecoveryStatus = "none";
+	m_lastVoiSupplyRecoveryReason = "none";
+	m_lastVoiSupplyProviderCommandKind = "none";
+	m_lastVoiSupplyProviderCommandUpdateId = "";
+
+	const std::vector<MetaType> baselineTypes = {
+		MetaTypeEnum::Barracks,
+		MetaTypeEnum::Factory,
+		MetaTypeEnum::BarracksTechLab,
+		MetaTypeEnum::FactoryTechLab,
+		MetaTypeEnum::Starport,
+		MetaTypeEnum::StarportReactor,
+			MetaTypeEnum::EngineeringBay,
+			MetaTypeEnum::CommandCenter,
+			MetaTypeEnum::SupplyDepot,
+			MetaTypeEnum::SiegeTank,
+		MetaTypeEnum::Hellion,
+		MetaTypeEnum::Cyclone,
+		MetaTypeEnum::Thor,
+		MetaTypeEnum::Medivac,
+		MetaTypeEnum::Viking,
+		MetaTypeEnum::Marauder,
+		MetaTypeEnum::Reaper,
+		MetaTypeEnum::Marine,
+	};
+	for (const auto & type : baselineTypes)
+	{
+		if (!type.isUnit())
+		{
+			continue;
+		}
+		const auto unitType = type.getUnitType();
+		const auto apiType = unitType.getAPIUnitType();
+		m_voiDoctrineQueueBaseline[apiType] = m_queue.contains(type);
+		m_voiDoctrineUnitCountBaseline[apiType] = m_bot.UnitInfo().getUnitTypeCount(Players::Self, unitType, false, true, true);
+	}
+}
+
+bool ProductionManager::wasVoiDoctrineQueuePresentAtBaseline(const MetaType & type) const
+{
+	if (!type.isUnit())
+	{
+		return false;
+	}
+	const auto it = m_voiDoctrineQueueBaseline.find(type.getUnitType().getAPIUnitType());
+	return it != m_voiDoctrineQueueBaseline.end() && it->second;
+}
+
+int ProductionManager::getVoiDoctrineUnitBaselineCount(const UnitType & unitType) const
+{
+	const auto it = m_voiDoctrineUnitCountBaseline.find(unitType.getAPIUnitType());
+	if (it == m_voiDoctrineUnitCountBaseline.end())
+	{
+		return 0;
+	}
+	return it->second;
+}
