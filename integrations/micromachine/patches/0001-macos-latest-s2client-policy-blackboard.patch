+void WorkerData::updateWorker(const Unit & unit)
+{
+	m_workerLastSeenFrame[unit.getTag()] = m_bot.GetCurrentFrame();
+    auto workerIt = m_workers.find(unit);
+    if (workerIt == m_workers.end())
+    {
+        m_workers.insert(unit);
+        m_workerJobMap[unit] = WorkerJobs::None;
+        m_workerJobCount[WorkerJobs::None]++;
+    }
+	else
+	{
+		// SC2 observations refresh Unit wrappers every frame. Keep set entries on
+		// the latest wrapper while preserving tag-keyed job maps.
+		if (workerIt->getUnitPtr() != unit.getUnitPtr())
+		{
+			m_workers.erase(workerIt);
+			m_workers.insert(unit);
+		}
+		auto refreshWorkerSet = [&unit](std::set<Unit> & units) {
+			auto it = units.find(unit);
+			if (it != units.end() && it->getUnitPtr() != unit.getUnitPtr())
+			{
+				units.erase(it);
+				units.insert(unit);
+			}
+		};
+		refreshWorkerSet(m_proxyWorkers);
+		refreshWorkerSet(m_idleWorkers);
+		refreshWorkerSet(m_mineralWorkers);
+	}
+}
