+		{
+			return true;
+		}
+	}
+
+	for (const auto & unit : bot.GetUnits())
+	{
+		if (unit.getType().isGeyser() && Util::DistSq(unit.getPosition(), targetPosition) < 3 * 3)
+		{
+			return true;
+		}
+	}
+
+	return false;
+}
