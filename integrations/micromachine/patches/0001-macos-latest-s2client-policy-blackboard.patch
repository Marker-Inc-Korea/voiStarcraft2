+	return (token == "TERRAN_MARINE" && type == sc2::UNIT_TYPEID::TERRAN_MARINE)
+		|| (token == "TERRAN_MARAUDER" && type == sc2::UNIT_TYPEID::TERRAN_MARAUDER)
+		|| (token == "TERRAN_REAPER" && type == sc2::UNIT_TYPEID::TERRAN_REAPER)
+		|| (token == "TERRAN_HELLION" && type == sc2::UNIT_TYPEID::TERRAN_HELLION)
+		|| (token == "TERRAN_CYCLONE" && type == sc2::UNIT_TYPEID::TERRAN_CYCLONE)
+		|| (token == "TERRAN_THOR" && type == sc2::UNIT_TYPEID::TERRAN_THOR)
+		|| (token == "TERRAN_SIEGETANK" && (type == sc2::UNIT_TYPEID::TERRAN_SIEGETANK || type == sc2::UNIT_TYPEID::TERRAN_SIEGETANKSIEGED))
+		|| (token == "TERRAN_MEDIVAC" && type == sc2::UNIT_TYPEID::TERRAN_MEDIVAC)
