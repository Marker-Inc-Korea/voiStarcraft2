+int WorkerData::getNumAssignedWorkers(const Unit & unit)
+{
+	if (!unit.isValid())
+		return 0;
+	
+    if (unit.getType().isResourceDepot())
+    {
+        auto it = m_depotWorkerCount.find(unit);
+
+        // if there is an entry, return it
+        if (it != m_depotWorkerCount.end())
+        {
+            return it->second;
+        }
+    }
+    else if (unit.getType().isRefinery())
+    {
+		auto tagIt = m_refineryWorkerTags.find(unit.getTag());
+		if (tagIt != m_refineryWorkerTags.end())
+		{
+#ifndef PUBLIC_RELEASE
+			if(m_bot.Config().DrawWorkerInfo)
+				m_bot.Map().drawText(unit.getPosition(), "Workers affected: " + std::to_string(tagIt->second.size()));
+#endif
+			return static_cast<int>(tagIt->second.size());
+		}
+
+        auto it = m_refineryWorkerCount.find(unit);
+
+        // if there is an entry, return it
+        if (it != m_refineryWorkerCount.end())
+        {
+#ifndef PUBLIC_RELEASE
+			if(m_bot.Config().DrawWorkerInfo)
+				m_bot.Map().drawText(unit.getPosition(), "Workers affected: " + std::to_string(it->second));
+#endif
+            return it->second;
+        }
+        // otherwise, we are only calling this on completed refineries, so set it
+        else
+        {
+            m_refineryWorkerCount[unit] = 0;
+        }
+    }
+
+    // when all else fails, return 0
+    return 0;
+}
+
+bool WorkerData::isWorkerAssignedToRefinery(const Unit & worker, const Unit & refinery) const
+{
+	if (!worker.isValid() || !refinery.isValid() || !refinery.getType().isRefinery())
+	{
+		return false;
+	}
+	auto it = m_workerRefineryTagMap.find(worker.getTag());
+	return it != m_workerRefineryTagMap.end() && it->second == refinery.getTag();
+}
+
+std::vector<Unit> WorkerData::getAssignedWorkersRefinery(const Unit & unit)
+{
+	std::vector<Unit> assignedWorkers;
+	if (unit.isValid() && unit.getType().isRefinery())
+	{
+		auto tagIt = m_refineryWorkerTags.find(unit.getTag());
+		if (tagIt != m_refineryWorkerTags.end())
+		{
+			for (const auto workerTag : tagIt->second)
+			{
+				for (const auto & worker : m_workers)
+				{
+					if (worker.isValid()
+						&& worker.getTag() == workerTag
+						&& getWorkerJob(worker) == WorkerJobs::Gas
+						&& isWorkerAssignedToRefinery(worker, unit))
+					{
+						assignedWorkers.push_back(worker);
+						break;
+					}
+				}
+			}
+			return assignedWorkers;
+		}
+	}
+
+	if (unit.getType().isResourceDepot())
+	{
+		auto it = m_refineryWorkerMap.find(unit);
+		// if there is an entry, return it
+		if (it != m_refineryWorkerMap.end())
+		{
+			return it->second;
+		}
+	}
+	else if (unit.getType().isRefinery())
+	{
+		auto it = m_refineryWorkerMap.find(unit);
+
+		// if there is an entry, return it
+		if (it != m_refineryWorkerMap.end())
+		{
+			return it->second;
+		}
+	}
+
+	// when all else fails, return 0
+	return std::vector<Unit>();
+}
