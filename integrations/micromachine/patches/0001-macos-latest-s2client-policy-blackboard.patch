+class ScopedVoiEnvironmentStripper {
+    std::vector<std::pair<std::string, std::string>> m_saved;
+
+public:
+    ScopedVoiEnvironmentStripper()
+    {
+        const char * names[] = {
+            "VOI_MICROMACHINE_BLACKBOARD_DIR",
+            "VOI_SC2_BOOTSTRAP_SELF_UNITS",
+            "VOI_SC2_CONNECT_PORT",
+            "VOI_SC2_DIAGNOSTIC_AGENT",
+            "VOI_SC2_EXTRA_ARGS",
+            nullptr,
+        };
+        for (const char ** name = names; *name != nullptr; ++name)
+        {
+            const char * value = std::getenv(*name);
+            if (value != nullptr)
+            {
+                m_saved.emplace_back(*name, value);
+                unsetenv(*name);
+            }
+        }
+    }
+
+    ~ScopedVoiEnvironmentStripper()
+    {
+        for (const auto & item : m_saved)
+        {
+            setenv(item.first.c_str(), item.second.c_str(), 1);
+        }
+    }
+};
