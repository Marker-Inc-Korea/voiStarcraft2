+float voiTargetPriorityScore(const Unit & enemyUnit, CCBot & bot)
+{
+	const UnitType & type = enemyUnit.getType();
+	float score = 0.0f;
+	if (type.isWorker())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.worker_line", 0.0f);
+	}
+	if (type.isResourceDepot())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.townhall", 0.0f);
+	}
+	if (type.isBuilding() && !type.isResourceDepot())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.production", 0.0f);
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.tech", 0.0f);
+	}
+	if (type.isCombatUnit())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.army", 0.0f);
+	}
+	if (type.isDetector())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.detector", 0.0f);
+	}
+	if (enemyUnit.isFlying())
+	{
+		score += bot.Commander().getVoiPolicyFloat("combat.target_priority_biases.air_threat", 0.0f);
+	}
+	return score;
+}
