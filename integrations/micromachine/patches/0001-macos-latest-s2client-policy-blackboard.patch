+			type == MetaTypeEnum::SupplyDepot.getUnitType()) && bot.GetCurrentFrame() < 7000) ||
+		(type == MetaTypeEnum::EngineeringBay.getUnitType() && bot.GetCurrentFrame() < 9000) ||
+		(canTrustOpeningWallPlacement(bot, type) && bot.GetCurrentFrame() < 10000) ||
+		canTrustDelayedBootstrapPlacement(bot, type);
