+		case sc2::UNIT_TYPEID::NEUTRAL_RICHVESPENEGEYSER:
+			std::cout << "Unit type " << m_type << " has no vespene gas but is a vespene geyser" << std::endl;
+			return true;
+        default: return false;
+    }
