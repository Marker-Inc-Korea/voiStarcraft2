+
+void ProductionManager::applyVoiDoctrineProductionBias()
+{
+	if (m_bot.GetSelfRace() != CCRace::Terran || !m_bot.Commander().isVoiPolicyActive())
+	{
+		return;
+	}
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	const std::string updateId = m_bot.Commander().getVoiPolicyString("update_id", "");
+	refreshVoiDoctrinePolicyBaseline(updateId);
+	if (currentFrame - m_lastVoiDoctrineFrame < 112)
+	{
+		return;
+	}
+
+	const std::string tacticalTaskType = m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const std::string tacticalProductionTargets = m_bot.Commander().getVoiPolicyString("tactical_task.production_targets", "");
+	const float tacticalTaskPriority = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("tactical_task.priority", 0.0f));
+	const bool tacticalTaskActive = voiTacticalTaskWithinDuration(m_bot);
+	const bool taskSustainProduction = tacticalTaskActive && tacticalTaskType == "sustain_production";
+	const bool taskTechTransition = tacticalTaskActive && tacticalTaskType == "tech_transition";
+	const bool taskExpandCommandCenter = tacticalTaskActive && tacticalTaskType == "expand_or_land_command_center";
+	const bool taskTargetsScv = voiCommaListContains(tacticalProductionTargets, "TERRAN_SCV") || voiCommaListContains(tacticalProductionTargets, "SCV");
+	const bool taskTargetsSupplyDepot = voiCommaListContains(tacticalProductionTargets, "TERRAN_SUPPLYDEPOT");
+	const bool taskTargetsCommandCenter = voiCommaListContains(tacticalProductionTargets, "TERRAN_COMMANDCENTER");
+	const bool taskTargetsFactory = voiCommaListContains(tacticalProductionTargets, "TERRAN_FACTORY");
+	const bool taskTargetsFactoryTechLab = voiCommaListContains(tacticalProductionTargets, "FACTORY_TECHLAB") || voiCommaListContains(tacticalProductionTargets, "TERRAN_FACTORYTECHLAB");
+	const bool taskTargetsStarport = voiCommaListContains(tacticalProductionTargets, "TERRAN_STARPORT");
+	const bool taskTargetsStarportTechLab = voiCommaListContains(tacticalProductionTargets, "STARPORT_TECHLAB") || voiCommaListContains(tacticalProductionTargets, "TERRAN_STARPORTTECHLAB");
+	const bool taskTargetsFusionCore = voiCommaListContains(tacticalProductionTargets, "TERRAN_FUSIONCORE");
+	const bool taskTargetsMarine = voiCommaListContains(tacticalProductionTargets, "TERRAN_MARINE");
+	const bool taskTargetsSiegeTank = voiCommaListContains(tacticalProductionTargets, "TERRAN_SIEGETANK");
+	const bool taskTargetsMedivac = voiCommaListContains(tacticalProductionTargets, "TERRAN_MEDIVAC");
+	const bool taskTargetsViking = voiCommaListContains(tacticalProductionTargets, "TERRAN_VIKINGFIGHTER");
+	const bool taskTargetsBanshee = voiCommaListContains(tacticalProductionTargets, "TERRAN_BANSHEE");
+	const bool taskTargetsRaven = voiCommaListContains(tacticalProductionTargets, "TERRAN_RAVEN");
+	const bool taskTargetsBattlecruiser = voiCommaListContains(tacticalProductionTargets, "TERRAN_BATTLECRUISER");
+	const std::string doctrine = m_bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	const float techSwitchUrgency = m_bot.Commander().getVoiPolicyFloat("production.tech_switch_urgency", 0.0f);
+	const float compositionBioBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.bio", 0.0f);
+	const float compositionMechBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.mech", 0.0f);
+	const float compositionSiegeBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.siege", 0.0f);
+	const float compositionDropBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.drop", 0.0f);
+	const float compositionMedivacBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.medivac_support", 0.0f);
+	const float compositionHarassBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.harass", 0.0f);
+	const float compositionWorkerLineBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.worker_line", 0.0f);
+	const float compositionMacroBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.macro", 0.0f);
+	const float compositionAntiAirBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.anti_air", 0.0f);
+	const float compositionDefenseBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.defense", 0.0f);
+	const float compositionCounterattackBias = m_bot.Commander().getVoiPolicyFloat("production.composition_biases.counterattack", 0.0f);
+	const float workerProductionBias = std::max(
+		m_bot.Commander().getVoiPolicyFloat("economy.worker_production_bias", 0.0f),
+		(taskSustainProduction && taskTargetsScv) ? tacticalTaskPriority : 0.0f);
+	const float factoryBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_FACTORY", "production.production_facility_biases.TERRAN_FACTORY", "tech.structure_biases.TERRAN_FACTORY"),
+		(taskTechTransition && taskTargetsFactory) ? tacticalTaskPriority : 0.0f);
+	const float starportBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_STARPORT", "production.production_facility_biases.TERRAN_STARPORT", "tech.structure_biases.TERRAN_STARPORT"),
+		(taskTechTransition && taskTargetsStarport) ? tacticalTaskPriority : 0.0f);
+	const float commandCenterBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_COMMANDCENTER", "economy.expand_bias"),
+		(taskExpandCommandCenter || taskTargetsCommandCenter) ? tacticalTaskPriority : 0.0f);
+	const float barracksBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_BARRACKS", "production.production_facility_biases.TERRAN_BARRACKS");
+	const float barracksTechLabBias = voiMaxBias(m_bot, "production.queue_biases.BARRACKS_TECHLAB", "production.addon_biases.BARRACKS_TECHLAB");
+	const float marineBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_MARINE", "tech.unit_biases.TERRAN_MARINE"),
+		(taskSustainProduction && taskTargetsMarine) ? tacticalTaskPriority : 0.0f);
+	const float marauderBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_MARAUDER", "tech.unit_biases.TERRAN_MARAUDER");
+	const float reaperBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_REAPER", "tech.unit_biases.TERRAN_REAPER");
+	const float tankBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_SIEGETANK", "tech.unit_biases.TERRAN_SIEGETANK"),
+		(taskTechTransition && taskTargetsSiegeTank) ? tacticalTaskPriority : 0.0f);
+	const float hellionBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_HELLION", "tech.unit_biases.TERRAN_HELLION");
+	const float cycloneBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_CYCLONE", "tech.unit_biases.TERRAN_CYCLONE");
+	const float thorBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_THOR", "tech.unit_biases.TERRAN_THOR");
+	const float medivacBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_MEDIVAC", "tech.unit_biases.TERRAN_MEDIVAC"),
+		(taskTechTransition && taskTargetsMedivac) ? tacticalTaskPriority : 0.0f);
+	const float vikingBias = voiMaxBias(m_bot, "production.queue_biases.TERRAN_VIKINGFIGHTER", "tech.unit_biases.TERRAN_VIKINGFIGHTER");
+	const float bansheeBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_BANSHEE", "tech.unit_biases.TERRAN_BANSHEE"),
+		(taskTechTransition && taskTargetsBanshee) ? tacticalTaskPriority : 0.0f);
+	const float ravenBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_RAVEN", "tech.unit_biases.TERRAN_RAVEN"),
+		(taskTechTransition && taskTargetsRaven) ? tacticalTaskPriority : 0.0f);
+	const float battlecruiserBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.TERRAN_BATTLECRUISER", "tech.unit_biases.TERRAN_BATTLECRUISER"),
+		(taskTechTransition && taskTargetsBattlecruiser) ? tacticalTaskPriority : 0.0f);
+	const float factoryTechLabBias = std::max(
+		voiMaxBias(m_bot, "production.queue_biases.FACTORY_TECHLAB", "production.addon_biases.FACTORY_TECHLAB"),
