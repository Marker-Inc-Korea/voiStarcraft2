+int UnitType::mineralPrice() const
+{
+	BOT_ASSERT(m_type != 0, "Invalid type id");
+	const sc2::UnitTypeData * unitTypeData = findUnitTypeData(m_bot, m_type);
+	return unitTypeData ? static_cast<int>(unitTypeData->mineral_cost) : 0;
+}
+
+int UnitType::gasPrice() const
+{
+	BOT_ASSERT(m_type != 0, "Invalid type id");
+	const sc2::UnitTypeData * unitTypeData = findUnitTypeData(m_bot, m_type);
+	return unitTypeData ? static_cast<int>(unitTypeData->vespene_cost) : 0;
