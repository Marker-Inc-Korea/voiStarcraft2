+const sc2::UnitTypeData * findUnitTypeData(CCBot * bot, sc2::UnitTypeID type)
+{
+	if (bot == nullptr)
+	{
+		return nullptr;
+	}
+	const sc2::UnitTypes & unitTypes = bot->Observation()->GetUnitTypeData();
+	const uint32_t typeId = static_cast<uint32_t>(type);
+	if (typeId < unitTypes.size() && unitTypes[typeId].unit_type_id == type)
+	{
+		return &unitTypes[typeId];
+	}
+	for (const sc2::UnitTypeData & data : unitTypes)
+	{
+		if (data.unit_type_id == type)
+		{
+			return &data;
+		}
+	}
+	return nullptr;
+}
