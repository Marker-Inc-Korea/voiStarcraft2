+bool isVoiSc2MacroPlacementSafeWithOptions(
+	CCBot & bot,
+	const UnitType & type,
+	const CCTilePosition & position,
+	bool ignoreReserved,
+	bool includeAddonTiles,
+	bool ignoreExtraBorder,
+	bool requireQueryPlacement,
+	bool allowCombatInfluence)
+{
+	if (!shouldUseVoiSc2MacroPlacement(bot, type) ||
+		position == CCTilePosition() ||
+		!bot.Map().isValidTile(position))
+	{
+		return false;
+	}
+
+	const int extraBorder = ignoreExtraBorder ? 0 : 0;
+	const auto tiles = bot.Buildings().getBuildingPlacer().getTilesForBuildLocation(
+		position.x,
+		position.y,
+		type,
+		type.tileWidth(),
+		type.tileHeight(),
+		includeAddonTiles,
+		extraBorder);
+	for (const auto & tile : tiles)
+	{
+		if (!bot.Map().isValidTile(tile))
+		{
+			return false;
+		}
+		if (!ignoreReserved && bot.Buildings().getBuildingPlacer().isReserved(tile.x, tile.y))
+		{
+			return false;
+		}
+		if (!Util::IsZerg(bot.GetSelfRace()) && bot.Observation()->HasCreep(CCPosition(tile.x, tile.y)))
+		{
+			return false;
+		}
+		if (!allowCombatInfluence && Util::PathFinding::GetCombatInfluenceOnTile(tile, false, bot) > 0)
+		{
+			return false;
+		}
+	}
+	if (isVoiDepotFlowProtectedPlacement(bot, type, tiles))
+	{
+		return false;
+	}
+
+	return !requireQueryPlacement || queryCanPlaceVoiBuilding(bot, type, Util::GetPosition(position));
+}
