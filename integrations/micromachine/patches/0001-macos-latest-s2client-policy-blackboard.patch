+bool GameCommander::hasVoiPolicyDomain(const std::string & domain) const
+{
+	return m_voiPolicyActive
+		&& !domain.empty()
+		&& voiCommaListContains(m_voiPolicyBlackboard.getString("manager_bias_domains", ""), domain);
+}
+
+bool GameCommander::hasVoiPolicyKey(const std::string & key) const
+{
+	if (!m_voiPolicyActive || !m_voiPolicyBlackboard.has(key))
+	{
+		return false;
+	}
+	const auto separator = key.find('.');
+	if (separator == std::string::npos)
+	{
+		return true;
+	}
+	return hasVoiPolicyDomain(key.substr(0, separator));
+}
+
+float GameCommander::getVoiPolicyFloat(const std::string & key, float fallback) const
+{
+	return m_voiPolicyActive ? m_voiPolicyBlackboard.getFloat(key, fallback) : fallback;
+}
+
+int GameCommander::getVoiPolicyInt(const std::string & key, int fallback) const
+{
+	return m_voiPolicyActive ? m_voiPolicyBlackboard.getInt(key, fallback) : fallback;
+}
+
+bool GameCommander::getVoiPolicyBool(const std::string & key, bool fallback) const
+{
+	return m_voiPolicyActive ? m_voiPolicyBlackboard.getBool(key, fallback) : fallback;
+}
+
+std::string GameCommander::getVoiPolicyString(const std::string & key, const std::string & fallback) const
+{
+	return m_voiPolicyActive ? m_voiPolicyBlackboard.getString(key, fallback) : fallback;
+}
+
+int GameCommander::getVoiWorkerRepeatGuardFrames() const
+{
+	if (!hasVoiPolicyKey("workers.repeat_order_guard_frames"))
+	{
+		return 0;
+	}
+
+	int guardFrames = getVoiPolicyInt("workers.repeat_order_guard_frames", 0);
+	if (guardFrames < 4)
+	{
+		guardFrames = 4;
+	}
+	else if (guardFrames > 96)
+	{
+		guardFrames = 96;
+	}
+	return guardFrames;
+}
+
+bool GameCommander::shouldSuppressRepeatedWorkerCommand(const sc2::Unit * unit, const sc2::AbilityID & abilityID, sc2::Tag targetTag, const CCPosition & targetPosition, const std::string & targetKind)
+{
+	if (unit == nullptr || !voiIsWorkerUnitType(unit->unit_type) || targetKind.empty())
+	{
+		return false;
+	}
+
+	const uint32_t currentFrame = m_bot.GetGameLoop();
+	VoiWorkerCommandRecord next;
+	next.abilityId = static_cast<int>(abilityID.ToType());
+	next.targetTag = targetTag;
+	next.targetX100 = voiQuantizePosition(targetPosition.x);
+	next.targetY100 = voiQuantizePosition(targetPosition.y);
+	next.frame = currentFrame;
+	next.targetKind = targetKind;
+	next.reason = consumeVoiWorkerCommandReason(unit->tag, targetKind);
+
+	const CCPosition workerPosition(unit->pos);
+	const float targetDistanceSq = voiDistanceSq(workerPosition, targetPosition);
+	if (targetTag == 0 && voiIsPositionWorkerAbility(abilityID) && targetDistanceSq <= 0.36f)
+	{
+		m_voiWorkerSelfPositionCommandBlocks++;
+		m_voiWorkerLastRootCauseStatus = "self_position_move_blocked";
+		m_voiWorkerLastRootCauseReason = next.reason;
+		m_voiWorkerLastSelfPositionFrame = currentFrame;
+		m_voiWorkerLastSelfPositionWorker = unit->tag;
+		m_voiWorkerLastSelfPositionAbility = next.abilityId;
+		m_voiWorkerLastSelfPositionTargetX = targetPosition.x;
+		m_voiWorkerLastSelfPositionTargetY = targetPosition.y;
+		m_voiWorkerLastSelfPositionDistanceSq = targetDistanceSq;
+		m_voiWorkerLastSelfPositionTargetKind = targetKind;
+		m_voiWorkerLastCurrentOrderAbility = 0;
+		m_voiWorkerLastCurrentOrderTargetTag = 0;
+		m_voiWorkerLastCurrentOrderTargetX = 0.0f;
+		m_voiWorkerLastCurrentOrderTargetY = 0.0f;
+		if (!unit->orders.empty())
+		{
+			const auto & order = unit->orders[0];
+			m_voiWorkerLastCurrentOrderAbility = static_cast<int>(order.ability_id.ToType());
+			m_voiWorkerLastCurrentOrderTargetTag = order.target_unit_tag;
+			m_voiWorkerLastCurrentOrderTargetX = order.target_pos.x;
+			m_voiWorkerLastCurrentOrderTargetY = order.target_pos.y;
+		}
+		return true;
+	}
+
+	const int guardFrames = getVoiWorkerRepeatGuardFrames();
+	if (guardFrames <= 0)
+	{
+		return false;
+	}
+
+	const auto previous = m_voiWorkerLastCommands.find(unit->tag);
+	if (previous != m_voiWorkerLastCommands.end())
+	{
+		const VoiWorkerCommandRecord & last = previous->second;
+		const bool sameCommand = last.abilityId == next.abilityId
+			&& last.targetTag == next.targetTag
+			&& last.targetX100 == next.targetX100
+			&& last.targetY100 == next.targetY100
+			&& last.targetKind == next.targetKind;
+		if (sameCommand && currentFrame >= last.frame && currentFrame - last.frame < static_cast<uint32_t>(guardFrames))
+		{
+			m_voiWorkerRepeatedCommandSuppressions++;
+			m_voiWorkerLastSuppressionFrame = currentFrame;
+			m_voiWorkerLastSuppressedWorker = unit->tag;
+			m_voiWorkerLastSuppressedAbility = next.abilityId;
+			m_voiWorkerLastSuppressedTargetTag = targetTag;
+			m_voiWorkerLastSuppressedTargetX = targetPosition.x;
+			m_voiWorkerLastSuppressedTargetY = targetPosition.y;
+			m_voiWorkerLastSuppressedTargetKind = targetKind;
+			m_voiWorkerLastRootCauseStatus = "duplicate_command_safety_blocked";
+			m_voiWorkerLastRootCauseReason = next.reason;
+			return true;
+		}
+	}
+
+	m_voiWorkerLastCommands[unit->tag] = next;
+	return false;
+}
+
+void GameCommander::setVoiWorkerCommandReason(const Unit & worker, const std::string & reason)
+{
+	if (!worker.isValid() || reason.empty())
+	{
+		return;
+	}
+	m_voiWorkerCommandReasons[worker.getTag()] = reason;
+}
+
+std::string GameCommander::consumeVoiWorkerCommandReason(sc2::Tag workerTag, const std::string & fallback)
+{
+	auto it = m_voiWorkerCommandReasons.find(workerTag);
+	if (it == m_voiWorkerCommandReasons.end())
+	{
+		return fallback.empty() ? "unlabeled_worker_command" : "unlabeled_" + fallback;
+	}
+	const std::string reason = it->second.empty() ? fallback : it->second;
+	m_voiWorkerCommandReasons.erase(it);
+	return reason;
+}
