+
+bool voiDoctrineExpectsActualItem(const std::string & doctrine, const std::string & itemName)
+{
+	if (doctrine == "tank_defensive_hold" || doctrine == "siege_contain")
+	{
+		return itemName == "Factory" || itemName == "FactoryTechLab" || itemName == "SiegeTank" || itemName == "SupplyDepot";
+	}
+	if (doctrine == "mech_transition")
+	{
+		return itemName == "Factory" || itemName == "FactoryTechLab" || itemName == "Hellion" || itemName == "Cyclone" || itemName == "SiegeTank" || itemName == "Thor" || itemName == "SupplyDepot";
+	}
+	if (doctrine == "drop_harassment")
+	{
+		return itemName == "Factory" || itemName == "Starport" || itemName == "StarportReactor" || itemName == "Medivac" || itemName == "SupplyDepot";
+	}
+	if (doctrine == "bio_pressure")
+	{
+		return itemName == "Barracks" || itemName == "BarracksTechLab" || itemName == "Marauder" || itemName == "Starport" || itemName == "Medivac" || itemName == "SupplyDepot";
+	}
+	if (doctrine == "marine_rush")
+	{
+		return itemName == "Barracks" || itemName == "BarracksTechLab" || itemName == "Marine" || itemName == "Marauder" || itemName == "SupplyDepot";
+	}
+	if (doctrine == "expand_macro")
+	{
+		return itemName == "CommandCenter" || itemName == "SupplyDepot" || itemName == "Barracks";
+	}
+	if (doctrine == "worker_line_harassment")
+	{
+		return itemName == "Factory" || itemName == "Starport" || itemName == "Hellion" || itemName == "Reaper" || itemName == "Medivac";
+	}
+	if (doctrine == "anti_air_response")
+	{
+		return itemName == "Factory" || itemName == "Starport" || itemName == "EngineeringBay" || itemName == "Viking" || itemName == "Cyclone";
+	}
+	if (doctrine == "contain_enemy_natural")
+	{
+		return itemName == "Factory" || itemName == "SiegeTank" || itemName == "Marine" || itemName == "SupplyDepot";
+	}
+	return false;
+}
+
+bool voiDoctrineRequestsTechTransition(CCBot & bot, const MetaType & type)
+{
+	if (!bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const std::string doctrine = bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	return (type == MetaTypeEnum::Factory
+			&& (voiDoctrineIsOneOf(doctrine, "tank_defensive_hold", "siege_contain", "mech_transition", "drop_harassment")
+				|| voiDoctrineIsOneOf(doctrine, "worker_line_harassment", "anti_air_response", "contain_enemy_natural")))
+		|| (type == MetaTypeEnum::Starport
+			&& voiDoctrineIsOneOf(doctrine, "bio_pressure", "drop_harassment", "worker_line_harassment", "anti_air_response"))
+		|| (type == MetaTypeEnum::FactoryTechLab
+			&& voiDoctrineIsOneOf(doctrine, "tank_defensive_hold", "siege_contain", "mech_transition", "contain_enemy_natural"))
+		|| (type == MetaTypeEnum::StarportReactor
+			&& voiDoctrineIsOneOf(doctrine, "drop_harassment", "worker_line_harassment"));
+}
+
+bool voiWantsSiegeTank(CCBot & bot)
+{
+	if (!bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const std::string doctrine = bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	const float tankBias = voiMaxBias(bot, "production.queue_biases.TERRAN_SIEGETANK", "tech.unit_biases.TERRAN_SIEGETANK");
+	const float compositionSiegeBias = bot.Commander().getVoiPolicyFloat("production.composition_biases.siege", 0.0f);
+	const float compositionDefenseBias = bot.Commander().getVoiPolicyFloat("production.composition_biases.defense", 0.0f);
+	const float compositionMechBias = bot.Commander().getVoiPolicyFloat("production.composition_biases.mech", 0.0f);
+	return voiDoctrineIsOneOf(doctrine, "tank_defensive_hold", "siege_contain", "contain_enemy_natural")
+		|| tankBias > 0.25f
+		|| compositionSiegeBias > 0.25f
+		|| compositionDefenseBias > 0.55f
+		|| (doctrine == "mech_transition" && compositionMechBias > 0.45f);
+}
