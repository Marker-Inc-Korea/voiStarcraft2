+void CombatCommander::updateClearExpandSquads()
+{
+	m_blockedExpandByInvis = false;
+
+	// reset clear expand squads
+	for (const auto & kv : m_squadData.getSquads())
+	{
+		const Squad & squad = kv.second;
+		if (squad.getName().find("Clear Expand") != std::string::npos)
+		{
+			m_squadData.getSquad(squad.getName()).clear();
+		}
+	}
+
+	for(const auto baseLocation : m_bot.Bases().getBaseLocations())
+	{
+		if(baseLocation->isBlocked())
+		{
+			const auto basePosition = baseLocation->getDepotPosition();
+			std::stringstream squadName;
+			squadName << "Clear Expand " << basePosition.x << " " << basePosition.y;
+
+			const SquadOrder clearExpand(SquadOrderTypes::Clear, basePosition, DefaultOrderRadius, "Clear Blocked Expand");
+			// if we don't have a squad assigned to this blocked expand already, create one
+			if (!m_squadData.squadExists(squadName.str()))
+			{
+				m_squadData.addSquad(squadName.str(), Squad(squadName.str(), clearExpand, ClearExpandPriority, m_bot));
+			}
+
+			// Assign the order to the squad
+			Squad & clearExpandSquad = m_squadData.getSquad(squadName.str());
+			clearExpandSquad.setSquadOrder(clearExpand);
+
+			// Check creep, visibility and detection of the base location
+			bool allCornersVisible = true;
+			bool allCornersDetected = true;
+			bool creepCleared = !m_bot.Observation()->HasCreep(basePosition);
+			int CORNER_DIST = 4;
+			for (int x = -CORNER_DIST; x <= CORNER_DIST; x += CORNER_DIST*2)
+			{
+				for (int y = -CORNER_DIST; y <= CORNER_DIST; y += CORNER_DIST*2)
+				{
+					const auto corner = basePosition + CCPosition(x, y);
+					if (m_bot.Observation()->HasCreep(corner))
+						creepCleared = false;
+					if (!m_bot.Map().isVisible(corner))
+					{
+						allCornersVisible = false;
+						allCornersDetected = false;
+					}
+					else if (!m_bot.Map().isDetected(corner))
+						allCornersDetected = false;
+				}
+			}
+
+			// Check the units requirement
+			const auto & blockingUnits = baseLocation->getBlockingUnits();
+			bool groundUnits = blockingUnits.empty();	// If we see no unit that block the base, it's probably a burrowed unit
+			bool visibleGroundUnits = false;
+			bool airUnits = false;
+			bool invisUnits = blockingUnits.empty();	// If we see no unit that block the base, it's probably a burrowed unit
+			for (const auto & blockingUnit : blockingUnits)
+			{
+				if (blockingUnit.isFlying())
+					airUnits = true;
+				else
+				{
+					groundUnits = true;
+					visibleGroundUnits = true;
+				}
+				if (blockingUnit.getUnitPtr()->cloak == sc2::Unit::CloakState::Cloaked || blockingUnit.getUnitPtr()->cloak == sc2::Unit::CloakState::CloakedDetected || blockingUnit.getUnitPtr()->is_burrowed)
+					invisUnits = true;
+			}
+
+			// Check known burrowed units if necessary
+			if (!airUnits)
+			{
+				bool closeBurrowedUnit = false;
+				for (const auto burrowedUnit : m_bot.Analyzer().getBurrowedUnits())
+				{
+					const auto dist = Util::DistSq(burrowedUnit->pos, basePosition);
+					if (dist < 4 * 4)
+					{
+						closeBurrowedUnit = true;
+						break;
+					}
+				}
+				// Create a burrowed unit if there is none we know of, to allow the use of a scan
+				if (!visibleGroundUnits && !closeBurrowedUnit && !allCornersDetected && allCornersVisible)
+				{
+					const auto enemyPlayerRace = m_bot.GetPlayerRace(Players::Enemy);
+					if (enemyPlayerRace == sc2::Zerg)
+					{
+						invisUnits = true;
+						if (creepCleared)
+						{
+							m_bot.Analyzer().addBurrowedUnits(Util::CreateDummyBurrowedZergling(basePosition, m_bot));
+						}
+						else if (!creepCleared && !airUnits)
+						{
+							// TODO should be a Creep tumor, but it doesn't really matter
+							m_bot.Analyzer().addBurrowedUnits(Util::CreateDummyBurrowedZergling(basePosition, m_bot));
+						}
+					}
+				}
+			}
+
+			// If we have the vision (and detection if required) of the base location corners, we overwrite the units requirement
+			if (allCornersVisible && (!invisUnits || allCornersDetected))
+			{
+				groundUnits = false;
+				airUnits = false;
+				invisUnits = false;
+
+				for (const auto & enemyUnit : m_bot.GetKnownEnemyUnits())
+				{
+					const auto dist = Util::DistSq(enemyUnit, basePosition);
+					if (dist > 10 * 10)
+						continue;
+					if (enemyUnit.isFlying())
+						airUnits = true;
+					else
+						groundUnits = true;
+					if (enemyUnit.getUnitPtr()->cloak == sc2::Unit::CloakState::Cloaked || enemyUnit.getUnitPtr()->cloak == sc2::Unit::CloakState::CloakedDetected || enemyUnit.getUnitPtr()->is_burrowed)
+						invisUnits = true;
+				}
+
+				if (!groundUnits && !airUnits && !invisUnits)
+				{
+					// If there is creep and we see no units, there might be a Creep Tumor nearby
+					if (!creepCleared && !allCornersDetected)
+					{
+						groundUnits = true;
+						invisUnits = true;
+					}
+					else
+					{
+						clearExpandSquad.clear();
+						baseLocation->clearBlocked();
+						continue;
+					}
+				}
+			}
+
+			if (invisUnits)
+				m_blockedExpandByInvis = true;
+
+			// add closest unit in squad (one for each type of requirement)
+			Unit closestGroundAttackingUnit;
+			Unit closestAirAttackingUnit;
+			Unit closestDetectorUnit;
+			float groundDistance = 0.f;
+			float airDistance = 0.f;
+			float detectorDistance = 0.f;
+			for (auto & unitPair : m_bot.GetAllyUnits())
+			{
+				const auto & unit = unitPair.second;
+
+				if (!unit.isValid())
+					continue;
+				if (unit.getType().isBuilding())
+					continue;
+				if (unit.getType().isWorker())
+					continue;
+				if (!m_squadData.canAssignUnitToSquad(unit, clearExpandSquad))
+					continue;
+
+				// Check ground attacking needs
+				if(groundUnits && Util::CanUnitAttackGround(unit.getUnitPtr(), m_bot))
+				{
+					const float dist = Util::DistSq(unit, basePosition);
+					if(!closestGroundAttackingUnit.isValid() || dist < groundDistance)
+					{
+						groundDistance = dist;
+						closestGroundAttackingUnit = unit;
+					}
+				}
+
+				// Check air attacking needs
+				if (airUnits && Util::CanUnitAttackAir(unit.getUnitPtr(), m_bot))
+				{
+					const float dist = Util::DistSq(unit, basePosition);
+					if (!closestAirAttackingUnit.isValid() || dist < airDistance)
+					{
+						airDistance = dist;
+						closestAirAttackingUnit = unit;
+					}
+				}
+
+				// Check detection needs
+				if (invisUnits && unit.getType().isDetector())
+				{
+					const float dist = Util::DistSq(unit, basePosition);
+					if (!closestDetectorUnit.isValid() || dist < detectorDistance)
+					{
+						detectorDistance = dist;
+						closestDetectorUnit = unit;
+					}
+				}
+			}
+
+			// If we don't have every type of unit needed, don't go to not waste time of our units (ex: Reaper against burrowed Zergling)
+			bool noGroundAttackingUnits = groundUnits && !closestGroundAttackingUnit.isValid();
+			bool noAirAttackingUnits = airUnits && !closestAirAttackingUnit.isValid();
+			bool noDetector = invisUnits && !closestDetectorUnit.isValid() && !m_bot.Buildings().hasEnergyForScan();
+			if (noAirAttackingUnits)
+				m_bot.Strategy().setShouldProduceAntiAirOffense(true);	// We need air attacking units to kill the Overlord
+			if (noGroundAttackingUnits || noAirAttackingUnits || noDetector)
+				continue;
+
+			if (closestGroundAttackingUnit.isValid())
+				m_squadData.assignUnitToSquad(closestGroundAttackingUnit.getUnitPtr(), clearExpandSquad);
+
+			if (closestAirAttackingUnit.isValid() && closestAirAttackingUnit.getUnitPtr() != closestGroundAttackingUnit.getUnitPtr())
+				m_squadData.assignUnitToSquad(closestAirAttackingUnit.getUnitPtr(), clearExpandSquad);
+
+			if (closestDetectorUnit.isValid())
+				m_squadData.assignUnitToSquad(closestDetectorUnit.getUnitPtr(), clearExpandSquad);
+		}
+	}
+}
+
+void CombatCommander::updateScoutSquad()
+{
+	Squad & scoutSquad = m_squadData.getSquad("Scout");
+	const std::string tacticalTaskType = m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const bool tacticalScoutTask = tacticalTaskType == "scout_with_units" && voiTacticalTaskWithinDuration(m_bot);
+	const std::string scopeArmyGroup = m_bot.Commander().getVoiPolicyString("scope.army_group", "");
+	const std::string scopeUnitClasses = m_bot.Commander().getVoiPolicyString("scope.unit_classes", "");
+	const std::string tacticalTaskUnitClasses = m_bot.Commander().getVoiPolicyString("tactical_task.unit_classes", "");
+	const std::string effectiveScopeUnitClasses = tacticalScoutTask && !tacticalTaskUnitClasses.empty() ? tacticalTaskUnitClasses : scopeUnitClasses;
+	const std::string tacticalTaskLocationIntent = m_bot.Commander().getVoiPolicyString("tactical_task.location_intent", "");
+	const std::string scopeLocationIntent = m_bot.Commander().getVoiPolicyString("scope.location_intent", "");
+	const std::string effectiveLocationIntent = tacticalScoutTask && !tacticalTaskLocationIntent.empty() ? tacticalTaskLocationIntent : scopeLocationIntent;
+	const float scoutPriority = m_bot.Commander().getVoiPolicyFloat("scouting.scout_priority", 0.0f);
+	const float marineScoutBias = m_bot.Commander().getVoiPolicyFloat("squad.squad_role_biases.marine_scout", 0.0f);
+	const bool explicitScoutScope = m_bot.Commander().isVoiPolicyActive()
+		&& (scopeArmyGroup == "scout" || tacticalScoutTask || scoutPriority >= 0.65f || marineScoutBias > 0.25f);
+	const BaseLocation * enemyStartingBase = m_bot.Bases().getPlayerStartingBaseLocation(Players::Enemy);
+	const bool enemyStartNeedsCombatScout = enemyStartingBase != nullptr
+		&& !m_bot.Map().isExplored(enemyStartingBase->getPosition());
+	const bool autonomousCombatScoutScope = !explicitScoutScope
+		&& enemyStartNeedsCombatScout
+		&& voiCountMobileAttackUnits(m_combatUnits) >= 2;
+	const bool activeScoutScope = explicitScoutScope || autonomousCombatScoutScope;
+	const int requestedMinUnits = std::max(
+		std::max(0, m_bot.Commander().getVoiPolicyInt("scope.min_units", 0)),
+		tacticalScoutTask ? std::max(0, m_bot.Commander().getVoiPolicyInt("tactical_task.min_units", 0)) : 0);
+	const int requestedMaxUnits = std::max(
+		std::max(0, m_bot.Commander().getVoiPolicyInt("scope.max_units", 0)),
+		tacticalScoutTask ? std::max(0, m_bot.Commander().getVoiPolicyInt("tactical_task.max_units", 0)) : 0);
+	const bool allowPartialScoutTask = m_bot.Commander().getVoiPolicyBool("tactical_task.allow_partial", true);
+	int desiredScoutUnits = activeScoutScope
+		? std::max(1, requestedMinUnits > 0 ? requestedMinUnits : requestedMaxUnits)
+		: 1;
+	if (requestedMaxUnits > 0)
+	{
+		desiredScoutUnits = std::min(std::max(1, requestedMaxUnits), std::max(1, desiredScoutUnits));
+	}
+	desiredScoutUnits = std::min(desiredScoutUnits, 6);
+	m_lastVoiScoutScopeFrame = m_bot.GetGameLoop();
+	m_lastVoiScoutRequestedMinUnits = requestedMinUnits;
+	m_lastVoiScoutRequestedMaxUnits = requestedMaxUnits;
+	m_lastVoiScoutAssignedUnitCount = static_cast<int>(scoutSquad.getUnits().size());
+
+	// Scout for proxy against Protoss unless we ourselves do a proxy strategy or have already scouted the map once
+	bool scoutForProxy = m_bot.GetPlayerRace(Players::Enemy) == sc2::Race::Protoss && !m_bot.Strategy().isProxyStartingStrategy() && !m_scoutedMapOnce;
+	if (!activeScoutScope && !m_bot.Strategy().enemyHasMassZerglings() && m_bot.GetCurrentFrame() < 4704 && !scoutForProxy)	//around 3:30, or as soon as enemy has a lot of lings
+	{
+		scoutSquad.clear();
+		m_lastVoiScoutScopeStatus = "Waiting";
+		m_lastVoiScoutScopeReason = "Default scout gate before 3:30";
+		m_lastVoiScoutAssignedUnitCount = 0;
+		m_lastVoiScoutHomeDistance = 0.0f;
+		return;
+	}
+
+	if (m_combatUnits.size() == 1 && !scoutForProxy && !activeScoutScope)
+	{
+		scoutSquad.clear();	// Prevent our only combat unit to scout instead of fighting, unless we haven't scouted the map once against Protoss
+		m_lastVoiScoutScopeStatus = "Waiting";
+		m_lastVoiScoutScopeReason = "Only one combat unit available";
+		m_lastVoiScoutAssignedUnitCount = 0;
+		m_lastVoiScoutHomeDistance = 0.0f;
+	}
+	else if (scoutSquad.getUnits().size() < static_cast<size_t>(desiredScoutUnits))
+	{
+		std::vector<sc2::UNIT_TYPEID> scoutUnitTypes;
+		const bool wantsMarine = effectiveScopeUnitClasses.empty()
+			|| voiCommaListContains(effectiveScopeUnitClasses, "TERRAN_MARINE")
+			|| marineScoutBias > 0.25f;
+		const bool wantsReaper = effectiveScopeUnitClasses.empty() || voiCommaListContains(effectiveScopeUnitClasses, "TERRAN_REAPER");
+		if (activeScoutScope && wantsMarine)
+		{
+			scoutUnitTypes.push_back(sc2::UNIT_TYPEID::TERRAN_MARINE);
+		}
+		if (wantsReaper)
+		{
+			scoutUnitTypes.push_back(sc2::UNIT_TYPEID::TERRAN_REAPER);
+		}
+		if (!activeScoutScope || !wantsMarine)
+		{
+			scoutUnitTypes.push_back(sc2::UNIT_TYPEID::TERRAN_MARINE);
+		}
+		const auto base = m_bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+		if (base)
+		{
+			for (auto scoutUnitType : scoutUnitTypes)
+			{
+				while (scoutSquad.getUnits().size() < static_cast<size_t>(desiredScoutUnits))
+				{
+					Unit bestCandidate;
+					float distanceFromBase = 0.f;
+					for (auto & unit : m_combatUnits)
+					{
+						BOT_ASSERT(unit.isValid(), "null unit in combat units");
+						if (unit.getUnitPtr()->unit_type != scoutUnitType)
+							continue;
+
+						const float dist = Util::DistSq(unit, base->getPosition());
+						if (!bestCandidate.isValid() || dist < distanceFromBase)
+						{
+							if (m_squadData.canAssignUnitToSquad(unit, scoutSquad))
+							{
+								bestCandidate = unit;
+								distanceFromBase = dist;
+							}
+						}
+					}
+					if (!bestCandidate.isValid())
+					{
+						break;
+					}
+					m_squadData.assignUnitToSquad(bestCandidate, scoutSquad);
+				}
+				if (scoutSquad.getUnits().size() >= static_cast<size_t>(desiredScoutUnits))
+					break;
+			}
+		}
+	}
+
+	if (scoutSquad.getUnits().empty())
+	{
+		m_lastVoiScoutScopeStatus = activeScoutScope ? "Waiting" : "Default";
+		m_lastVoiScoutScopeReason = activeScoutScope ? "No eligible combat scout units" : "No scout units assigned";
+		m_lastVoiScoutAssignedUnitCount = 0;
+		m_lastVoiScoutHomeDistance = 0.0f;
+		return;
+	}
+	if (tacticalScoutTask && !allowPartialScoutTask && requestedMinUnits > 0 && static_cast<int>(scoutSquad.getUnits().size()) < requestedMinUnits)
+	{
+		scoutSquad.clear();
+		m_lastVoiScoutScopeStatus = "Waiting";
+		m_lastVoiScoutScopeReason = "Tactical task scout_with_units waiting for requested min_units";
+		m_lastVoiScoutAssignedUnitCount = 0;
+		m_lastVoiScoutHomeDistance = 0.0f;
+		return;
+	}
+
+	const CCPosition defaultScoutTarget = GetNextBaseLocationToScout();
+	const CCPosition scoutTarget = activeScoutScope
+		? voiResolveCombatLocationIntent(m_bot, effectiveLocationIntent.empty() ? "enemy_main" : effectiveLocationIntent, defaultScoutTarget)
+		: defaultScoutTarget;
+	const SquadOrder scoutOrder(SquadOrderTypes::Scout, scoutTarget, ScoutOrderRadius, "Scout");
+	scoutSquad.setSquadOrder(scoutOrder);
+	m_lastVoiScoutAssignedUnitCount = static_cast<int>(scoutSquad.getUnits().size());
+	m_lastVoiScoutScopeStatus = activeScoutScope ? "Consumed" : "Default";
+	m_lastVoiScoutScopeReason = tacticalScoutTask ? "Tactical task scout_with_units assigned to Scout squad" : (explicitScoutScope ? "Explicit VOI scout scope assigned to Scout squad" : (autonomousCombatScoutScope ? "Autonomous combat scout assigned because enemy start is unexplored" : "Default scout squad assigned"));
+	m_lastVoiScoutHomeDistance = voiSquadMaxHomeDistance(scoutSquad.getUnits(), m_bot);
+	m_maxVoiScoutHomeDistance = std::max(m_maxVoiScoutHomeDistance, m_lastVoiScoutHomeDistance);
+}
+
+void CombatCommander::updateHarassSquads()
+{
+	std::map<sc2::UNIT_TYPEID, std::vector<Unit>> harassUnits;
+	int i = 1;
+	while (m_squadData.squadExists("Harass" + std::to_string(i)))
+	{
+		Squad & squad = m_squadData.getSquad("Harass" + std::to_string(i));
+		const auto & squadUnits = squad.getUnits();
+		for (const auto & squadUnit : squadUnits)
+		{
+			if (squadUnit.getAPIUnitType() == sc2::UNIT_TYPEID::TERRAN_BANSHEE && !shouldBansheesHarass())
+				continue;
+			harassUnits[squadUnit.getAPIUnitType()].push_back(squadUnit);
+		}
+		squad.clear();
+		++i;
+	}
+	std::vector<const BaseLocation *> baseLocations;
+	const auto & occupiedBaseLocations = m_bot.Bases().getOccupiedBaseLocations(Players::Enemy);
+	baseLocations.insert(baseLocations.end(), occupiedBaseLocations.begin(), occupiedBaseLocations.end());
+	if (baseLocations.empty())
+	{
+		const BaseLocation* enemyStartingBase = m_bot.Bases().getPlayerStartingBaseLocation(Players::Enemy);
+		if (!enemyStartingBase)
+			return;
+		baseLocations.push_back(enemyStartingBase);
+	}
+	
+	i = 0;
+	for (auto baseLocation : baseLocations)
+	{
+		++i;
+		std::string squadName = "Harass" + std::to_string(i);
+		const SquadOrder harassOrder(SquadOrderTypes::Harass, baseLocation->getPosition(), HarassOrderRadius, squadName);
+		if (!m_squadData.squadExists(squadName))
+		{
+			Squad harassSquad(squadName, harassOrder, HarassPriority, m_bot);
+			m_squadData.addSquad(squadName, harassSquad);
+		}
+		else
+		{
+			Squad & squad = m_squadData.getSquad(squadName);
+			squad.setSquadOrder(harassOrder);
+		}
+	}
+	
+	Squad & idleSquad = m_squadData.getSquad("Idle");
+	for (auto & idleUnit : idleSquad.getUnits())
+	{
+		if ((idleUnit.getAPIUnitType() == sc2::UNIT_TYPEID::TERRAN_BANSHEE && shouldBansheesHarass()) || idleUnit.getAPIUnitType() == sc2::UNIT_TYPEID::TERRAN_REAPER)
+		{
+			harassUnits[idleUnit.getAPIUnitType()].push_back(idleUnit);
+		}
+	}
+
+	if (harassUnits.empty())
+		return;
+
+	for (auto & harassUnitType : harassUnits)
+	{
+		i = 0;
+		for (auto & harassUnit : harassUnitType.second)
+		{
+			++i;
+			std::string squadName = "Harass" + std::to_string(i);
+			if (!m_squadData.squadExists(squadName))
+			{
+				i = 1;
+				squadName = "Harass" + std::to_string(i);
+			}
+			auto & harassSquad = m_squadData.getSquad(squadName);
+			m_squadData.assignUnitToSquad(harassUnit, harassSquad);
+		}
+	}
+}
+
+void CombatCommander::updateAttackSquads()
+{
+    /*if (!m_attackStarted)
+    {
+        return;
+    }*/
+
+    Squad & mainAttackSquad = m_squadData.getSquad("MainAttack");
+
+	// Worker rush strategy is not used anymore
+	if (m_bot.Strategy().getStartingStrategy() == WORKER_RUSH)
+	{
+		for (auto & probe : m_bot.GetAllyUnits(sc2::UNIT_TYPEID::PROTOSS_PROBE))
+		{
+			if (m_squadData.canAssignUnitToSquad(probe, mainAttackSquad, false))
+			{
+				m_bot.Workers().getWorkerData().setWorkerJob(probe, WorkerJobs::Combat);
+				m_squadData.assignUnitToSquad(probe, mainAttackSquad);
+			}
+		}
+		
+		const SquadOrder mainAttackOrder(SquadOrderTypes::Attack, getMainAttackLocation(), MainAttackOrderRadius, "Attack");
+		mainAttackSquad.setSquadOrder(mainAttackOrder);
+		return;
+	}
+
+	const auto squadCenter = mainAttackSquad.calcCenter();
+	std::vector<Unit> unitsToTransfer;
+	Squad & backupSquad = m_squadData.getSquad("Backup");
+
+	// Check to see if we want to move units from the main attack squad to the backup squad
+	for (auto & unit : mainAttackSquad.getUnits())
+	{
+		const auto dist = Util::DistSq(unit, squadCenter);
+		const auto radius = mainAttackSquad.getSquadOrder().getRadius();
+		if (dist > radius * radius && ShouldUnitHeal(unit.getUnitPtr()))
+			unitsToTransfer.push_back(unit);
+	}
+
+	for (const auto & unit : unitsToTransfer)
+	{
+		m_squadData.assignUnitToSquad(unit, backupSquad);
+	}
+	unitsToTransfer.clear();
+	
+	// Check to see if we want to move units from the backup squad to the main attack squad
+	for (auto & backupUnit : backupSquad.getUnits())
+	{
+		bool closeEnough = mainAttackSquad.getUnits().empty();
+		if (!closeEnough)
+		{
+			auto dist = Util::DistSq(backupUnit, squadCenter);
+			const auto radius = mainAttackSquad.getSquadOrder().getRadius();
+			if (dist <= radius * radius)
+				closeEnough = true;
+			else
+			{
+				for (auto & unit : mainAttackSquad.getUnits())
+				{
+					dist = Util::DistSq(unit, backupUnit);
+					if (dist <= 10.f * 10.f)
+					{
+						closeEnough = true;
+						break;
+					}
+				}
+			}
+		}
+		if (closeEnough && m_squadData.canAssignUnitToSquad(backupUnit, mainAttackSquad))
+			unitsToTransfer.push_back(backupUnit);
+	}
+	
+	for (const auto & unit : unitsToTransfer)
+		m_squadData.assignUnitToSquad(unit, mainAttackSquad);
+
+	const std::string exactCompositionTaskType = m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const bool exactCompositionPressureTask = exactCompositionTaskType == "pressure_with_main_army"
+		&& voiTacticalTaskWithinDuration(m_bot)
+		&& m_bot.Commander().hasVoiPolicyDomain("composition_requirements");
+	bool exactCompositionBlocksAttack = false;
+	if (exactCompositionPressureTask)
+	{
+		const bool allowPartialComposition = m_bot.Commander().getVoiPolicyBool("tactical_task.allow_partial", true);
+		std::vector<std::pair<std::string, int>> requirements;
+		for (int i = 0; i < 8; ++i)
+		{
+			const std::string unitType = m_bot.Commander().getVoiPolicyString("composition_requirements." + std::to_string(i) + ".unit_type", "");
+			const int count = std::max(0, m_bot.Commander().getVoiPolicyInt("composition_requirements." + std::to_string(i) + ".count", 0));
+			if (!unitType.empty() && count > 0)
+			{
+				requirements.push_back(std::make_pair(unitType, count));
+			}
+		}
+		std::vector<Unit> overflowUnits;
+		for (const auto & unit : mainAttackSquad.getUnits())
+		{
+			bool represented = false;
+			for (const auto & requirement : requirements)
+			{
+				if (voiUnitMatchesCompositionToken(unit, requirement.first))
+				{
+					represented = true;
+					break;
+				}
+			}
+			if (!represented)
+			{
+				overflowUnits.push_back(unit);
+			}
+		}
+		for (const auto & requirement : requirements)
+		{
+			int keptForType = 0;
+			for (const auto & unit : mainAttackSquad.getUnits())
+			{
+				if (!voiUnitMatchesCompositionToken(unit, requirement.first))
+				{
+					continue;
+				}
+				if (keptForType < requirement.second)
+				{
+					keptForType++;
+				}
+				else
+				{
+					overflowUnits.push_back(unit);
+				}
+			}
+		}
+		for (const auto & unit : overflowUnits)
+		{
+			m_squadData.assignUnitToSquad(unit, backupSquad);
+		}
+		std::stringstream missing;
+		int totalRequired = 0;
+		int totalAssigned = 0;
+		for (const auto & requirement : requirements)
+		{
+			totalRequired += requirement.second;
+			int assignedForType = 0;
+			for (const auto & unit : mainAttackSquad.getUnits())
+			{
+				if (voiUnitMatchesCompositionToken(unit, requirement.first))
+				{
+					assignedForType++;
+				}
+			}
+			for (const std::string poolName : {"Idle", "Backup", "Scout"})
+			{
+				if (assignedForType >= requirement.second || !m_squadData.squadExists(poolName))
+				{
+					continue;
+				}
+				Squad & pool = m_squadData.getSquad(poolName);
+				std::vector<Unit> candidates;
+				for (const auto & unit : pool.getUnits())
+				{
+					if (voiUnitMatchesCompositionToken(unit, requirement.first) && m_squadData.canAssignUnitToSquad(unit, mainAttackSquad))
+					{
+						candidates.push_back(unit);
+					}
+				}
+				for (const auto & unit : candidates)
+				{
+					if (assignedForType >= requirement.second)
+					{
+						break;
+					}
+					m_squadData.assignUnitToSquad(unit, mainAttackSquad);
+					assignedForType++;
+				}
+			}
+			totalAssigned += std::min(assignedForType, requirement.second);
+			if (assignedForType < requirement.second)
+			{
+				if (missing.tellp() > 0)
+				{
+					missing << ",";
+				}
+				missing << requirement.first << ":" << assignedForType << "/" << requirement.second;
+			}
+		}
+		m_lastVoiCompositionStatus = totalAssigned >= totalRequired ? "Satisfied" : (allowPartialComposition && totalAssigned > 0 ? "Partial" : "Waiting");
+		m_lastVoiCompositionReason = missing.tellp() > 0 ? "Missing composition units " + missing.str() : "Requested composition assigned to MainAttack";
+		m_lastVoiCompositionRequired = totalRequired;
+		m_lastVoiCompositionAssigned = totalAssigned;
+		m_lastVoiCompositionMissing = missing.str();
+		m_lastVoiCompositionFrame = m_bot.GetGameLoop();
+		m_lastVoiCompositionRequirements = "";
+		for (int i = 0; i < 8; ++i)
+		{
+			const std::string label = voiCompositionRequirementLabel(m_bot, i);
+			if (!label.empty())
+			{
+				if (!m_lastVoiCompositionRequirements.empty())
+				{
+					m_lastVoiCompositionRequirements += ",";
+				}
+				m_lastVoiCompositionRequirements += label;
+			}
+		}
+		if (!allowPartialComposition && totalAssigned < totalRequired)
+		{
+			exactCompositionBlocksAttack = true;
+			mainAttackSquad.clear();
+		}
+	}
+
+	if (mainAttackSquad.getUnits().empty() && m_attackStarted && !exactCompositionBlocksAttack)
+	{
+		Squad & idleSquad = m_squadData.getSquad("Idle");
+		for (const auto & idleUnit : idleSquad.getUnits())
+		{
+			if (voiIsMobileAttackUnit(idleUnit) && m_squadData.canAssignUnitToSquad(idleUnit, mainAttackSquad))
+			{
+				unitsToTransfer.push_back(idleUnit);
+			}
+		}
+		for (const auto & unit : unitsToTransfer)
+		{
+			m_squadData.assignUnitToSquad(unit, mainAttackSquad);
+		}
+		unitsToTransfer.clear();
+	}
+
+	if (mainAttackSquad.getUnits().empty())
+	{
+		m_lastVoiMainAttackOrderStatus = "Waiting";
+		m_lastVoiMainAttackOrderReason = exactCompositionBlocksAttack ? m_lastVoiCompositionReason : "No main attack units";
+		m_lastVoiMainAttackUnitCount = 0;
+		m_lastVoiMainAttackScopeMinUnits = std::max(0, m_bot.Commander().getVoiPolicyInt("scope.min_units", 0));
+		m_lastVoiMainAttackScopeThresholdMet = m_lastVoiMainAttackScopeMinUnits == 0;
+		m_lastVoiMainAttackSimulationWon = false;
+		m_lastVoiMainAttackOrderPosition = mainAttackSquad.getSquadOrder().getPosition();
+		m_lastVoiMainAttackHomeDistance = 0.0f;
+		return;
+	}
+
+	CCPosition orderPosition = GetClosestEnemyBaseLocation();
+	bool retreat = false;
+	std::string retreatReason;
+	bool proxyStrategy = m_bot.Strategy().isProxyStartingStrategy();
+	const std::string tacticalTaskType = m_bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const bool tacticalPressureTask = tacticalTaskType == "pressure_with_main_army" && voiTacticalTaskWithinDuration(m_bot);
+	const float tacticalTaskPriority = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("tactical_task.priority", 0.0f));
+	const float tacticalTaskSafetyMargin = tacticalPressureTask ? std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("tactical_task.safety_margin", 0.0f)) : 0.0f;
+	const bool voiForceRetreat = m_bot.Commander().getVoiPolicyBool("emergency.force_retreat", false)
+		|| m_bot.Commander().getVoiPolicyBool("emergency.cancel_attacks", false);
+	const float voiDefendBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("combat.defend_bias", 0.0f));
+	const float voiAggression = m_bot.Commander().getVoiPolicyFloat("combat.aggression", 0.0f) + (tacticalPressureTask ? tacticalTaskPriority * 0.25f : 0.0f);
+	const float voiAttackTimingBias = m_bot.Commander().getVoiPolicyFloat("combat.attack_timing_bias", 0.0f) + (tacticalPressureTask ? tacticalTaskPriority * 0.25f : 0.0f);
+	const float voiCommitmentLevel = m_bot.Commander().getVoiPolicyFloat("combat.commitment_level", 0.0f) + (tacticalPressureTask ? tacticalTaskPriority * 0.15f : 0.0f);
+	const float voiRallyBeforeAttackBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("combat.rally_before_attack_bias", 0.0f));
+	const float voiRetreatPatienceBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("combat.retreat_patience_bias", 0.0f));
+	const float voiContainBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("squad.contain_bias", 0.0f));
+	const float voiFlankBias = std::max(
+		std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("squad.flank_bias", 0.0f)),
+		std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("combat.flank_bias", 0.0f)));
+	const float voiSquadDefenseBias = std::max(0.0f, m_bot.Commander().getVoiPolicyFloat("squad.defense_bias", 0.0f));
+	const float voiMainArmyBias = m_bot.Commander().getVoiPolicyFloat("squad.main_army_bias", 0.0f);
+	const std::string configuredAttackOverride = m_bot.Commander().getVoiPolicyString("combat.attack_condition_override", "normal");
+	const std::string voiAttackOverride = tacticalPressureTask && configuredAttackOverride == "normal" ? "earlier_if_safe" : configuredAttackOverride;
+	const std::string tacticalTaskLocationIntent = m_bot.Commander().getVoiPolicyString("tactical_task.location_intent", "");
+	const std::string voiLocationIntent = tacticalPressureTask && !tacticalTaskLocationIntent.empty()
+		? tacticalTaskLocationIntent
+		: m_bot.Commander().getVoiPolicyString("scope.location_intent", "");
+	const std::string voiTargetIntent = m_bot.Commander().getVoiPolicyString("target_intent.target_type", "");
+	const std::string voiEffectiveLocationIntent = !voiLocationIntent.empty()
+		? voiLocationIntent
+		: (voiTargetIntent == "enemy_main" || voiTargetIntent == "enemy_natural" ? voiTargetIntent : "");
+	const std::string voiRouteIntent = m_bot.Commander().getVoiPolicyString("route_intent.route_type", "");
+	const int voiScopeMinUnits = std::max(
+		std::max(0, m_bot.Commander().getVoiPolicyInt("scope.min_units", 0)),
+		tacticalPressureTask ? std::max(0, m_bot.Commander().getVoiPolicyInt("tactical_task.min_units", 0)) : 0);
+	const int voiScopeMaxUnits = std::max(
+		std::max(0, m_bot.Commander().getVoiPolicyInt("scope.max_units", 0)),
+		tacticalPressureTask ? std::max(0, m_bot.Commander().getVoiPolicyInt("tactical_task.max_units", 0)) : 0);
+	if (tacticalPressureTask && !exactCompositionPressureTask && voiScopeMaxUnits > 0 && mainAttackSquad.getUnits().size() > static_cast<size_t>(voiScopeMaxUnits))
+	{
+		int keptUnits = 0;
+		for (auto & unit : mainAttackSquad.getUnits())
+		{
+			if (keptUnits < voiScopeMaxUnits && voiIsMobileAttackUnit(unit))
+			{
+				keptUnits++;
+				continue;
+			}
+			unitsToTransfer.push_back(unit);
+		}
+		for (const auto & unit : unitsToTransfer)
+		{
+			m_squadData.assignUnitToSquad(unit, backupSquad);
+		}
+		unitsToTransfer.clear();
+	}
+	const bool voiPartialCompositionReady = exactCompositionPressureTask
+		&& m_bot.Commander().getVoiPolicyBool("tactical_task.allow_partial", true)
+		&& m_lastVoiCompositionAssigned > 0;
+	const bool voiScopeThresholdMet = voiScopeMinUnits == 0
+		|| static_cast<int>(mainAttackSquad.getUnits().size()) >= voiScopeMinUnits
+		|| voiPartialCompositionReady;
+	const int autonomousAttackUnitCount = voiCountMobileAttackUnits(mainAttackSquad.getUnits());
+	const int autonomousAttackMinUnits = std::max(1, m_bot.Commander().getVoiPolicyInt("combat.autonomous_attack_min_units", 4));
+	const bool voiDefensivePolicyBlocksAutonomy =
+		(m_bot.Commander().hasVoiPolicyDomain("combat") && (voiAggression < 0.0f || voiDefendBias > std::max(0.45f, std::max(0.0f, voiAggression) + 0.25f)))
+		|| (m_bot.Commander().hasVoiPolicyDomain("squad") && voiSquadDefenseBias > 0.60f && voiMainArmyBias <= 0.0f)
+		|| m_bot.Commander().getVoiPolicyBool("emergency.hold_position", false);
+	const bool autonomousAttackReady = autonomousAttackUnitCount >= autonomousAttackMinUnits
+		&& !voiForceRetreat
+		&& voiAttackOverride != "never"
+		&& !voiDefensivePolicyBlocksAutonomy;
+	const bool voiForceAttackWhenReady =
+		voiScopeThresholdMet
+		&& voiAttackOverride == "force_when_threshold_met"
+		&& voiAggression + voiAttackTimingBias + voiCommitmentLevel >= 1.0f;
+	const float voiEngageMarginDelta = std::max(
+		-0.35f,
+		std::min(
+			0.55f,
+			voiDefendBias * 0.35f
+				- voiAggression * 0.25f
+				- std::max(0.0f, voiCommitmentLevel) * 0.15f
+				- voiRetreatPatienceBias * 0.20f
+				+ tacticalTaskSafetyMargin * 0.35f));
+	if (voiContainBias > 0.0f || !voiEffectiveLocationIntent.empty())
+	{
+		const CCPosition resolvedTarget = voiResolveCombatLocationIntent(m_bot, voiEffectiveLocationIntent.empty() ? "enemy_natural" : voiEffectiveLocationIntent, orderPosition);
+		if (voiEffectiveLocationIntent == "enemy_main" || voiEffectiveLocationIntent == "enemy_start" || voiEffectiveLocationIntent == "enemy_start_location")
+		{
+			orderPosition = resolvedTarget;
+		}
+		else
+		{
+		if (voiIsRemoteCombatTarget(m_bot, resolvedTarget))
+		{
+			const CCPosition enemyBasePressure = GetClosestEnemyBaseLocation();
+			const float containWeight = std::max(0.0f, std::min(1.0f, voiContainBias));
+			orderPosition = resolvedTarget * (0.65f + 0.35f * containWeight) + enemyBasePressure * (0.35f - 0.35f * containWeight);
+		}
+		else
+		{
+			orderPosition = resolvedTarget;
+		}
+		}
+	}
+
+	if ((voiFlankBias > 0.0f || voiRouteIntent == "flank_left" || voiRouteIntent == "flank_right" || voiRouteIntent == "safe_path")
+		&& voiIsRemoteCombatTarget(m_bot, orderPosition)
+		&& voiSquadMaxHomeDistance(mainAttackSquad.getUnits(), m_bot) < 70.0f)
+	{
+		const float routeBias = (voiRouteIntent == "flank_left" || voiRouteIntent == "flank_right" || voiRouteIntent == "safe_path") ? 0.65f : 0.0f;
+		const float flankStageWeight = std::min(0.45f, std::max(routeBias, std::max(0.0f, voiFlankBias)) * 0.45f);
+		orderPosition = orderPosition * (1.0f - flankStageWeight) + m_bot.Map().center() * flankStageWeight;
+	}
+
+	if (voiForceRetreat)
+	{
+		retreat = true;
+		retreatReason = "VOI force retreat";
+	}
+	if (!retreat && voiAttackOverride == "never")
+	{
+		retreat = true;
+		retreatReason = "VOI attack condition override never";
+	}
+	if (!retreat && voiAttackOverride == "force_when_threshold_met" && !voiScopeThresholdMet)
+	{
+		retreat = true;
+		retreatReason = "Waiting for scope min units";
+	}
+
+	// Do not attack before 5 minutes unless we have a proxy strategy or the enemy has more bases than us
+	const float voiAttackDelayMinutes = std::max(
+		2.0f,
+		5.0f
+			+ voiDefendBias
+			+ voiRallyBeforeAttackBias
+			- std::max(0.0f, voiAggression) * 0.75f
+			- std::max(0.0f, voiAttackTimingBias) * 2.0f
+			- std::max(0.0f, voiCommitmentLevel) * 1.5f);
+	if (!retreat && !voiForceAttackWhenReady && !autonomousAttackReady && !proxyStrategy && m_bot.GetCurrentFrame() < 22.4f * 60 * voiAttackDelayMinutes)
+	{
+		int allyBases = m_bot.Bases().getBaseCount(Players::Self);
+		int enemyBases = m_bot.Bases().getBaseCount(Players::Enemy);
+		const bool voiMayAttackEarly =
+			voiScopeThresholdMet
+			&& (voiAttackOverride == "force_when_threshold_met"
+				|| (voiAttackOverride == "earlier_if_safe" && voiAggression + voiAttackTimingBias + voiCommitmentLevel > 0.6f));
+		if (allyBases >= enemyBases && !voiMayAttackEarly)
+		{
+			retreat = true;
+			retreatReason = "Don't attack yet";
+		}
+	}
+	// A retreat must last at least 5 seconds. VOI may lower timing thresholds,
+	// but it must not bypass the combat simulation safety gate.
+	if (!retreat && m_bot.GetCurrentFrame() >= m_lastRetreatFrame + 5 * 22.4)
+	{
+		bool earlyCycloneRush = false;
+		if (m_bot.Strategy().getStartingStrategy() == PROXY_CYCLONES)
+		{
+			for (const auto & unit : m_combatUnits)
+			{
+				if (unit.getAPIUnitType() == sc2::UNIT_TYPEID::TERRAN_BARRACKSFLYING)
+				{
+					earlyCycloneRush = true;
+					break;
+				}
+			}
+		}
+
+		// We don't want to stop the offensive with the proxy Cyclones strategy when we still have our flying Barracks
+		if (!earlyCycloneRush)
+		{
+			sc2::Units allyUnits;
+			if (proxyStrategy)
+			{
+				for (auto & mainAttackSquadUnit : mainAttackSquad.getUnits())
+				{
+					if (Util::DistSq(mainAttackSquadUnit, m_bot.Map().center()) < Util::DistSq(mainAttackSquadUnit, m_bot.GetStartLocation()))
+					{
+						allyUnits.push_back(mainAttackSquadUnit.getUnitPtr());
+					}
+				}
+			}
+			else
+			{
+				Util::CCUnitsToSc2Units(mainAttackSquad.getUnits(), allyUnits);
+			}
+			bool hasGround = false;
+			bool hasAir = false;
+			for (const auto ally : allyUnits)
+			{
+				if (hasGround && hasAir)
+					break;
+				hasGround = hasGround || !ally->is_flying;
+				hasAir = hasAir || ally->is_flying;
+			}
+			m_bot.StartProfiling("0.10.4.2.3.0     calcEnemies");
+			sc2::Units enemyUnits;
+			for (const auto & enemyUnitPair : m_bot.GetEnemyUnits())
+			{
+				const auto & enemyUnit = enemyUnitPair.second;
+				// We want to consider only combat enemy units but not buildings unless we have a proxy strategy
+				if (enemyUnit.getType().isCombatUnit() && (!enemyUnit.getType().isBuilding() || m_bot.Strategy().isProxyStartingStrategy()))
+				{
+					// Ignore temporary units
+					if (enemyUnit.getType().isSpawnedUnit())
+						continue;
+					// Ignore units that can't be targetted
+					if (!UnitType::isTargetable(enemyUnit.getAPIUnitType()))
+						continue;
+					if (enemyUnit.getType().isBuilding())
+					{
+						// Ignore buildings in construction
+						if (!enemyUnit.isCompleted())
+							continue;
+						// Ignore unpowered protoss buildings
+						if ((enemyUnit.getAPIUnitType() == sc2::UNIT_TYPEID::PROTOSS_SHIELDBATTERY || enemyUnit.getAPIUnitType() == sc2::UNIT_TYPEID::PROTOSS_PHOTONCANNON)
+							&& !enemyUnit.isPowered())
+							continue;
+						// Ignore proxy buildings
+						if (m_bot.GetEnemyStartLocations().size() > 0 && Util::DistSq(enemyUnit, m_bot.GetStartLocation()) < Util::DistSq(enemyUnit, m_bot.GetEnemyStartLocations()[0]))
+							continue;
+					}
+					// Ignore proxy enemies when we are doing a proxy strategy (to allow base trade)
+					if (proxyStrategy && Util::DistSq(enemyUnit, m_bot.GetStartLocation()) < Util::DistSq(enemyUnit, m_bot.Map().center()))
+						continue;
+					const bool canAttack = enemyUnit.getAPIUnitType() == sc2::UNIT_TYPEID::PROTOSS_SHIELDBATTERY
+						|| (hasGround && Util::CanUnitAttackGround(enemyUnit.getUnitPtr(), m_bot))
+						|| (hasAir && Util::CanUnitAttackAir(enemyUnit.getUnitPtr(), m_bot));
+					if (canAttack)
+						enemyUnits.push_back(enemyUnit.getUnitPtr());
+				}
+			}
+			m_bot.StopProfiling("0.10.4.2.3.0     calcEnemies");
+			m_bot.StartProfiling("0.10.4.2.3.1     simulateCombat");
+			bool considerOurSiegeTanksUnsieged = !m_winAttackSimulation;
+			bool stopSimulationWhenGroupHasNoTarget = false;
+			const auto simulationResult = Util::SimulateCombat(allyUnits, enemyUnits, considerOurSiegeTanksUnsieged, stopSimulationWhenGroupHasNoTarget, m_bot);
+			float armyRemainingDifference = simulationResult.supplyPercentageRemaining - simulationResult.enemySupplyPercentageRemaining;
+			m_bot.StopProfiling("0.10.4.2.3.1     simulateCombat");
+			if (m_winAttackSimulation)
+			{
+				m_winAttackSimulation = armyRemainingDifference > voiEngageMarginDelta || m_bot.GetCurrentSupply() >= 195;
+				if (!m_winAttackSimulation)
+				{
+					auto allySupply = Util::GetSupplyOfUnits(allyUnits, m_bot);
+					auto enemySupply = Util::GetSupplyOfUnits(enemyUnits, m_bot);
+					std::stringstream ss;
+					ss << std::fixed << std::setprecision(2);	// floats will show only 2 decimals
+					ss << "Cancel offensive (" << armyRemainingDifference * 100 << "%, " << allySupply << " ally supply vs " << enemySupply << " enemy supply)";
+					m_bot.Actions()->SendChat(ss.str(), sc2::ChatChannel::Team);
+					Util::Log(__FUNCTION__, ss.str(), m_bot);
+					m_lastRetreatFrame = m_bot.GetCurrentFrame();
+				}
+			}
+			else
+			{
+				const float voiRelaunchMargin = (voiForceAttackWhenReady ? 0.15f : 0.7f) + voiEngageMarginDelta;
+				m_winAttackSimulation = armyRemainingDifference > voiRelaunchMargin || m_bot.GetCurrentSupply() >= 195;
+				if (m_winAttackSimulation)
+				{
+					auto allySupply = Util::GetSupplyOfUnits(allyUnits, m_bot);
+					auto enemySupply = Util::GetSupplyOfUnits(enemyUnits, m_bot);
+					std::stringstream ss;
+					ss << std::fixed << std::setprecision(2);	// floats will show only 2 decimals
+					ss << "Relaunch offensive (" << armyRemainingDifference * 100 << "%, " << allySupply << " ally supply vs " << enemySupply << " enemy supply)";
+					m_bot.Actions()->SendChat(ss.str(), sc2::ChatChannel::Team);
+					Util::Log(__FUNCTION__, ss.str(), m_bot);
+				}
+			}
+			if (!m_winAttackSimulation)
+			{
+				retreat = true;
+				retreatReason = "Lose attack simulation";
+			}
+		}
+	}
+	else
+	{
+		retreat = true;
+		retreatReason = "Keep retreating";
+	}
+
+	std::string orderStatus = "Attack";
+	std::string orderReason = autonomousAttackReady ? "Autonomous combat threshold met" : (voiForceAttackWhenReady ? "VOI force threshold met" : "Attack conditions met");
+	if (retreat)
+	{
+		orderPosition = proxyStrategy ? Util::GetPosition(m_bot.Buildings().getProxyLocation()) : m_idlePosition;
+		orderStatus = "Retreat";
+		orderReason = retreatReason;
+		backupSquad.getSquadOrder().setType(SquadOrderTypes::Retreat);
+		backupSquad.getSquadOrder().setStatus(orderStatus);
+	}
+
+	if (mainAttackSquad.getSquadOrder().getPosition() != orderPosition
+		|| m_lastVoiMainAttackOrderStatus != orderStatus
+		|| m_lastVoiMainAttackOrderReason != orderReason)
+	{
+		std::stringstream ss;
+		ss << "MainAttackSquad new order = " << orderStatus << " (" << orderPosition.x << ", " << orderPosition.y << ") " << orderReason;
+		Util::Log(__FUNCTION__, ss.str(), m_bot);
+	}
+	m_lastVoiMainAttackOrderStatus = orderStatus;
+	m_lastVoiMainAttackOrderReason = orderReason;
+	m_lastVoiMainAttackUnitCount = static_cast<int>(mainAttackSquad.getUnits().size());
+	m_lastVoiMainAttackScopeMinUnits = voiScopeMinUnits;
+	m_lastVoiMainAttackScopeThresholdMet = voiScopeThresholdMet;
+	m_lastVoiMainAttackSimulationWon = m_winAttackSimulation;
+	m_lastVoiMainAttackOrderPosition = orderPosition;
+	m_lastVoiMainAttackHomeDistance = voiSquadMaxHomeDistance(mainAttackSquad.getUnits(), m_bot);
+	m_maxVoiMainAttackHomeDistance = std::max(m_maxVoiMainAttackHomeDistance, m_lastVoiMainAttackHomeDistance);
+	const float voiAttackRadius = std::max(18.0f, MainAttackOrderRadius - voiContainBias * 12.0f);
+	const SquadOrder mainAttackOrder(SquadOrderTypes::Attack, orderPosition, voiAttackRadius, orderStatus);
+	mainAttackSquad.setSquadOrder(mainAttackOrder);
+
+    /*if (mainAttackSquad.needsToRetreat())
+    {
+        SquadOrder retreatOrder(SquadOrderTypes::Retreat, getMainAttackLocation(), DefaultOrderRadius, "Retreat!!");
+        mainAttackSquad.setSquadOrder(retreatOrder);
+    }
+    //regroup only after retreat
+    else if (mainAttackSquad.needsToRegroup())
+    {
+        SquadOrder regroupOrder(SquadOrderTypes::Regroup, getMainAttackLocation(), DefaultOrderRadius, "Regroup");
+        mainAttackSquad.setSquadOrder(regroupOrder);
+    }
+    else
+    {
+        SquadOrder mainAttackOrder(SquadOrderTypes::Attack, getMainAttackLocation(), MainAttackOrderRadius, "Attack");
+        mainAttackSquad.setSquadOrder(mainAttackOrder);
+    }*/
+}
