+        << "\"combat_aggression\":" << m_voiPolicyBlackboard.getFloat("combat.aggression", 0.0f) << ","
+        << "\"emergency_force_retreat\":" << (m_voiPolicyBlackboard.getBool("emergency.force_retreat", false) ? "true" : "false") << ","
+        << "\"emergency_cancel_attacks\":" << (m_voiPolicyBlackboard.getBool("emergency.cancel_attacks", false) ? "true" : "false") << ","
+        << "\"scouting_scout_priority\":" << m_voiPolicyBlackboard.getFloat("scouting.scout_priority", 0.0f) << ","
+        << "\"scouting_risk_tolerance\":" << m_voiPolicyBlackboard.getFloat("scouting.risk_tolerance", 0.0f) << ","
+        << "\"scouting_require_fresh_enemy_observation\":" << (m_voiPolicyBlackboard.getBool("scouting.require_fresh_enemy_observation", false) ? "true" : "false")
+        << "},"
+        << "\"CombatCommander\":{"
+        << "\"active\":true,"
+        << "\"combat_unit_count\":" << m_combatUnits.size() << ","
+        << "\"defend_bias\":" << m_voiPolicyBlackboard.getFloat("combat.defend_bias", 0.0f) << ","
+        << "\"aggression\":" << m_voiPolicyBlackboard.getFloat("combat.aggression", 0.0f) << ","
+        << "\"force_retreat\":" << (m_voiPolicyBlackboard.getBool("emergency.force_retreat", false) ? "true" : "false") << ","
+        << "\"bounded_intervention\":" << (m_voiPolicyActive && (m_voiPolicyBlackboard.getFloat("combat.defend_bias", 0.0f) != 0.0f || m_voiPolicyBlackboard.getFloat("combat.aggression", 0.0f) != 0.0f || m_voiPolicyBlackboard.getBool("emergency.force_retreat", false)) ? "true" : "false")
