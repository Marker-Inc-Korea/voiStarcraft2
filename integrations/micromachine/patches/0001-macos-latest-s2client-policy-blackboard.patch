+bool ProductionManager::isPlacementRetryCoolingDown(const MetaType & type) const
+{
+	if (!type.isUnit())
+	{
+		return false;
+	}
+
+	const auto unitType = type.getUnitType().getAPIUnitType();
+	const auto retryIt = m_nextPlacementRetryFrame.find(unitType);
+	return retryIt != m_nextPlacementRetryFrame.end() && m_bot.GetCurrentFrame() < retryIt->second;
+}
+
+void ProductionManager::deferPlacementRetry(const MetaType & type, const std::string & reason)
+{
+	if (!type.isUnit() || !type.getUnitType().isBuilding())
+	{
+		return;
+	}
+
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	const auto unitType = type.getUnitType().getAPIUnitType();
+	const int retryCount = ++m_placementRetryCount[unitType];
+	const bool isVoiTransitionBuilding = voiDoctrineRequestsTechTransition(m_bot, type);
+	const bool isVoiExpandCommandCenter = type == MetaTypeEnum::CommandCenter && isVoiExpandMacroActive();
+	uint32_t retryDelayFrames = 22 * 15;
+	if (isVoiExpandCommandCenter)
+	{
+		// Expansion placement can fail transiently while base/path safety data catches up.
+		// Do not push VOI macro intent into a multi-minute generic building cooldown.
+		retryDelayFrames = retryCount <= 2 ? 22 * 5 : 22 * 10;
+	}
+	else if (isVoiTransitionBuilding)
+	{
+		retryDelayFrames = 22 * 15;
+	}
+	else if (retryCount == 2)
+	{
+		retryDelayFrames = 22 * 240;
+	}
+	else if (retryCount >= 3)
+	{
+		retryDelayFrames = 22 * 240;
+	}
+	m_nextPlacementRetryFrame[unitType] = currentFrame + retryDelayFrames;
+	Util::Log(__FUNCTION__, "Deferring placement retry for " + type.getName() + " until frame " + std::to_string(m_nextPlacementRetryFrame[unitType]) + " after " + reason + " count=" + std::to_string(retryCount) + " voi_expand_macro_short_retry=" + std::to_string(isVoiExpandCommandCenter) + ".", m_bot);
+}
