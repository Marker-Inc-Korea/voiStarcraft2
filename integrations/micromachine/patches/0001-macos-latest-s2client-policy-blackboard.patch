+bool voiBuildingTaskMatchesType(CCBot & bot, const UnitType & type)
+{
+	const std::string requested = bot.Commander().getVoiPolicyString("building_tasks.0.building_type", "");
+	if (requested.empty())
+	{
+		return false;
+	}
+	const sc2::UNIT_TYPEID apiType = type.getAPIUnitType();
+	return (requested == "TERRAN_BUNKER" && apiType == sc2::UNIT_TYPEID::TERRAN_BUNKER)
+		|| (requested == "TERRAN_BARRACKS" && apiType == sc2::UNIT_TYPEID::TERRAN_BARRACKS)
+		|| (requested == "TERRAN_FACTORY" && apiType == sc2::UNIT_TYPEID::TERRAN_FACTORY)
+		|| (requested == "TERRAN_STARPORT" && apiType == sc2::UNIT_TYPEID::TERRAN_STARPORT)
+		|| (requested == "TERRAN_SUPPLYDEPOT" && apiType == sc2::UNIT_TYPEID::TERRAN_SUPPLYDEPOT)
+		|| (requested == "TERRAN_ENGINEERINGBAY" && apiType == sc2::UNIT_TYPEID::TERRAN_ENGINEERINGBAY)
+		|| (requested == "TERRAN_ARMORY" && apiType == sc2::UNIT_TYPEID::TERRAN_ARMORY);
+}
+
+CCTilePosition voiExplicitBuildingTaskCoordinate(CCBot & bot)
+{
+	const std::string raw = bot.Commander().getVoiPolicyString("building_tasks.0.target_position", "");
+	const size_t comma = raw.find(',');
+	if (comma == std::string::npos)
+	{
+		return CCTilePosition();
+	}
+	const float x = static_cast<float>(std::atof(raw.substr(0, comma).c_str()));
+	const float y = static_cast<float>(std::atof(raw.substr(comma + 1).c_str()));
+	return Util::GetTilePosition(CCPosition(x, y));
+}
+
+CCTilePosition offsetVoiBuildingTaskAnchor(CCBot & bot, const CCTilePosition & anchor, const std::string & direction, int distance)
+{
+	if (anchor == CCTilePosition() || direction.empty() || direction == "center")
+	{
+		return anchor;
+	}
+	CCPosition enemy = voiFarthestEnemyStartPosition(bot);
+	if (enemy == CCPosition())
+	{
+		enemy = bot.GetStartLocation();
+	}
+	const CCPosition anchorPosition = Util::GetPosition(anchor);
+	int dx = 0;
+	int dy = 0;
+	if (direction == "toward_enemy" || direction == "away_from_enemy")
+	{
+		dx = enemy.x > anchorPosition.x ? 1 : -1;
+		dy = enemy.y > anchorPosition.y ? 1 : -1;
+		if (direction == "away_from_enemy")
+		{
+			dx = -dx;
+			dy = -dy;
+		}
+	}
+	else if (direction == "inside")
+	{
+		const CCPosition home = bot.GetStartLocation();
+		dx = home.x > anchorPosition.x ? 1 : -1;
+		dy = home.y > anchorPosition.y ? 1 : -1;
+	}
+	else if (direction == "left")
+	{
+		dx = -1;
+	}
+	else if (direction == "right")
+	{
+		dx = 1;
+	}
+	return CCTilePosition(anchor.x + (dx * distance), anchor.y + (dy * distance));
+}
+
+CCTilePosition resolveVoiBuildingTaskAnchor(CCBot & bot, const std::string & intent, const std::string & anchorIntent)
+{
+	if (anchorIntent == "explicit_coordinate" || intent == "explicit_coordinate")
+	{
+		return voiExplicitBuildingTaskCoordinate(bot);
+	}
+	if (anchorIntent == "self_natural" || intent == "self_natural_choke" || intent == "self_natural_safe")
+	{
+		if (BaseLocation * nat = bot.Bases().getPlayerNat(Players::Self))
+		{
+			return nat->getDepotTilePosition();
+		}
+	}
+	if (anchorIntent == "enemy_natural" || intent == "proxy_near_enemy_natural")
+	{
+		if (BaseLocation * enemyNat = bot.Bases().getPlayerNat(Players::Enemy))
+		{
+			return enemyNat->getDepotTilePosition();
+		}
+	}
+	if (anchorIntent == "enemy_main")
+	{
+		const BaseLocation * enemyMain = bot.Bases().getPlayerStartingBaseLocation(Players::Enemy);
+		return enemyMain ? enemyMain->getDepotTilePosition() : Util::GetTilePosition(voiFarthestEnemyStartPosition(bot));
+	}
+	return Util::GetTilePosition(bot.GetStartLocation());
+}
+
+void recordVoiBuildingTaskPlacement(CCBot & bot, const std::string & status, const std::string & reason, const CCTilePosition & position);
+
+bool resolveVoiBuildingTaskPlacement(CCBot & bot, const Building & building, CCTilePosition & selected, bool & allowNearestFallback, const std::string & source)
+{
+	if (!bot.Commander().isVoiPolicyActive() || !voiBuildingTaskMatchesType(bot, building.type))
+	{
+		return false;
+	}
+	const std::string intent = bot.Commander().getVoiPolicyString("building_tasks.0.placement_intent", "");
+	if (intent.empty())
+	{
+		return false;
+	}
+	const std::string anchorIntent = bot.Commander().getVoiPolicyString("building_tasks.0.anchor", "");
+	std::string offsetDirection = bot.Commander().getVoiPolicyString("building_tasks.0.offset_direction", "");
+	allowNearestFallback = bot.Commander().getVoiPolicyBool("building_tasks.0.allow_nearest_valid_fallback", true);
+	if (offsetDirection.empty())
+	{
+		if (intent == "self_natural_choke" || intent == "proxy_near_enemy_natural")
+		{
+			offsetDirection = "toward_enemy";
+		}
+		else if (intent == "self_main_safe_macro" || intent == "self_natural_safe")
+		{
+			offsetDirection = "inside";
+		}
+	}
+	CCTilePosition anchor = resolveVoiBuildingTaskAnchor(bot, intent, anchorIntent);
+	const int offsetDistance = intent == "proxy_near_enemy_natural" ? 12 : (intent == "self_natural_choke" || intent == "self_main_ramp" ? 5 : 3);
+	anchor = offsetVoiBuildingTaskAnchor(bot, anchor, offsetDirection, offsetDistance);
+	if (anchor == CCTilePosition() || !bot.Map().isValidTile(anchor))
+	{
+		Util::Log(source, "VOI building_task placement rejected invalid anchor intent=" + intent + " anchor=" + anchorIntent + " direction=" + offsetDirection + " type=" + building.type.getName(), bot);
+		recordVoiBuildingTaskPlacement(bot, "refused", "invalid semantic placement anchor", anchor);
+		return false;
+	}
+	if (!allowNearestFallback && !isVoiSc2MacroPlacementSafe(bot, building.type, anchor, false, !building.type.isAddon(), false, true))
+	{
+		Util::Log(source, "VOI building_task placement rejected exact coordinate without fallback intent=" + intent + " anchor_x=" + std::to_string(anchor.x) + " anchor_y=" + std::to_string(anchor.y) + " type=" + building.type.getName(), bot);
+		recordVoiBuildingTaskPlacement(bot, "refused", "exact placement invalid and nearest fallback disabled", anchor);
+		return false;
+	}
+	selected = anchor;
+	Util::Log(source, "VOI building_task placement anchor selected type=" + building.type.getName() + " intent=" + intent + " anchor=" + anchorIntent + " direction=" + offsetDirection + " nearest_fallback=" + (allowNearestFallback ? "true" : "false") + " anchor_x=" + std::to_string(anchor.x) + " anchor_y=" + std::to_string(anchor.y), bot);
+	recordVoiBuildingTaskPlacement(bot, "accepted", "semantic placement anchor resolved", anchor);
+	return true;
+}
+
+void recordVoiBuildingTaskPlacement(CCBot & bot, const std::string & status, const std::string & reason, const CCTilePosition & position)
+{
+	bot.Commander().recordVoiBuildingTaskPlacement(status, reason, position);
+}
+
+int voiMacroTileKey(const CCTilePosition & position)
+{
+	return (position.x * 10000) + position.y;
+}
+
+bool findVoiSc2QueryMacroPlacement(
+	CCBot & bot,
+	const Building & building,
+	bool includeAddonTiles,
+	bool ignoreExtraBorder,
+	bool forceSameHeight,
+	CCTilePosition & selected,
+	const std::string & source)
+{
+	if (!shouldUseVoiSc2MacroPlacement(bot, building.type))
+	{
+		return false;
+	}
+
+	std::vector<CCTilePosition> anchors;
+	std::set<int> seenAnchors;
+	auto addAnchor = [&](const CCTilePosition & anchor) {
+		if (anchor == CCTilePosition() || !bot.Map().isValidTile(anchor))
+		{
+			return;
+		}
+		const int key = voiMacroTileKey(anchor);
+		if (seenAnchors.insert(key).second)
+		{
+			anchors.push_back(anchor);
+		}
+	};
+
+	addAnchor(building.desiredPosition);
+	addAnchor(Util::GetTilePosition(bot.GetStartLocation()));
+	for (const auto & depot : bot.GetAllyUnits(Util::GetResourceDepotType().getAPIUnitType()))
+	{
+		if (depot.isValid() && depot.isAlive() && !depot.isFlying())
+		{
+			addAnchor(depot.getTilePosition());
+		}
+	}
+	for (const auto & apiType : {
+		sc2::UNIT_TYPEID::TERRAN_BARRACKS,
+		sc2::UNIT_TYPEID::TERRAN_FACTORY,
+		sc2::UNIT_TYPEID::TERRAN_STARPORT,
+		sc2::UNIT_TYPEID::TERRAN_ENGINEERINGBAY})
+	{
+		for (const auto & structure : bot.GetAllyUnits(apiType))
+		{
+			if (structure.isValid() && structure.isAlive() && !structure.isFlying())
+			{
+				addAnchor(structure.getTilePosition());
+			}
+		}
+	}
+
+	if (anchors.empty())
+	{
+		return false;
+	}
+
+	struct QueryMeta
+	{
+		CCTilePosition finalPosition;
+		CCPosition commandPosition;
+		float score = 0.0f;
+	};
+
+	std::vector<sc2::QueryInterface::PlacementQuery> queries;
+	std::vector<QueryMeta> queryMeta;
+	std::set<int> seenTiles;
+	const auto buildAbility = bot.Data(building.type).buildAbility;
+	const CCPosition desiredPosition = Util::GetPosition(building.desiredPosition);
+	const float desiredHeight = forceSameHeight ? Util::TerrainHeight(building.desiredPosition) : 0.0f;
+	constexpr size_t maxQueries = 900;
+	const size_t maxTilesPerAnchor = isVoiSupplyRecoveryDepot(bot, building.type) ? 5000 : 2200;
+
+	auto tryAddCandidate = [&](const CCTilePosition & candidate, bool allowCombatInfluence, bool ignoreReservedForCandidate) {
+		if (candidate == CCTilePosition() ||
+			!bot.Map().isValidTile(candidate) ||
+			seenTiles.find(voiMacroTileKey(candidate)) != seenTiles.end())
+		{
+			return false;
+		}
+		if (forceSameHeight && Util::TerrainHeight(candidate) != desiredHeight)
+		{
+			return false;
+		}
+		if (!isVoiSc2MacroPlacementSafeWithOptions(
+			bot,
+			building.type,
+			candidate,
+			ignoreReservedForCandidate,
+			includeAddonTiles,
+			ignoreExtraBorder,
+			false,
+			allowCombatInfluence))
+		{
+			return false;
+		}
+
+		const CCPosition commandPosition = Util::GetPosition(candidate);
+		seenTiles.insert(voiMacroTileKey(candidate));
+		queries.emplace_back(buildAbility, commandPosition);
+		QueryMeta meta;
+		meta.finalPosition = candidate;
+		meta.commandPosition = commandPosition;
+		meta.score = Util::DistSq(desiredPosition, commandPosition);
+		queryMeta.push_back(meta);
+		return true;
+	};
+
+	auto collectCandidates = [&](bool allowCombatInfluence, bool ignoreReservedForCandidate) {
+		for (const auto & anchor : anchors)
+		{
+			const auto & closestTiles = bot.Map().getClosestTilesTo(anchor);
+			size_t scanned = 0;
+			for (const auto & candidate : closestTiles)
+			{
+				if (++scanned > maxTilesPerAnchor || queries.size() >= maxQueries)
+				{
+					break;
+				}
+				tryAddCandidate(candidate, allowCombatInfluence, ignoreReservedForCandidate);
+			}
+			if (queries.size() >= maxQueries)
+			{
+				break;
+			}
+		}
+	};
+	auto collectSpiralCandidates = [&](bool allowCombatInfluence, bool ignoreReservedForCandidate) {
+		for (const auto & anchor : anchors)
+		{
+			for (int radius = 2; radius <= 72 && queries.size() < maxQueries; radius += 2)
+			{
+				for (int dx = -radius; dx <= radius && queries.size() < maxQueries; dx += 2)
+				{
+					for (int dy = -radius; dy <= radius && queries.size() < maxQueries; dy += 2)
+					{
+						if (dx != -radius && dx != radius && dy != -radius && dy != radius)
+						{
+							continue;
+						}
+						tryAddCandidate(CCTilePosition(anchor.x + dx, anchor.y + dy), allowCombatInfluence, ignoreReservedForCandidate);
+					}
+				}
+			}
+			if (queries.size() >= maxQueries)
+			{
+				break;
+			}
+		}
+	};
+
+	collectCandidates(false, false);
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI SC2 Query macro placement found no closest-tile candidates for " + building.type.getName() + "; retrying with local spiral SC2 Query placement.", bot);
+		collectSpiralCandidates(false, false);
+	}
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI SC2 Query macro placement found no strict spiral candidates for " + building.type.getName() + "; retrying with stale-reservation-relaxed local spiral placement.", bot);
+		collectSpiralCandidates(false, true);
+	}
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI SC2 Query macro placement found no reservation-relaxed candidates for " + building.type.getName() + "; retrying with combat-influence-relaxed SC2 Query placement.", bot);
+		collectCandidates(true, true);
+	}
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI SC2 Query macro placement found no combat-influence-relaxed closest-tile candidates for " + building.type.getName() + "; retrying with combat-influence-relaxed local spiral placement.", bot);
+		collectSpiralCandidates(true, true);
+	}
+	if (queries.empty() && isVoiSupplyRecoveryDepot(bot, building.type))
+	{
+		Util::Log(source, "VOI SupplyDepot recovery found no strict macro candidates; retrying with stale-reservation-relaxed SC2 Query placement.", bot);
+		collectCandidates(false, true);
+	}
+	if (queries.empty() && isVoiSupplyRecoveryDepot(bot, building.type))
+	{
+		Util::Log(source, "VOI SupplyDepot recovery found no reservation-relaxed macro candidates; retrying with combat-influence-relaxed SC2 Query placement.", bot);
+		collectCandidates(true, true);
+	}
+	if (queries.empty() && isVoiSupplyRecoveryDepot(bot, building.type))
+	{
+		Util::Log(source, "VOI SupplyDepot recovery found no closest-tile macro candidates; retrying with spiral SC2 Query placement.", bot);
+		collectSpiralCandidates(true, true);
+	}
+
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI SC2 Query macro placement found no prechecked candidates for " + building.type.getName() + ".", bot);
+		return false;
+	}
+
+	const std::vector<bool> results = bot.Query()->Placement(queries);
+	bool hasSelected = false;
+	QueryMeta best;
+	best.score = std::numeric_limits<float>::max();
+	for (size_t i = 0; i < results.size() && i < queryMeta.size(); ++i)
+	{
+		if (!results[i])
+		{
+			continue;
+		}
+		if (!hasSelected || queryMeta[i].score < best.score)
+		{
+			hasSelected = true;
+			best = queryMeta[i];
+		}
+	}
+
+	if (!hasSelected)
+	{
+		Util::Log(source,
+			"VOI SC2 Query macro placement rejected all candidates for " + building.type.getName() +
+			" query_count=" + std::to_string(queries.size()) + ".",
+			bot);
+		return false;
+	}
+
+	selected = best.finalPosition;
+	Util::Log(source,
+		"VOI SC2 Query macro placement selected " + building.type.getName() +
+		" final_x=" + std::to_string(selected.x) +
+		" final_y=" + std::to_string(selected.y) +
+		" command_x=" + std::to_string(best.commandPosition.x) +
+		" command_y=" + std::to_string(best.commandPosition.y) +
+		" query_count=" + std::to_string(queries.size()),
+		bot);
+	return true;
+}
+
+int voiExpansionTileKey(const CCTilePosition & position)
+{
+	return (position.x * 10000) + position.y;
+}
+
+std::map<int, CCPosition> & voiExpansionCommandPositionCache()
+{
+	static std::map<int, CCPosition> cache;
+	return cache;
+}
+
+bool findVoiExpansionPlacementCommandPosition(CCBot & bot, const UnitType & type, const CCTilePosition & position, CCPosition & commandPosition)
+{
+	if (!shouldUseVoiExpansionDepotLocation(bot, type) ||
+		position == CCTilePosition() ||
+		!bot.Map().isValidTile(position))
+	{
+		return false;
+	}
+
+	auto & cache = voiExpansionCommandPositionCache();
+	auto cached = cache.find(voiExpansionTileKey(position));
+	if (cached != cache.end())
+	{
+		if (queryCanPlaceVoiBuilding(bot, type, cached->second))
+		{
+			commandPosition = cached->second;
+			return true;
+		}
+		cache.erase(cached);
+	}
+
+	std::vector<CCPosition> candidates;
+	if (const BaseLocation * base = bot.Bases().getBaseForDepotPosition(position))
+	{
+		candidates.push_back(base->getDepotPosition());
+	}
+	candidates.push_back(CCPosition(position.x + 0.5f, position.y + 0.5f));
+	candidates.push_back(Util::GetPosition(position));
+
+	for (const auto & candidate : candidates)
+	{
+		if (queryCanPlaceVoiBuilding(bot, type, candidate))
+		{
+			commandPosition = candidate;
+			cache[voiExpansionTileKey(position)] = candidate;
+			return true;
+		}
+	}
+
+	return false;
+}
+
+bool isKnownVoiExpansionDepotLocation(CCBot & bot, const UnitType & type, const CCTilePosition & position)
+{
+	if (!shouldUseVoiExpansionDepotLocation(bot, type) ||
+		position == CCTilePosition() ||
+		!bot.Map().isValidTile(position))
+	{
+		return false;
+	}
+
+	const BaseLocation * base = bot.Bases().getBaseForDepotPosition(position);
+	if (!base || base->getDepotTilePosition() != position)
+	{
+		return false;
+	}
+	if (base->isMineralOnly() || base->isStartLocation() || base->isOccupiedByPlayer(Players::Enemy))
+	{
+		return false;
+	}
+	if (base->isOccupiedByPlayer(Players::Self))
+	{
+		const Unit depot = base->getResourceDepot();
+		if (depot.isValid() && depot.isAlive())
+		{
+			return false;
+		}
+	}
+
+	return true;
+}
+
+bool isVoiExpansionDepotFootprintUsable(CCBot & bot, const UnitType & type, const CCTilePosition & position)
+{
+	if (!bot.Map().isValidTile(position))
+	{
+		return false;
+	}
+
+	if (isKnownVoiExpansionDepotLocation(bot, type, position))
+	{
+		// BaseLocation computes depot tiles through BuildingPlacer::canBuildDepotHere().
+		// Do not re-run generic building placement here: it includes resource-blocked
+		// expansion-main heuristics that reject legal expansion depot locations.
+		const auto tiles = bot.Buildings().getBuildingPlacer().getTilesForBuildLocation(
+			position.x,
+			position.y,
+			type,
+			type.tileWidth(),
+			type.tileHeight(),
+			false,
+			0);
+		for (const auto & tile : tiles)
+		{
+			if (!bot.Map().isValidTile(tile))
+			{
+				return false;
+			}
+			if (!Util::IsZerg(bot.GetSelfRace()) && bot.Observation()->HasCreep(CCPosition(tile.x, tile.y)))
+			{
+				return false;
+			}
+		}
+		return true;
+	}
+
+	const auto tiles = bot.Buildings().getBuildingPlacer().getTilesForBuildLocation(
+		position.x,
+		position.y,
+		type,
+		type.tileWidth(),
+		type.tileHeight(),
+		false,
+		0);
+	for (const auto & tile : tiles)
+	{
+		if (!bot.Map().isValidTile(tile) || !bot.Map().isBuildable(tile.x, tile.y))
+		{
+			return false;
+		}
+		if (!Util::IsZerg(bot.GetSelfRace()) && bot.Observation()->HasCreep(CCPosition(tile.x, tile.y)))
+		{
+			return false;
+		}
+	}
+
+	return true;
+}
+
+CCPosition getVoiExpansionAnchor(CCBot & bot)
+{
+	Unit closestDepot;
+	float closestDistance = 0.0f;
+	const CCPosition startLocation = bot.GetStartLocation();
+	for (auto & depot : bot.GetAllyUnits(Util::GetResourceDepotType().getAPIUnitType()))
+	{
+		if (!depot.isValid() || !depot.isAlive() || depot.isFlying())
+		{
+			continue;
+		}
+		const float distance = Util::DistSq(depot.getPosition(), startLocation);
+		if (!closestDepot.isValid() || distance < closestDistance)
+		{
+			closestDepot = depot;
+			closestDistance = distance;
+		}
+	}
+
+	return closestDepot.isValid() ? closestDepot.getPosition() : startLocation;
+}
+
+bool isVoiExpansionDepotAlreadyOccupied(CCBot & bot, const CCTilePosition & position, const std::string & source, const std::string & evidence)
+{
+	const CCPosition candidatePosition = Util::GetPosition(position);
+	for (auto & unit : bot.GetUnits())
+	{
+		if (!unit.isValid() || !unit.isAlive() || !unit.getType().isResourceDepot())
+		{
+			continue;
+		}
+		if (Util::DistSq(unit.getPosition(), candidatePosition) <= 8.0f * 8.0f)
+		{
+			Util::Log(source,
+				"VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) +
+				" y=" + std::to_string(position.y) +
+				" evidence=" + evidence +
+				" reason=depot_already_occupied existing_depot_x=" + std::to_string(unit.getPosition().x) +
+				" existing_depot_y=" + std::to_string(unit.getPosition().y),
+				bot);
+			return true;
+		}
+	}
+	return false;
+}
+
+struct VoiExpansionResourceCluster
+{
+	CCPosition center;
+	int resources = 0;
+	int minerals = 0;
+	int geysers = 0;
+};
+
+struct VoiExpansionPlacementCandidate
+{
+	CCTilePosition finalPosition;
+	CCPosition commandPosition;
+	int clusterIndex = -1;
+	int groundDistance = -1;
+	float score = 0.0f;
+};
+
+bool isVoiExpansionResource(const Unit & unit)
+{
+	return unit.isValid() && unit.isAlive() && (unit.getType().isMineral() || unit.getType().isGeyser());
+}
+
+bool isVoiExpansionCommandPositionOccupied(CCBot & bot, const CCPosition & commandPosition)
+{
+	for (auto & unit : bot.GetUnits())
+	{
+		if (!unit.isValid() || !unit.isAlive() || !unit.getType().isResourceDepot())
+		{
+			continue;
+		}
+		if (Util::DistSq(unit.getPosition(), commandPosition) <= 10.0f * 10.0f)
+		{
+			return true;
+		}
+	}
+	return false;
+}
+
+std::vector<VoiExpansionResourceCluster> getVoiExpansionResourceClusters(CCBot & bot)
+{
+	constexpr float clusterDistance = 15.0f;
+	std::vector<VoiExpansionResourceCluster> clusters;
+
+	for (auto & unit : bot.GetUnits())
+	{
+		if (!isVoiExpansionResource(unit))
+		{
+			continue;
+		}
+
+		int bestIndex = -1;
+		float bestDistance = 0.0f;
+		for (int i = 0; i < static_cast<int>(clusters.size()); ++i)
+		{
+			const float distance = Util::DistSq(unit.getPosition(), clusters[i].center);
+			if ((bestIndex < 0 || distance < bestDistance) && distance <= clusterDistance * clusterDistance)
+			{
+				bestIndex = i;
+				bestDistance = distance;
+			}
+		}
+
+		if (bestIndex < 0)
+		{
+			VoiExpansionResourceCluster cluster;
+			cluster.center = unit.getPosition();
+			cluster.resources = 1;
+			cluster.minerals = unit.getType().isMineral() ? 1 : 0;
+			cluster.geysers = unit.getType().isGeyser() ? 1 : 0;
+			clusters.push_back(cluster);
+			continue;
+		}
+
+		auto & cluster = clusters[bestIndex];
+		const float previousCount = static_cast<float>(cluster.resources);
+		cluster.center.x = ((cluster.center.x * previousCount) + unit.getPosition().x) / (previousCount + 1.0f);
+		cluster.center.y = ((cluster.center.y * previousCount) + unit.getPosition().y) / (previousCount + 1.0f);
+		++cluster.resources;
+		if (unit.getType().isMineral())
+		{
+			++cluster.minerals;
+		}
+		if (unit.getType().isGeyser())
+		{
+			++cluster.geysers;
+		}
+	}
+
+	return clusters;
+}
+
+bool findVoiSc2QueryExpansionPlacement(CCBot & bot, const UnitType & type, VoiExpansionPlacementCandidate & selected, const std::string & source)
+{
+	if (!shouldUseVoiExpansionDepotLocation(bot, type))
+	{
+		return false;
+	}
+
+	const auto clusters = getVoiExpansionResourceClusters(bot);
+	if (clusters.empty())
+	{
+		Util::Log(source, "VOI expand_macro SC2 query scanner found no neutral resource clusters.", bot);
+		return false;
+	}
+
+	struct QueryMeta
+	{
+		CCTilePosition finalPosition;
+		CCPosition commandPosition;
+		int clusterIndex = -1;
+	};
+
+	std::vector<sc2::QueryInterface::PlacementQuery> queries;
+	std::vector<QueryMeta> queryMeta;
+	std::set<int> seenTiles;
+	const auto buildAbility = bot.Data(type).buildAbility;
+
+	for (int clusterIndex = 0; clusterIndex < static_cast<int>(clusters.size()); ++clusterIndex)
+	{
+		const auto & cluster = clusters[clusterIndex];
+		if (cluster.minerals < 3 || cluster.geysers == 0)
+		{
+			Util::DebugLog(source,
+				"VOI expand_macro skipped resource cluster index=" + std::to_string(clusterIndex) +
+				" minerals=" + std::to_string(cluster.minerals) +
+				" geysers=" + std::to_string(cluster.geysers) +
+				" reason=mineral_only_or_too_few_minerals",
+				bot);
+			continue;
+		}
+
+		const int centerX = static_cast<int>(std::floor(cluster.center.x));
+		const int centerY = static_cast<int>(std::floor(cluster.center.y));
+		for (int dx = -10; dx <= 10; ++dx)
+		{
+			for (int dy = -10; dy <= 10; ++dy)
+			{
+				const float distance = std::sqrt(static_cast<float>(dx * dx + dy * dy));
+				if (distance < 4.0f || distance > 8.5f)
+				{
+					continue;
+				}
+
+				const CCPosition commandPosition(static_cast<float>(centerX + dx) + 0.5f, static_cast<float>(centerY + dy) + 0.5f);
+				const CCTilePosition finalPosition = Util::GetTilePosition(commandPosition);
+				const int tileKey = voiExpansionTileKey(finalPosition);
+				if (!bot.Map().isValidTile(finalPosition) || seenTiles.find(tileKey) != seenTiles.end())
+				{
+					continue;
+				}
+				if (isVoiExpansionCommandPositionOccupied(bot, commandPosition))
+				{
+					continue;
+				}
+				if (Util::PathFinding::GetCombatInfluenceOnTile(finalPosition, false, bot) > 0)
+				{
+					continue;
+				}
+
+				seenTiles.insert(tileKey);
+				queries.emplace_back(buildAbility, commandPosition);
+				QueryMeta meta;
+				meta.finalPosition = finalPosition;
+				meta.commandPosition = commandPosition;
+				meta.clusterIndex = clusterIndex;
+				queryMeta.push_back(meta);
+			}
+		}
+	}
+
+	if (queries.empty())
+	{
+		Util::Log(source, "VOI expand_macro SC2 query scanner produced no safe CommandCenter placement queries.", bot);
+		return false;
+	}
+
+	const std::vector<bool> results = bot.Query()->Placement(queries);
+	const CCPosition anchor = getVoiExpansionAnchor(bot);
+	bool hasSelected = false;
+	VoiExpansionPlacementCandidate best;
+	best.score = std::numeric_limits<float>::max();
+
+	for (size_t i = 0; i < results.size() && i < queryMeta.size(); ++i)
+	{
+		if (!results[i])
+		{
+			continue;
+		}
+
+		const auto & meta = queryMeta[i];
+		const auto & cluster = clusters[meta.clusterIndex];
+		const int groundDistance = bot.Map().getGroundDistance(anchor, meta.commandPosition);
+		const float airDistance = Util::DistSq(anchor, meta.commandPosition);
+		const float resourceDistance = Util::DistSq(cluster.center, meta.commandPosition);
+		const float score = (groundDistance >= 0 ? static_cast<float>(groundDistance) : airDistance + 100000.0f) + (resourceDistance * 0.01f);
+		if (!hasSelected || score < best.score)
+		{
+			hasSelected = true;
+			best.finalPosition = meta.finalPosition;
+			best.commandPosition = meta.commandPosition;
+			best.clusterIndex = meta.clusterIndex;
+			best.groundDistance = groundDistance;
+			best.score = score;
+		}
+	}
+
+	if (!hasSelected)
+	{
+		Util::Log(source,
+			"VOI expand_macro SC2 query scanner rejected all CommandCenter candidates query_count=" + std::to_string(queries.size()) +
+			" cluster_count=" + std::to_string(clusters.size()),
+			bot);
+		return false;
+	}
+
+	selected = best;
+	voiExpansionCommandPositionCache()[voiExpansionTileKey(best.finalPosition)] = best.commandPosition;
+	const auto & cluster = clusters[best.clusterIndex];
+	Util::Log(source,
+		"VOI expand_macro selected SC2 Query expansion placement final_x=" + std::to_string(best.finalPosition.x) +
+		" final_y=" + std::to_string(best.finalPosition.y) +
+		" command_x=" + std::to_string(best.commandPosition.x) +
+		" command_y=" + std::to_string(best.commandPosition.y) +
+		" cluster_index=" + std::to_string(best.clusterIndex) +
+		" minerals=" + std::to_string(cluster.minerals) +
+		" geysers=" + std::to_string(cluster.geysers) +
+		" ground_distance=" + std::to_string(best.groundDistance) +
+		" query_count=" + std::to_string(queries.size()),
+		bot);
+	return true;
+}
+
+CCTilePosition getVoiExpansionDepotPosition(CCBot & bot, const UnitType & type, bool requirePlacement, const std::string & source)
+{
+	if (!shouldUseVoiExpansionDepotLocation(bot, type))
+	{
+		return CCTilePosition();
+	}
+
+	auto accepts = [&](const CCTilePosition & position, const std::string & evidence) {
+		if (position == CCTilePosition() || !bot.Map().isValidTile(position))
+		{
+			return false;
+		}
+		if (isVoiExpansionDepotAlreadyOccupied(bot, position, source, evidence))
+		{
+			return false;
+		}
+		if (requirePlacement && !isVoiExpansionDepotFootprintUsable(bot, type, position))
+		{
+			Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=depot_footprint_unusable", bot);
+			return false;
+		}
+		if (requirePlacement)
+		{
+			CCPosition commandPosition;
+			if (!findVoiExpansionPlacementCommandPosition(bot, type, position, commandPosition))
+			{
+				Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=sc2_query_placement_rejected", bot);
+				return false;
+			}
+			Util::DebugLog(source, "VOI expand_macro accepted CommandCenter SC2 placement x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " command_x=" + std::to_string(commandPosition.x) + " command_y=" + std::to_string(commandPosition.y) + " evidence=" + evidence, bot);
+		}
+		const BaseLocation * base = bot.Bases().getBaseForDepotPosition(position);
+		if (base && base->isUnderAttack())
+		{
+			Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=base_under_attack", bot);
+			return false;
+		}
+		Util::Log(source, "VOI expand_macro selected CommandCenter depot x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence, bot);
+		return true;
+	};
+
+	CCTilePosition position = bot.Bases().getNextExpansionPosition(Players::Self, true, false, false);
+	if (accepts(position, "next_expansion_unblocked"))
+	{
+		return position;
+	}
+
+	position = bot.Bases().getNextExpansionPosition(Players::Self, false, false, true);
+	if (accepts(position, "next_expansion_ignore_blocked_reserved"))
+	{
+		return position;
+	}
+
+	if (BaseLocation * nat = bot.Bases().getPlayerNat(Players::Self))
+	{
+		position = nat->getDepotTilePosition();
+		if (accepts(position, "player_natural_fallback"))
+		{
+			return position;
+		}
+	}
+
+	if (requirePlacement)
+	{
+		VoiExpansionPlacementCandidate queryPlacement;
+		if (findVoiSc2QueryExpansionPlacement(bot, type, queryPlacement, source))
+		{
+			return queryPlacement.finalPosition;
+		}
+	}
+
+	const CCPosition anchor = getVoiExpansionAnchor(bot);
+	CCTilePosition bestPosition;
+	std::string bestEvidence;
+	float bestScore = 0.0f;
+	int bestGroundDistance = -1;
+
+	for (BaseLocation * base : bot.Bases().getBaseLocations())
+	{
+		if (!base || base->isStartLocation() || base->isMineralOnly() || base->isOccupiedByPlayer(Players::Enemy))
+		{
+			continue;
+		}
+		if (base->isOccupiedByPlayer(Players::Self))
+		{
+			const Unit depot = base->getResourceDepot();
+			if (depot.isValid() && depot.isAlive())
+			{
+				continue;
+			}
+		}
+		position = base->getDepotTilePosition();
+		const std::string evidence = "base_scan_ranked_fallback";
+		if (position == CCTilePosition() || !bot.Map().isValidTile(position))
+		{
+			continue;
+		}
+		if (isVoiExpansionDepotAlreadyOccupied(bot, position, source, evidence))
+		{
+			continue;
+		}
+		if (requirePlacement && !isVoiExpansionDepotFootprintUsable(bot, type, position))
+		{
+			Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=depot_footprint_unusable", bot);
+			continue;
+		}
+		if (requirePlacement)
+		{
+			CCPosition commandPosition;
+			if (!findVoiExpansionPlacementCommandPosition(bot, type, position, commandPosition))
+			{
+				Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=sc2_query_placement_rejected", bot);
+				continue;
+			}
+			Util::DebugLog(source, "VOI expand_macro accepted CommandCenter SC2 placement x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " command_x=" + std::to_string(commandPosition.x) + " command_y=" + std::to_string(commandPosition.y) + " evidence=" + evidence, bot);
+		}
+		if (base->isUnderAttack())
+		{
+			Util::Log(source, "VOI expand_macro rejected CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " evidence=" + evidence + " reason=base_under_attack", bot);
+			continue;
+		}
+
+		const int groundDistance = bot.Map().getGroundDistance(anchor, base->getDepotPosition());
+		const float fallbackDistance = Util::DistSq(anchor, base->getDepotPosition());
+		const float score = groundDistance >= 0
+			? static_cast<float>(groundDistance)
+			: fallbackDistance + 100000.0f;
+		Util::DebugLog(source, "VOI expand_macro ranked CommandCenter candidate x=" + std::to_string(position.x) + " y=" + std::to_string(position.y) + " score=" + std::to_string(score) + " ground_distance=" + std::to_string(groundDistance), bot);
+		if (bestPosition == CCTilePosition() || score < bestScore)
+		{
+			bestPosition = position;
+			bestEvidence = evidence;
+			bestScore = score;
+			bestGroundDistance = groundDistance;
+		}
+	}
+
+	if (bestPosition != CCTilePosition())
+	{
+		Util::Log(source, "VOI expand_macro selected CommandCenter depot x=" + std::to_string(bestPosition.x) + " y=" + std::to_string(bestPosition.y) + " evidence=" + bestEvidence + " score=" + std::to_string(bestScore) + " ground_distance=" + std::to_string(bestGroundDistance), bot);
+		return bestPosition;
+	}
+
+	Util::Log(source, "VOI expand_macro could not find a valid CommandCenter expansion depot candidate.", bot);
+	return CCTilePosition();
+}
+
+bool canTrustVoiExpansionDepotPlacement(CCBot & bot, const UnitType & type, const CCTilePosition & position)
+{
+	if (!shouldUseVoiExpansionDepotLocation(bot, type) ||
+		position == CCTilePosition() ||
+		!bot.Map().isValidTile(position))
+	{
+		return false;
+	}
+	CCPosition commandPosition;
+	if (!findVoiExpansionPlacementCommandPosition(bot, type, position, commandPosition))
+	{
+		return false;
+	}
+
+	const BaseLocation * base = bot.Bases().getBaseForDepotPosition(position);
+	if (base && base->isUnderAttack())
+	{
+		return false;
+	}
+
+	// For VOI expansion placements, SC2 Query()->Placement is authoritative.
+	// The legacy footprint cache can reject legal expansion points on current SC2 maps.
+	return Util::PathFinding::GetCombatInfluenceOnTile(position, false, bot) <= 0;
+}
+
+bool canTrustAssignedVoiExpansionDepot(CCBot & bot, const Building & building)
+{
+	if (building.type.getAPIUnitType() != sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER ||
+		!shouldUseVoiExpansionDepotLocation(bot, building.type) ||
+		building.finalPosition == CCTilePosition() ||
+		!bot.Map().isValidTile(building.finalPosition) ||
+		!building.buildingUnit.isValid() ||
+		!building.buildingUnit.isCompleted() ||
+		building.buildingUnit.isFlying())
+	{
+		return false;
+	}
+
+	if (building.buildingUnit.getAPIUnitType() != sc2::UNIT_TYPEID::TERRAN_COMMANDCENTER)
+	{
+		return false;
+	}
+
+	const BaseLocation * base = bot.Bases().getBaseForDepotPosition(building.finalPosition);
+	if (base && base->isUnderAttack())
+	{
+		return false;
+	}
+
+	// A completed CommandCenter occupies its own footprint, so SC2 placement
+	// queries are no longer valid evidence. Trust the assigned expansion depot
+	// while BaseLocation resource-depot mapping catches up.
+	return Util::PathFinding::GetCombatInfluenceOnTile(building.finalPosition, false, bot) <= 0;
+}
