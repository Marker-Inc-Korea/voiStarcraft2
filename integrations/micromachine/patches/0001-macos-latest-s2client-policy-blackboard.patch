+bool GameCommander::shouldSuppressRepeatedWorkerCommand(const sc2::Unit * unit, const sc2::AbilityID & abilityID, sc2::Tag targetTag, const CCPosition & targetPosition, const std::string & targetKind)
+{
+	if (unit == nullptr || !voiIsWorkerUnitType(unit->unit_type) || targetKind.empty())
+	{
+		return false;
+	}
+
+	const uint32_t currentFrame = m_bot.GetGameLoop();
+	VoiWorkerCommandRecord next;
+	next.abilityId = static_cast<int>(abilityID.ToType());
+	next.targetTag = targetTag;
+	next.targetX100 = voiQuantizePosition(targetPosition.x);
+	next.targetY100 = voiQuantizePosition(targetPosition.y);
+	next.frame = currentFrame;
+	next.targetKind = targetKind;
+	next.reason = consumeVoiWorkerCommandReason(unit->tag, targetKind);
+
+	const CCPosition workerPosition(unit->pos);
+	const float targetDistanceSq = voiDistanceSq(workerPosition, targetPosition);
+	const bool buildPositionCommand = targetKind == "build_position" || targetKind == "ability_position";
+	constexpr float workerNearSelfCommandDistanceSq = 1.0f;
+	const bool selfPositionCommand = targetTag == 0
+		&& !buildPositionCommand
+		&& voiIsPositionWorkerAbility(abilityID)
+		&& targetDistanceSq <= workerNearSelfCommandDistanceSq;
+	const bool sameAbilityPositionOrder = voiHasSamePositionOrder(unit, abilityID, targetPosition, 2.25f);
+	const bool redundantExistingPositionOrder = targetTag == 0
+		&& voiIsWorkerPositionCommandKind(targetKind)
+		&& ((buildPositionCommand && sameAbilityPositionOrder)
+			|| (!buildPositionCommand && sameAbilityPositionOrder && targetDistanceSq <= workerNearSelfCommandDistanceSq));
+	if (selfPositionCommand)
+	{
+		m_voiWorkerLastRootCauseStatus = "self_position_move_blocked";
+		m_voiWorkerLastRootCauseReason = next.reason.empty() ? targetKind : next.reason;
+		recordVoiWorkerCommandTrace(next, unit, targetPosition, targetDistanceSq, "self_position_noop");
+		return true;
+	}
+	if (redundantExistingPositionOrder)
+	{
+		m_voiWorkerLastRootCauseStatus = "duplicate_command_safety_blocked";
+		m_voiWorkerLastRootCauseReason = next.reason.empty() ? targetKind : next.reason;
+		recordVoiWorkerCommandTrace(next, unit, targetPosition, targetDistanceSq, "redundant_existing_position_order");
+		return true;
+	}
+	recordVoiWorkerCommandTrace(next, unit, targetPosition, targetDistanceSq, "accepted_candidate");
+
+	const int guardFrames = getVoiWorkerRepeatGuardFrames();
+	if (guardFrames <= 0)
+	{
+		return false;
+	}
+
+	const auto previous = m_voiWorkerLastCommands.find(unit->tag);
+	if (previous != m_voiWorkerLastCommands.end())
+	{
+		const VoiWorkerCommandRecord & last = previous->second;
+		const bool sameCommand = last.abilityId == next.abilityId
+			&& last.targetTag == next.targetTag
+			&& last.targetX100 == next.targetX100
+			&& last.targetY100 == next.targetY100
+			&& last.targetKind == next.targetKind;
+		if (sameCommand && currentFrame >= last.frame && currentFrame - last.frame < static_cast<uint32_t>(guardFrames))
+		{
+			m_voiWorkerLastRootCauseStatus = "duplicate_command_safety_blocked";
+			m_voiWorkerLastRootCauseReason = next.reason.empty() ? targetKind : next.reason;
+			recordVoiWorkerCommandTrace(next, unit, targetPosition, targetDistanceSq, "duplicate_command_noop");
+			return true;
+		}
+	}
+
+	m_voiWorkerLastCommands[unit->tag] = next;
+	return false;
+}
+
+void GameCommander::recordVoiWorkerCommandTrace(const VoiWorkerCommandRecord & record, const sc2::Unit * unit, const CCPosition & targetPosition, float targetDistanceSq, const std::string & status)
+{
+	if (unit == nullptr)
+	{
+		return;
+	}
+	m_voiWorkerTraceEventCount++;
+	m_voiWorkerLastTraceFrame = record.frame;
+	m_voiWorkerLastTraceStatus = status.empty() ? "unknown" : status;
+	m_voiWorkerLastTraceReason = record.reason.empty() ? "unlabeled_worker_command" : record.reason;
+	m_voiWorkerLastTraceTargetKind = record.targetKind;
+	m_voiWorkerLastTraceTargetTag = record.targetTag;
+	m_voiWorkerLastTraceTargetX = targetPosition.x;
+	m_voiWorkerLastTraceTargetY = targetPosition.y;
+	m_voiWorkerLastTraceDistanceSq = targetDistanceSq;
+	m_voiWorkerLastTraceCurrentOrderAbility = 0;
+	m_voiWorkerLastTraceCurrentOrderTargetTag = 0;
+	m_voiWorkerLastTraceCurrentOrderTargetX = 0.0f;
+	m_voiWorkerLastTraceCurrentOrderTargetY = 0.0f;
+	if (status == "self_position_noop")
+	{
+		m_voiWorkerSelfPositionCommandBlocks++;
+		m_voiWorkerLastSelfPositionFrame = record.frame;
+		m_voiWorkerLastSelfPositionWorker = unit->tag;
+		m_voiWorkerLastSelfPositionAbility = record.abilityId;
+		m_voiWorkerLastSelfPositionTargetX = targetPosition.x;
+		m_voiWorkerLastSelfPositionTargetY = targetPosition.y;
+		m_voiWorkerLastSelfPositionDistanceSq = targetDistanceSq;
+		m_voiWorkerLastSelfPositionTargetKind = record.targetKind;
+	}
+	else if (status == "redundant_existing_position_order" || status == "duplicate_command_noop")
+	{
+		m_voiWorkerRepeatedCommandSuppressions++;
+		m_voiWorkerLastSuppressionFrame = record.frame;
+		m_voiWorkerLastSuppressedWorker = unit->tag;
+		m_voiWorkerLastSuppressedAbility = record.abilityId;
+		m_voiWorkerLastSuppressedTargetTag = record.targetTag;
+		m_voiWorkerLastSuppressedTargetX = targetPosition.x;
+		m_voiWorkerLastSuppressedTargetY = targetPosition.y;
+		m_voiWorkerLastSuppressedTargetKind = record.targetKind;
+	}
+	if (!unit->orders.empty())
+	{
+		const auto & order = unit->orders[0];
+		m_voiWorkerLastTraceCurrentOrderAbility = static_cast<int>(order.ability_id.ToType());
+		m_voiWorkerLastTraceCurrentOrderTargetTag = order.target_unit_tag;
+		m_voiWorkerLastTraceCurrentOrderTargetX = order.target_pos.x;
+		m_voiWorkerLastTraceCurrentOrderTargetY = order.target_pos.y;
+	}
+}
+
+void GameCommander::setVoiWorkerCommandReason(const Unit & worker, const std::string & reason)
+{
+	if (!worker.isValid() || reason.empty())
+	{
+		return;
+	}
+	m_voiWorkerCommandReasons[worker.getTag()] = reason;
+}
+
+std::string GameCommander::consumeVoiWorkerCommandReason(sc2::Tag workerTag, const std::string & fallback)
+{
+	auto it = m_voiWorkerCommandReasons.find(workerTag);
+	if (it == m_voiWorkerCommandReasons.end())
+	{
+		return fallback.empty() ? "unlabeled_worker_command" : "unlabeled_" + fallback;
+	}
+	const std::string reason = it->second.empty() ? fallback : it->second;
+	m_voiWorkerCommandReasons.erase(it);
+	return reason;
+}
