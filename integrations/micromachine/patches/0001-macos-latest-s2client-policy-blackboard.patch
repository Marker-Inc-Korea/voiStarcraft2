+		|| (token == "TERRAN_BANSHEE" && type == sc2::UNIT_TYPEID::TERRAN_BANSHEE)
+		|| (token == "TERRAN_RAVEN" && type == sc2::UNIT_TYPEID::TERRAN_RAVEN)
+		|| (token == "TERRAN_BATTLECRUISER" && type == sc2::UNIT_TYPEID::TERRAN_BATTLECRUISER);
+}
+
+std::string voiCompositionRequirementLabel(CCBot & bot, int index)
+{
+	const std::string unitType = bot.Commander().getVoiPolicyString("composition_requirements." + std::to_string(index) + ".unit_type", "");
+	if (unitType.empty())
+	{
+		return "";
+	}
+	const int count = std::max(0, bot.Commander().getVoiPolicyInt("composition_requirements." + std::to_string(index) + ".count", 0));
+	const std::string role = bot.Commander().getVoiPolicyString("composition_requirements." + std::to_string(index) + ".role", "");
+	return unitType + ":" + std::to_string(count) + (role.empty() ? "" : ":" + role);
+}
+
+int voiCountMobileAttackUnits(const std::vector<Unit> & units)
+{
+	int count = 0;
+	for (const auto & unit : units)
+	{
+		if (voiIsMobileAttackUnit(unit))
+		{
+			++count;
+		}
+	}
+	return count;
+}
+
+float voiSquadMaxHomeDistance(const std::vector<Unit> & units, CCBot & bot)
+{
+	const BaseLocation * selfBase = bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+	const CCPosition homePosition = selfBase ? selfBase->getPosition() : bot.GetStartLocation();
+	float maxDistanceSq = 0.0f;
+	for (const auto & unit : units)
+	{
+		if (!unit.isValid())
+		{
+			continue;
+		}
+		maxDistanceSq = std::max(maxDistanceSq, Util::DistSq(unit.getPosition(), homePosition));
+	}
+	return std::sqrt(maxDistanceSq);
+}
+
+CCPosition voiHomePosition(CCBot & bot)
+{
+	const BaseLocation * selfBase = bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+	return selfBase ? selfBase->getPosition() : bot.GetStartLocation();
+}
+
+bool voiIsRemoteCombatTarget(CCBot & bot, const CCPosition & targetPosition, float minimumDistance = 24.0f)
+{
+	if (targetPosition == CCPosition())
+	{
+		return false;
+	}
+	return Util::DistSq(targetPosition, voiHomePosition(bot)) >= minimumDistance * minimumDistance;
+}
+
+CCPosition voiFarthestEnemyStartPosition(CCBot & bot)
+{
+	CCPosition farthestPosition;
+	float farthestDistance = 0.0f;
+	const CCPosition homePosition = voiHomePosition(bot);
+	for (const auto & enemyStart : bot.GetEnemyStartLocations())
+	{
+		const float distance = Util::DistSq(enemyStart, homePosition);
+		if (farthestPosition == CCPosition() || distance > farthestDistance)
+		{
+			farthestPosition = enemyStart;
+			farthestDistance = distance;
+		}
+	}
+	return farthestPosition;
+}
+
+CCPosition voiEnemyMainCombatTarget(CCBot & bot)
+{
+	const BaseLocation * enemyBaseLocation = bot.Bases().getPlayerStartingBaseLocation(Players::Enemy);
+	if (enemyBaseLocation && voiIsRemoteCombatTarget(bot, enemyBaseLocation->getDepotPosition()))
+	{
+		return enemyBaseLocation->getDepotPosition();
+	}
+	const CCPosition enemyStart = voiFarthestEnemyStartPosition(bot);
+	if (voiIsRemoteCombatTarget(bot, enemyStart))
+	{
+		return enemyStart;
+	}
+	return enemyBaseLocation ? enemyBaseLocation->getDepotPosition() : enemyStart;
+}
+
+CCPosition voiEnemyNaturalCombatTarget(CCBot & bot)
+{
+	const BaseLocation * enemyNatural = bot.Bases().getPlayerNat(Players::Enemy);
+	if (enemyNatural && voiIsRemoteCombatTarget(bot, enemyNatural->getDepotPosition()))
+	{
+		return enemyNatural->getDepotPosition();
+	}
+	const CCPosition enemyMain = voiEnemyMainCombatTarget(bot);
+	const CCPosition center = bot.Map().center();
+	if (voiIsRemoteCombatTarget(bot, enemyMain) && enemyMain != center)
+	{
+		return enemyMain + Util::Normalized(center - enemyMain) * 12.0f;
+	}
+	return enemyMain;
+}
+
+CCPosition voiResolveCombatLocationIntent(CCBot & bot, const std::string & locationIntent, const CCPosition & fallbackPosition)
+{
+	if (locationIntent == "enemy_natural" || locationIntent == "contain_enemy_natural" || locationIntent == "enemy_front")
+	{
+		return voiEnemyNaturalCombatTarget(bot);
+	}
+	if (locationIntent == "enemy_main" || locationIntent == "enemy_start" || locationIntent == "enemy_start_location")
+	{
+		return voiEnemyMainCombatTarget(bot);
+	}
+	if (!locationIntent.empty() && !voiIsRemoteCombatTarget(bot, fallbackPosition))
+	{
+		return voiEnemyMainCombatTarget(bot);
+	}
+	return fallbackPosition;
+}
+
+bool voiSquadNeedsOutgoingWallOpen(Squad & squad, CCBot & bot, const CCTilePosition & wallCenterTile)
+{
+	if (squad.getUnits().empty())
+	{
+		return false;
+	}
+
+	SquadOrder & order = squad.getSquadOrder();
+	if (order.getStatus() == "Retreat")
+	{
+		return false;
+	}
+
+	const bool outgoingOrder = order.getType() == SquadOrderTypes::Attack
+		|| order.getType() == SquadOrderTypes::Harass
+		|| order.getType() == SquadOrderTypes::Scout;
+	if (!outgoingOrder || order.getPosition() == CCPosition())
+	{
+		return false;
+	}
+
+	const BaseLocation * selfBase = bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+	const CCPosition homePosition = selfBase ? selfBase->getPosition() : bot.GetStartLocation();
+	if (Util::DistSq(order.getPosition(), homePosition) < 22.0f * 22.0f)
+	{
+		return false;
+	}
+
+	const CCPosition wallCenter = Util::GetPosition(wallCenterTile);
+	for (const auto & unit : squad.getUnits())
+	{
+		if (!voiIsMobileAttackUnit(unit) || unit.isFlying())
+		{
+			continue;
+		}
+		const bool stillAtHome = Util::DistSq(unit.getPosition(), homePosition) <= 18.0f * 18.0f;
+		const bool waitingAtWall = wallCenter != CCPosition()
+			&& Util::DistSq(unit.getPosition(), wallCenter) <= 16.0f * 16.0f;
+		if (stillAtHome || waitingAtWall)
+		{
+			return true;
+		}
+	}
+	return false;
+}
+}
