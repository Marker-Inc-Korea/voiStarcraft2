+float voiMaxBias(CCBot & bot, const std::string & first, const std::string & second = "", const std::string & third = "", const std::string & fourth = "")
+{
+	float value = bot.Commander().getVoiPolicyFloat(first, 0.0f);
+	if (!second.empty())
+	{
+		value = std::max(value, bot.Commander().getVoiPolicyFloat(second, 0.0f));
+	}
+	if (!third.empty())
+	{
+		value = std::max(value, bot.Commander().getVoiPolicyFloat(third, 0.0f));
+	}
+	if (!fourth.empty())
+	{
+		value = std::max(value, bot.Commander().getVoiPolicyFloat(fourth, 0.0f));
+	}
+	return value;
+}
+
+bool voiDoctrineIsOneOf(const std::string & doctrine, const std::string & first, const std::string & second = "", const std::string & third = "", const std::string & fourth = "")
+{
+	return doctrine == first
+		|| (!second.empty() && doctrine == second)
+		|| (!third.empty() && doctrine == third)
+		|| (!fourth.empty() && doctrine == fourth);
+}
+
+bool voiCommaListContains(const std::string & commaList, const std::string & needle)
+{
+	if (commaList.empty() || needle.empty())
+	{
+		return false;
+	}
+	size_t start = 0;
+	while (start <= commaList.size())
+	{
+		const size_t end = commaList.find(',', start);
+		const std::string token = commaList.substr(start, end == std::string::npos ? std::string::npos : end - start);
+		if (token == needle)
+		{
+			return true;
+		}
+		if (end == std::string::npos)
+		{
+			break;
+		}
+		start = end + 1;
+	}
+	return false;
+}
+
+bool voiTacticalTaskWithinDuration(CCBot & bot)
+{
+	const int durationSeconds = std::max(0, bot.Commander().getVoiPolicyInt("tactical_task.duration_seconds", 0));
+	if (durationSeconds == 0)
+	{
+		return true;
+	}
+	const uint32_t issuedAtFrame = static_cast<uint32_t>(std::max(0, bot.Commander().getVoiPolicyInt("issued_at_frame", 0)));
+	const uint32_t durationFrames = static_cast<uint32_t>(durationSeconds) * 22u;
+	const uint32_t currentFrame = bot.GetCurrentFrame();
+	return currentFrame <= issuedAtFrame + durationFrames;
+}
+
+bool isBootstrapPlacementCritical(CCBot & bot, const MetaType & type)
+{
+	if (!type.isUnit() || !type.getUnitType().isBuilding())
+	{
+		return false;
+	}
+
+	const auto apiType = type.getUnitType().getAPIUnitType();
+	if (bot.Commander().isVoiPolicyActive())
+	{
+		const std::string doctrine = bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+		if (apiType == sc2::UNIT_TYPEID::TERRAN_BARRACKS)
+		{
+			return (voiDoctrineIsOneOf(doctrine, "bio_pressure", "marine_rush", "expand_macro")
+					&& bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Barracks.getUnitType(), false, true, true) < 3)
+				|| bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Barracks.getUnitType(), false, true, true) == 0;
+		}
+		if (apiType == sc2::UNIT_TYPEID::TERRAN_SUPPLYDEPOT)
+		{
+			const int supplyDepotCount = bot.UnitInfo().getUnitTypeCount(
+				Players::Self,
+				MetaTypeEnum::SupplyDepot.getUnitType(),
+				false,
+				true,
+				true);
+			return supplyDepotCount <= 1 && bot.GetCurrentFrame() < 7000;
+		}
+		if (apiType == sc2::UNIT_TYPEID::TERRAN_REFINERY)
+		{
+			return bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Refinery.getUnitType(), false, true, true) < 2;
+		}
+		if (apiType == sc2::UNIT_TYPEID::TERRAN_FACTORY)
+		{
+			return voiDoctrineIsOneOf(doctrine, "tank_defensive_hold", "siege_contain", "mech_transition", "drop_harassment")
+				|| voiDoctrineIsOneOf(doctrine, "worker_line_harassment", "anti_air_response", "contain_enemy_natural");
+		}
+		if (apiType == sc2::UNIT_TYPEID::TERRAN_STARPORT)
+		{
+			return voiDoctrineIsOneOf(doctrine, "bio_pressure", "drop_harassment", "worker_line_harassment", "anti_air_response");
+		}
+	}
+
+	if (apiType == sc2::UNIT_TYPEID::TERRAN_BARRACKS)
+	{
+		return bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::Barracks.getUnitType(), false, true, true) == 0;
+	}
+	if (apiType == sc2::UNIT_TYPEID::TERRAN_SUPPLYDEPOT)
+	{
+		return bot.UnitInfo().getUnitTypeCount(Players::Self, MetaTypeEnum::SupplyDepot.getUnitType(), false, true, true) == 0;
+	}
+
+	return false;
+}
