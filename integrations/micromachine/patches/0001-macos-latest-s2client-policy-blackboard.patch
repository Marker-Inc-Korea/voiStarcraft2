+bool voiCommaListContains(const std::string & values, const std::string & target)
+{
+	std::size_t start = 0;
+	while (start <= values.size())
+	{
+		const auto separator = values.find(',', start);
+		const auto end = separator == std::string::npos ? values.size() : separator;
+		std::string token = values.substr(start, end - start);
+		const auto first = token.find_first_not_of(" \t\r\n");
+		const auto last = token.find_last_not_of(" \t\r\n");
+		if (first != std::string::npos)
+		{
+			token = token.substr(first, last - first + 1);
+		}
+		if (token == target)
+		{
+			return true;
+		}
+		if (separator == std::string::npos)
+		{
+			break;
+		}
+		start = separator + 1;
+	}
+	return false;
+}
