+bool IsRefineryTargetStillValid(CCBot & bot, const Building & building)
+{
+	if (!building.type.isRefinery() || building.finalPosition == CCTilePosition(0, 0))
+	{
+		return false;
+	}
+
+	const auto targetPosition = Util::GetPosition(building.finalPosition);
+	for (const auto & allyRefinery : bot.GetAllyUnits(building.type.getAPIUnitType()))
+	{
+		if (allyRefinery.getTilePosition() == building.finalPosition ||
+			Util::DistSq(allyRefinery.getPosition(), targetPosition) < 3 * 3)
+		{
+			return true;
+		}
+	}
+
+	for (const auto & unit : bot.GetUnits())
+	{
+		if (unit.getType().isGeyser() && Util::DistSq(unit.getPosition(), targetPosition) < 3 * 3)
+		{
+			return true;
+		}
+	}
+
+	return false;
