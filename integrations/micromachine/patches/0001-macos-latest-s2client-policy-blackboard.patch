+bool canTrustOpeningWallPlacement(CCBot & bot, const UnitType & type)
+{
+	if (!bot.Commander().isVoiPolicyActive())
+	{
+		return false;
+	}
+
+	const auto apiType = type.getAPIUnitType();
+	const std::string doctrine = bot.Commander().getVoiPolicyString("strategy.doctrine", "");
+	if (apiType == sc2::UNIT_TYPEID::TERRAN_FACTORY)
+	{
+		return doctrine == "tank_defensive_hold"
+			|| doctrine == "siege_contain"
+			|| doctrine == "mech_transition"
+			|| doctrine == "drop_harassment"
+			|| doctrine == "worker_line_harassment"
+			|| doctrine == "anti_air_response"
+			|| doctrine == "contain_enemy_natural";
+	}
+	if (apiType == sc2::UNIT_TYPEID::TERRAN_STARPORT)
+	{
+		return doctrine == "drop_harassment"
+			|| doctrine == "worker_line_harassment"
+			|| doctrine == "anti_air_response"
+			|| doctrine == "bio_pressure";
+	}
+	return false;
