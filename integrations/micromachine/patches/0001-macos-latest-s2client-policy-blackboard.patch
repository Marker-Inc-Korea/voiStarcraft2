+std::string voiJsonEscape(const std::string & value)
+{
+    std::string escaped;
+    escaped.reserve(value.size());
+    for (const char ch : value)
+    {
+        if (ch == '\\' || ch == '"')
+        {
+            escaped.push_back('\\');
+        }
+        escaped.push_back(ch);
+    }
+    return escaped;
+}
+
+bool voiIsWorkerUnitType(sc2::UNIT_TYPEID unitType)
+{
+	switch (unitType)
+	{
+		case sc2::UNIT_TYPEID::TERRAN_SCV:
+		case sc2::UNIT_TYPEID::TERRAN_MULE:
+		case sc2::UNIT_TYPEID::PROTOSS_PROBE:
+		case sc2::UNIT_TYPEID::ZERG_DRONE:
+		case sc2::UNIT_TYPEID::ZERG_DRONEBURROWED:
+			return true;
+		default:
+			return false;
+	}
+}
+
+int voiQuantizePosition(float value)
+{
+	return static_cast<int>(std::lround(value * 100.0f));
+}
+
+float voiDistanceSq(const CCPosition & lhs, const CCPosition & rhs)
+{
+	const float dx = lhs.x - rhs.x;
+	const float dy = lhs.y - rhs.y;
+	return dx * dx + dy * dy;
+}
+
+bool voiIsPositionWorkerAbility(const sc2::AbilityID & abilityID)
+{
+	const auto abilityType = abilityID.ToType();
+	return abilityType == sc2::ABILITY_ID::MOVE
+		|| abilityType == sc2::ABILITY_ID::SMART;
+}
+
+bool voiIsWorkerPositionCommandKind(const std::string & targetKind)
+{
+	return targetKind == "build_position"
+		|| targetKind == "ability_position"
+		|| targetKind == "unit_move_position"
+		|| targetKind == "unit_move_tile_position"
+		|| targetKind == "unit_smart_position"
+		|| targetKind == "queued_position"
+		|| targetKind == "micro_smart_move_position";
+}
+
+bool voiHasSamePositionOrderTarget(const sc2::Unit * unit, const sc2::AbilityID & abilityID, const CCPosition & targetPosition, float maxDistanceSq)
+{
+	if (unit == nullptr || unit->orders.empty())
+	{
+		return false;
+	}
+
+	const auto & order = unit->orders[0];
+	if (order.ability_id.ToType() != abilityID.ToType())
+	{
+		return false;
+	}
+
+	const CCPosition currentTarget(order.target_pos);
+	return voiDistanceSq(currentTarget, targetPosition) <= maxDistanceSq;
+}
