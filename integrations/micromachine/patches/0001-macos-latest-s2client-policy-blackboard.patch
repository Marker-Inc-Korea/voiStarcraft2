+	return unitTypeData ? static_cast<int>(unitTypeData->food_provided) : 0;
+}
+
+int UnitType::supplyRequired() const
+{
+	const sc2::UnitTypeData * unitTypeData = findUnitTypeData(m_bot, m_type);
+	return unitTypeData ? static_cast<int>(unitTypeData->food_required) : 0;
