+void GameCommander::updateVoiPolicyBlackboard()
+{
+    m_voiPolicyActive = false;
+
+    const char * sharedDir = std::getenv("VOI_MICROMACHINE_BLACKBOARD_DIR");
+    if (sharedDir == nullptr || sharedDir[0] == '\0') {
+        return;
+    }
+
+    const std::string blackboardPath = std::string(sharedDir) + "/latest_modulation.kv";
+    if (!m_voiPolicyBlackboard.loadFromFile(blackboardPath)) {
+        return;
+    }
+
+    if (!m_voiPolicyBlackboard.isProtocolCompatible()
+        || m_voiPolicyBlackboard.isExpired(m_bot.GetGameLoop())) {
+        return;
+    }
+
+    m_voiPolicyActive = true;
+}
