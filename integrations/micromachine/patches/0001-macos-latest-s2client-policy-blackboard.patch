+void ScoutManager::recordVoiScoutCommand(const std::string & kind, const std::string & reason, const CCPosition & targetPosition)
+{
+    std::ostringstream command;
+    command << kind
+        << "|" << reason
+        << "|x=" << targetPosition.x
+        << "|y=" << targetPosition.y;
+    m_voiScoutCommandIssuedCount++;
+    const uint32_t currentFrame = m_bot.GetGameLoop();
+    m_lastVoiScoutCommandFrame = currentFrame == 0 ? 1 : currentFrame;
+    m_lastVoiScoutCommand = command.str();
+    m_lastVoiScoutTarget = targetPosition;
+    m_hasLastVoiScoutTarget = true;
+    if (m_scoutUnit.isValid())
+    {
+        m_lastVoiScoutTargetDistance = std::sqrt(Util::DistSq(m_scoutUnit.getPosition(), targetPosition));
+    }
+}
+
+void ScoutManager::recordVoiScoutProgress(const BaseLocation * enemyBaseLocation)
+{
+    if (!m_scoutUnit.isValid())
+    {
+        return;
+    }
+
+    const CCPosition scoutPosition = m_scoutUnit.getPosition();
+    const CCPosition homePosition = Util::GetPosition(m_bot.Bases().getClosestBasePosition(m_scoutUnit.getUnitPtr()));
+    m_lastVoiScoutHomeDistance = std::sqrt(Util::DistSq(scoutPosition, homePosition));
+    m_maxVoiScoutHomeDistance = std::max(m_maxVoiScoutHomeDistance, m_lastVoiScoutHomeDistance);
+    if (enemyBaseLocation != nullptr)
+    {
+        const CCPosition enemyPosition = enemyBaseLocation->getPosition();
+        const float enemyDistance = std::sqrt(Util::DistSq(scoutPosition, enemyPosition));
+        m_lastVoiScoutEnemyBaseDistance = enemyDistance;
+        if (m_minVoiScoutEnemyBaseDistance <= 0.0f || enemyDistance < m_minVoiScoutEnemyBaseDistance)
+        {
+            m_minVoiScoutEnemyBaseDistance = enemyDistance;
+        }
+        if (enemyDistance <= 16.0f || enemyBaseLocation->containsPosition(scoutPosition))
+        {
+            m_deepVoiScoutFrameCount++;
+        }
+    }
+}
