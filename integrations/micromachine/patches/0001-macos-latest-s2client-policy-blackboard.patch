+bool voiHasSamePositionOrder(const sc2::Unit * unit, const sc2::AbilityID & abilityID, const CCPosition & targetPosition, float maxDistanceSq)
+{
+	return voiHasSamePositionOrderTarget(unit, abilityID, targetPosition, maxDistanceSq);
+}
+
+std::string voiTrim(const std::string & value)
+{
+	const auto begin = value.find_first_not_of(" \t\r\n");
+	if (begin == std::string::npos)
+	{
+		return "";
+	}
+	const auto end = value.find_last_not_of(" \t\r\n");
+	return value.substr(begin, end - begin + 1);
+}
+
+bool voiCommaListContains(const std::string & values, const std::string & target)
+{
+	std::size_t start = 0;
+	while (start <= values.size())
+	{
+		const auto separator = values.find(',', start);
+		const auto end = separator == std::string::npos ? values.size() : separator;
+		if (voiTrim(values.substr(start, end - start)) == target)
+		{
+			return true;
+		}
+		if (separator == std::string::npos)
+		{
+			break;
+		}
+		start = separator + 1;
+	}
+	return false;
+}
