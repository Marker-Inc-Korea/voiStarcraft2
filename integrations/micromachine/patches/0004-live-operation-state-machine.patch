+bool BuildingManager::isVoiProducerCommandOwned(sc2::Tag tag) const
+{
+	if (isVoiBuildingMobilityOwned(tag))
+	{
+		return true;
+	}
+	for (const auto & building : m_buildings)
+	{
+		if (building.type.isAddon()
+			&& !building.buildingUnit.isValid()
+			&& building.builderUnit.isValid()
+			&& building.builderUnit.getTag() == tag)
+		{
+			return true;
+		}
+	}
+	return false;
+}
