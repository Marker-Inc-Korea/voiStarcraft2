+		&& action.explicitAbilityName
+			== m_voiExplicitAbilityAttemptAbility;
+}
+
+void CombatCommander::discardVoiExplicitAbilityActions()
+{
+	for (auto it = unitActions.begin();
+		it != unitActions.end();)
+	{
+		const UnitAction & action = it->second;
+		const bool explicitAction =
+			action.explicitAbilityAttemptGeneration != 0
+			|| action.description.rfind(
+				"VoiExplicitAbility:",
+				0) == 0
+			|| action.description.rfind(
+				"VoiExplicitAbilityStage:",
+				0) == 0;
+		if (explicitAction)
+		{
+			it = unitActions.erase(it);
+		}
+		else
+		{
+			++it;
+		}
+	}
+}
+
+void CombatCommander::advanceVoiExplicitAbilityAttempt()
