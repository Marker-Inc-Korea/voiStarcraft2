+bool voiExplicitAbilityIsIrreversible(
+	const std::string & abilityName)
+{
+	return abilityName != "siege_mode"
+		&& abilityName != "unsiege"
+		&& abilityName != "widow_mine_burrow"
+		&& abilityName != "widow_mine_unburrow"
+		&& abilityName != "ghost_cloak"
+		&& abilityName != "ghost_decloak"
+		&& abilityName != "hellbat_mode"
+		&& abilityName != "hellion_mode"
+		&& abilityName != "thor_high_impact_mode"
+		&& abilityName != "thor_explosive_mode"
+		&& abilityName != "medivac_heal"
+		&& abilityName != "viking_fighter_mode"
+		&& abilityName != "viking_assault_mode"
+		&& abilityName != "liberator_defender_mode"
+		&& abilityName != "liberator_fighter_mode"
+		&& abilityName != "banshee_cloak"
+		&& abilityName != "banshee_decloak";
+}
+
+bool voiExplicitAbilityAcceptanceIsTerminal(
+	const std::string & abilityName)
+{
+	return abilityName == "lock_on"
+		|| abilityName == "interference_matrix"
+		|| abilityName == "anti_armor_missile";
+}
+
+bool voiExpectedActorBuff(
+	const std::string & abilityName,
+	const sc2::Unit * actor,
+	sc2::BUFF_ID & buff)
+{
+	if (actor == nullptr)
+	{
+		return false;
+	}
+	if (abilityName == "stimpack")
+	{
+		if (actor->unit_type == sc2::UNIT_TYPEID::TERRAN_MARINE)
+		{
+			buff = sc2::BUFF_ID::STIMPACK;
+			return true;
+		}
+		if (actor->unit_type == sc2::UNIT_TYPEID::TERRAN_MARAUDER)
+		{
+			buff = sc2::BUFF_ID::STIMPACKMARAUDER;
+			return true;
+		}
+		return false;
+	}
+	if (abilityName == "marine_stimpack")
+	{
+		buff = sc2::BUFF_ID::STIMPACK;
+		return true;
+	}
+	if (abilityName == "marauder_stimpack")
+	{
+		buff = sc2::BUFF_ID::STIMPACKMARAUDER;
+		return true;
+	}
+	if (abilityName == "medivac_afterburners")
+	{
+		buff = sc2::BUFF_ID::MEDIVACSPEEDBOOST;
+		return true;
+	}
+	return false;
+}
+
+bool voiActorHasExpectedBuff(
+	const std::string & abilityName,
+	const sc2::Unit * actor)
+{
+	sc2::BUFF_ID buff = static_cast<sc2::BUFF_ID>(0);
+	return voiExpectedActorBuff(abilityName, actor, buff)
+		&& Util::unitHasBuff(actor, buff);
+}
+
+bool voiExplicitAbilityDesiredStateSatisfied(
+	const std::string & abilityName,
+	const sc2::Unit * actor,
+	std::string & evidence)
+{
+	if (actor == nullptr)
+	{
+		return false;
+	}
+	const auto actorIs =
+		[&](sc2::UNIT_TYPEID type, const std::string & typeName)
+		{
+			if (actor->unit_type != type)
+			{
+				return false;
+			}
+			evidence = "unit_type:" + typeName;
+			return true;
+		};
+	if (abilityName == "siege_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_SIEGETANKSIEGED,
+			"TERRAN_SIEGETANKSIEGED");
+	}
+	if (abilityName == "unsiege")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_SIEGETANK,
+			"TERRAN_SIEGETANK");
+	}
+	if (abilityName == "widow_mine_burrow")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_WIDOWMINEBURROWED,
+			"TERRAN_WIDOWMINEBURROWED");
+	}
+	if (abilityName == "widow_mine_unburrow")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_WIDOWMINE,
+			"TERRAN_WIDOWMINE");
+	}
+	if (abilityName == "hellbat_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_HELLIONTANK,
+			"TERRAN_HELLIONTANK");
+	}
+	if (abilityName == "hellion_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_HELLION,
+			"TERRAN_HELLION");
+	}
+	if (abilityName == "thor_high_impact_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_THORAP,
+			"TERRAN_THORAP");
+	}
+	if (abilityName == "thor_explosive_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_THOR,
+			"TERRAN_THOR");
+	}
+	if (abilityName == "viking_fighter_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_VIKINGFIGHTER,
+			"TERRAN_VIKINGFIGHTER");
+	}
+	if (abilityName == "viking_assault_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_VIKINGASSAULT,
+			"TERRAN_VIKINGASSAULT");
+	}
+	if (abilityName == "liberator_defender_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_LIBERATORAG,
+			"TERRAN_LIBERATORAG");
+	}
+	if (abilityName == "liberator_fighter_mode")
+	{
+		return actorIs(
+			sc2::UNIT_TYPEID::TERRAN_LIBERATOR,
+			"TERRAN_LIBERATOR");
+	}
+	if (abilityName == "ghost_cloak"
+		|| abilityName == "banshee_cloak")
+	{
+		if (actor->cloak == sc2::Unit::NotCloaked
+			|| actor->cloak == sc2::Unit::Unknown)
+		{
+			return false;
+		}
+		evidence = "cloak_state:cloaked";
+		return true;
+	}
+	if (abilityName == "ghost_decloak"
+		|| abilityName == "banshee_decloak")
+	{
+		if (actor->cloak != sc2::Unit::NotCloaked)
+		{
+			return false;
+		}
+		evidence = "cloak_state:not_cloaked";
+		return true;
+	}
+	if (abilityName == "stimpack"
+		|| abilityName == "marine_stimpack"
+		|| abilityName == "marauder_stimpack"
+		|| abilityName == "medivac_afterburners")
+	{
+		sc2::BUFF_ID buff = static_cast<sc2::BUFF_ID>(0);
+		if (!voiExpectedActorBuff(abilityName, actor, buff)
+			|| !Util::unitHasBuff(actor, buff))
+		{
+			return false;
+		}
+		evidence = "actor_buff:"
+			+ std::string(
+				abilityName == "medivac_afterburners"
+					? "MEDIVACSPEEDBOOST"
+					: (buff == sc2::BUFF_ID::STIMPACK
+						? "STIMPACK"
+						: "STIMPACKMARAUDER"));
+		return true;
+	}
+	if (abilityName == "medivac_unload_all"
+		&& actor->cargo_space_taken == 0
+		&& actor->passengers.empty())
+	{
+		evidence = "cargo:empty";
+		return true;
+	}
+	return false;
+}
+
+std::set<sc2::Tag> voiPassengerTags(const sc2::Unit * actor)
+{
+	std::set<sc2::Tag> result;
+	if (actor == nullptr)
+	{
+		return result;
+	}
+	for (const auto & passenger : actor->passengers)
+	{
+		result.insert(passenger.tag);
+	}
+	return result;
+}
+
+bool voiActorHasExactAbilityOrder(
+	const sc2::Unit * actor,
+	sc2::AbilityID abilityId,
+	sc2::Tag targetTag,
+	const CCPosition & targetPosition)
+{
+	if (actor == nullptr)
+	{
+		return false;
+	}
+	for (const auto & order : actor->orders)
+	{
+		if (order.ability_id != abilityId)
+		{
+			continue;
+		}
+		if (targetTag != 0)
+		{
+			if (order.target_unit_tag == targetTag)
+			{
+				return true;
+			}
+			continue;
+		}
+		if (targetPosition != CCPosition())
+		{
+			if (order.target_unit_tag == 0
+				&& Util::DistSq(
+					order.target_pos,
+					targetPosition)
+					<= ExplicitAbilityOrderPositionToleranceSq)
+			{
+				return true;
+			}
+			continue;
+		}
+		return true;
+	}
+	return false;
+}
