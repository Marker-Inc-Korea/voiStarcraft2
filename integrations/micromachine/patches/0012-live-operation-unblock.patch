+CCPosition CombatCommander::GetNextEnemyStartCandidateToScout()
+{
+	auto & squad = m_squadData.getSquad("Scout");
+	if (squad.getUnits().empty())
+	{
+		return GetNextBaseLocationToScout();
+	}
+
+	const Unit & scoutUnit = squad.getUnits().front();
+	CCPosition selectedCandidate;
+	float selectedDistance = 0.0f;
+	for (const auto & candidate : m_bot.GetEnemyStartLocations())
+	{
+		if (m_bot.Map().isExplored(candidate))
+		{
+			continue;
+		}
+		bool stalled = false;
+		for (const auto & stalledTarget : m_voiStalledScoutTargets)
+		{
+			if (Util::DistSq(stalledTarget, candidate) <= 4.0f)
+			{
+				stalled = true;
+				break;
+			}
+		}
+		if (stalled)
+		{
+			continue;
+		}
+		if (!scoutUnit.isFlying()
+			&& m_bot.Map().getGroundDistance(candidate, scoutUnit.getPosition()) < 0)
+		{
+			continue;
+		}
+		const float distance = Util::DistSq(scoutUnit.getPosition(), candidate);
+		if (selectedCandidate == CCPosition() || distance < selectedDistance)
+		{
+			selectedCandidate = candidate;
+			selectedDistance = distance;
+		}
+	}
+	return selectedCandidate != CCPosition()
+		? selectedCandidate
+		: GetNextBaseLocationToScout();
+}
