+int BuildingManager::countVoiEligibleAddonProducers(sc2::UNIT_TYPEID producerType) const
+{
+	int count = 0;
+	for (const auto & producer : m_bot.GetAllyUnits(producerType))
+	{
+		if (!producer.isValid()
+			|| !producer.isAlive()
+			|| !producer.isCompleted()
+			|| producer.isFlying()
+			|| producer.getAddonTag() != 0
+			|| isVoiProducerCommandOwned(producer.getTag())
+			|| !isVoiAddonProducerEligible(producer.getTag()))
+		{
+			continue;
+		}
+		count++;
+	}
+	return count;
+}
+
+bool BuildingManager::hasVoiBlockedAddonProducer(sc2::UNIT_TYPEID producerType) const
+{
+	const uint32_t currentFrame = m_bot.GetCurrentFrame();
+	for (const auto & producer : m_bot.GetAllyUnits(producerType))
+	{
+		const auto blockedIt = m_addonProducerCooldownUntil.find(producer.getTag());
+		if (blockedIt != m_addonProducerCooldownUntil.end()
+			&& currentFrame < blockedIt->second)
+		{
+			return true;
+		}
+	}
+	return false;
+}
