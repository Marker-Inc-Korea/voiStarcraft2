+const std::vector<std::pair<std::string, MetaType>> & voiExactCompositionTypes()
+{
+	static const std::vector<std::pair<std::string, MetaType>> types = {
+		{ "TERRAN_MARINE", MetaTypeEnum::Marine },
+		{ "TERRAN_MARAUDER", MetaTypeEnum::Marauder },
+		{ "TERRAN_REAPER", MetaTypeEnum::Reaper },
+		{ "TERRAN_GHOST", MetaTypeEnum::Ghost },
+		{ "TERRAN_HELLION", MetaTypeEnum::Hellion },
+		{ "TERRAN_WIDOWMINE", MetaTypeEnum::WidowMine },
+		{ "TERRAN_CYCLONE", MetaTypeEnum::Cyclone },
+		{ "TERRAN_THOR", MetaTypeEnum::Thor },
+		{ "TERRAN_SIEGETANK", MetaTypeEnum::SiegeTank },
+		{ "TERRAN_MEDIVAC", MetaTypeEnum::Medivac },
+		{ "TERRAN_VIKINGFIGHTER", MetaTypeEnum::Viking },
+		{ "TERRAN_LIBERATOR", MetaTypeEnum::Liberator },
+		{ "TERRAN_BANSHEE", MetaTypeEnum::Banshee },
+		{ "TERRAN_RAVEN", MetaTypeEnum::Raven },
+		{ "TERRAN_BATTLECRUISER", MetaTypeEnum::Battlecruiser },
+	};
+	return types;
+}
+
+bool voiExactCompositionActive(CCBot & bot)
+{
+	if (!bot.Commander().isVoiPolicyActive()
+		|| !bot.Commander().hasVoiPolicyDomain("composition_requirements")
+		|| !voiTacticalTaskWithinDuration(bot))
+	{
+		return false;
+	}
+	const std::string taskType = bot.Commander().getVoiPolicyString("tactical_task.task_type", "");
+	const std::string lifetimeMode = bot.Commander().getVoiPolicyString("lifetime.mode", "");
+	if (taskType == "sustain_production"
+		&& (lifetimeMode == "until_cancelled" || lifetimeMode == "standing_order"))
+	{
+		return false;
+	}
+	return taskType == "pressure_with_main_army"
+		|| taskType == "scout_with_units"
+		|| taskType == "sustain_production"
+		|| taskType == "tech_transition";
+}
+
+std::string voiExactCompositionTokenForType(const MetaType & type)
+{
+	if (!type.isUnit())
+	{
+		return "";
+	}
+	const auto apiType = type.getUnitType().getAPIUnitType();
+	for (const auto & entry : voiExactCompositionTypes())
+	{
+		if (entry.second.getUnitType().getAPIUnitType() == apiType)
+		{
+			return entry.first;
+		}
+	}
+	return "";
+}
+
+bool voiExactCompositionAllowsTraining(CCBot & bot, const MetaType & type)
+{
+	if (!voiExactCompositionActive(bot))
+	{
+		return true;
+	}
+	const std::string token = voiExactCompositionTokenForType(type);
+	if (token.empty())
+	{
+		return true;
+	}
+	const int requestedCount = voiRequestedCompositionCount(bot, token);
+	return voiRepresentedUnitCount(bot, type) < requestedCount;
+}
+
+int voiCompletedGroundedProducerCount(CCBot & bot, sc2::UNIT_TYPEID producerType)
+{
+	int count = 0;
+	for (const auto & producer : bot.GetAllyUnits(producerType))
+	{
+		if (producer.isValid() && producer.isAlive() && producer.isCompleted() && !producer.isFlying())
+		{
+			count++;
+		}
+	}
+	return count;
+}
+
+int voiCompletedProducersWithAttachedAddon(
+	CCBot & bot,
+	sc2::UNIT_TYPEID producerType,
+	sc2::UNIT_TYPEID addonType)
+{
+	int count = 0;
+	for (const auto & producer : bot.GetAllyUnits(producerType))
+	{
+		if (!producer.isValid() || !producer.isAlive() || !producer.isCompleted() || producer.isFlying())
+		{
+			continue;
+		}
+		const sc2::Tag addonTag = producer.getAddonTag();
+		if (addonTag == 0)
+		{
+			continue;
+		}
+		const Unit addon = bot.GetUnit(addonTag);
+		if (addon.isValid() && addon.isAlive() && addon.isCompleted() && addon.getAPIUnitType() == addonType)
+		{
+			count++;
+		}
+	}
+	return count;
+}
