+void ProductionManager::reconcileVoiExactCompositionQueue()
+{
+	if (!voiExactCompositionActive(m_bot))
+	{
+		return;
+	}
+
+	for (const auto & entry : voiExactCompositionTypes())
+	{
+		const MetaType & type = entry.second;
+		const int requestedCount = voiRequestedCompositionCount(m_bot, entry.first);
+		const int representedCount = voiRepresentedUnitCount(m_bot, type);
+		const int allowedQueuedCount = std::max(0, requestedCount - representedCount);
+		const int queuedCount = m_queue.getCountOfType(type);
+		if (queuedCount <= allowedQueuedCount)
+		{
+			continue;
+		}
+
+		m_queue.removeAllOfType(type);
+		for (int i = 0; i < allowedQueuedCount; ++i)
+		{
+			m_queue.queueAsHighestPriority(type, false);
+		}
+		Util::Log(
+			__FUNCTION__,
+			"VOI exact composition reconciled " + type.getName()
+				+ " requested=" + std::to_string(requestedCount)
+				+ " represented=" + std::to_string(representedCount)
+				+ " queued=" + std::to_string(queuedCount)
+				+ " retained=" + std::to_string(allowedQueuedCount),
+			m_bot);
+	}
+}
