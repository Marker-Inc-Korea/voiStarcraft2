+bool voiIsVisibleLiveEnemy(const sc2::Unit * unit)
+{
+	return unit != nullptr
+		&& unit->is_alive
+		&& unit->health > 0.0f
+		&& unit->display_type == sc2::Unit::DisplayType::Visible;
+}
+
+const sc2::Unit * voiBestGhostSnipeTarget(CCBot & bot, const sc2::Unit * ghost)
+{
+	const sc2::Unit * bestTarget = nullptr;
+	float bestScore = 0.0f;
+	for (const auto & enemyUnit : bot.UnitInfo().getUnits(Players::Enemy))
+	{
+		const sc2::Unit * enemy = enemyUnit.getUnitPtr();
+		if (!voiIsVisibleLiveEnemy(enemy)
+			|| !enemyUnit.isBiological()
+			|| enemyUnit.getType().isBuilding())
+		{
+			continue;
+		}
+		const float castRange = 10.0f + ghost->radius + enemy->radius;
+		const float distanceSq = Util::DistSq(ghost->pos, enemy->pos);
+		if (distanceSq > castRange * castRange)
+		{
+			continue;
+		}
+		const float score = enemy->health_max * 2.0f + enemy->energy - distanceSq;
+		if (bestTarget == nullptr || score > bestScore)
+		{
+			bestTarget = enemy;
+			bestScore = score;
+		}
+	}
+	return bestTarget;
+}
+
+bool voiBestGhostEmpPosition(CCBot & bot, const sc2::Unit * ghost, CCPosition & position)
+{
+	float bestScore = 0.0f;
+	bool found = false;
+	for (const auto & enemyUnit : bot.UnitInfo().getUnits(Players::Enemy))
+	{
+		const sc2::Unit * enemy = enemyUnit.getUnitPtr();
+		if (!voiIsVisibleLiveEnemy(enemy))
+		{
+			continue;
+		}
+		const float castRange = 10.0f + ghost->radius;
+		const float distanceSq = Util::DistSq(ghost->pos, enemy->pos);
+		if (distanceSq > castRange * castRange)
+		{
+			continue;
+		}
+		float score = enemy->shield + enemy->energy;
+		for (const auto & nearbyEnemyUnit : bot.UnitInfo().getUnits(Players::Enemy))
+		{
+			const sc2::Unit * nearbyEnemy = nearbyEnemyUnit.getUnitPtr();
+			if (voiIsVisibleLiveEnemy(nearbyEnemy)
+				&& Util::DistSq(enemy->pos, nearbyEnemy->pos) <= 1.5f * 1.5f)
+			{
+				score += nearbyEnemy->shield + nearbyEnemy->energy;
+			}
+		}
+		if (score >= 75.0f && (!found || score > bestScore))
+		{
+			position = enemy->pos;
+			bestScore = score;
+			found = true;
+		}
+	}
+	return found;
+}
+
+const sc2::Unit * voiNearestVisibleGroundEnemy(
+	CCBot & bot,
+	const sc2::Unit * unit,
+	float maxRange)
+{
+	const sc2::Unit * nearest = nullptr;
+	float nearestDistanceSq = maxRange * maxRange;
+	for (const auto & enemyUnit : bot.UnitInfo().getUnits(Players::Enemy))
+	{
+		const sc2::Unit * enemy = enemyUnit.getUnitPtr();
+		if (!voiIsVisibleLiveEnemy(enemy) || enemy->is_flying)
+		{
+			continue;
+		}
+		const float distanceSq = Util::DistSq(unit->pos, enemy->pos);
+		if (distanceSq <= nearestDistanceSq)
+		{
+			nearest = enemy;
+			nearestDistanceSq = distanceSq;
+		}
+	}
+	return nearest;
+}
