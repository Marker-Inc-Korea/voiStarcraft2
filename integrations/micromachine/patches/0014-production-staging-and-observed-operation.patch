+bool voiProductionAddonAreaHasStaticBlocker(
+	CCBot & bot,
+	const UnitType & type,
+	const CCTilePosition & position)
+{
+	const auto apiType = type.getAPIUnitType();
+	if (apiType != sc2::UNIT_TYPEID::TERRAN_BARRACKS
+		&& apiType != sc2::UNIT_TYPEID::TERRAN_FACTORY
+		&& apiType != sc2::UNIT_TYPEID::TERRAN_STARPORT)
+	{
+		return false;
+	}
+
+	const CCPosition producerPosition = Util::GetPosition(position);
+	const CCPosition addonCenter = producerPosition + CCPosition(2.5f, -0.5f);
+	for (const auto & unit : bot.GetUnits())
+	{
+		if (!unit.isValid() || !unit.isAlive() || unit.isFlying())
+		{
+			continue;
+		}
+		if (!unit.getType().isBuilding()
+			&& !unit.getType().isMineral()
+			&& !unit.getType().isGeyser())
+		{
+			continue;
+		}
+		if (Util::Dist(addonCenter, unit.getPosition()) <= 1.0f + unit.getUnitPtr()->radius)
+		{
+			return true;
+		}
+	}
+	return false;
+}
