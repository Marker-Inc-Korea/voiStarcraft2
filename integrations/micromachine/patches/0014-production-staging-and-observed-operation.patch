+CCPosition voiProductionStagingPosition(CCBot & bot)
+{
+	const BaseLocation * selfBase = bot.Bases().getPlayerStartingBaseLocation(Players::Self);
+	const CCPosition home = selfBase ? selfBase->getPosition() : bot.GetStartLocation();
+	const CCPosition mapCenter = bot.Map().center();
+	const CCPosition towardCenter = mapCenter - home;
+	const float distance = std::sqrt(towardCenter.x * towardCenter.x + towardCenter.y * towardCenter.y);
+	if (distance > 0.1f)
+	{
+		const CCPosition staging = home + towardCenter / distance * 10.0f;
+		if (bot.Map().isValidPosition(staging)
+			&& bot.Map().isWalkable(staging)
+			&& bot.Map().isConnected(home, staging))
+		{
+			return staging;
+		}
+	}
+	return home;
+}
