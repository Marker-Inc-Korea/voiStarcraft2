+bool isVoiProductionBuildingWithAddonFootprint(const UnitType & type)
+{
+	const auto apiType = type.getAPIUnitType();
+	return apiType == sc2::UNIT_TYPEID::TERRAN_BARRACKS
+		|| apiType == sc2::UNIT_TYPEID::TERRAN_FACTORY
+		|| apiType == sc2::UNIT_TYPEID::TERRAN_STARPORT;
+}
+
+CCPosition voiProductionAddonProbePosition(const CCTilePosition & producerPosition)
+{
+	// A 2x2 SupplyDepot centered here covers exactly the future addon tiles:
+	// (x+2,y-1), (x+2,y), (x+3,y-1), and (x+3,y).
+	return CCPosition(
+		static_cast<float>(producerPosition.x + 3),
+		static_cast<float>(producerPosition.y));
+}
+
+bool queryCanPlaceVoiProductionAddonFootprint(
+	CCBot & bot,
+	const CCTilePosition & producerPosition)
+{
+	const UnitType addonProbeType(sc2::UNIT_TYPEID::TERRAN_SUPPLYDEPOT, bot);
+	return bot.Query()->Placement(
+		bot.Data(addonProbeType).buildAbility,
+		voiProductionAddonProbePosition(producerPosition));
+}
