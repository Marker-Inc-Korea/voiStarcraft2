+CCPosition voiObservedEnemyCombatTarget(CCBot & bot)
+{
+	CCPosition observedTarget;
+	int bestPriority = -1;
+	const uint32_t currentFrame = bot.GetCurrentFrame();
+	const uint32_t recentObservationWindowFrames = 22u * 20u;
+	for (const auto & enemy : bot.GetKnownEnemyUnits())
+	{
+		if (!enemy.isValid() || !enemy.isAlive())
+		{
+			continue;
+		}
+		const bool persistentBuildingEvidence = enemy.getType().isBuilding()
+			&& enemy.getUnitPtr()->display_type != sc2::Unit::Hidden;
+		const uint32_t lastSeenFrame = enemy.getUnitPtr()->last_seen_game_loop;
+		const bool recentMobileEvidence = !enemy.getType().isBuilding()
+			&& lastSeenFrame > 0
+			&& currentFrame >= lastSeenFrame
+			&& currentFrame - lastSeenFrame <= recentObservationWindowFrames;
+		if (!enemy.isVisible() && !persistentBuildingEvidence && !recentMobileEvidence)
+		{
+			continue;
+		}
+		if (!voiIsRemoteCombatTarget(bot, enemy.getPosition(), 16.0f))
+		{
+			continue;
+		}
+		int priority = enemy.isVisible() ? 3 : (persistentBuildingEvidence ? 2 : 1);
+		if (enemy.getType().isBuilding())
+		{
+			priority += 2;
+		}
+		if (enemy.getType().isResourceDepot())
+		{
+			priority += 4;
+		}
+		if (priority > bestPriority)
+		{
+			bestPriority = priority;
+			observedTarget = enemy.getPosition();
+		}
+	}
+	return observedTarget;
+}
+
+bool voiHasObservedEnemyLocationEvidence(CCBot & bot)
+{
+	return voiObservedEnemyCombatTarget(bot) != CCPosition();
+}
