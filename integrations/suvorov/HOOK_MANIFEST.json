  "known_blockers": [
    {
      "id": "no_bounded_blackboard",
      "severity": "high",
      "description": "Upstream Suvorov has no filesystem blackboard or sidecar protocol equivalent to MicroMachine latest_modulation.kv/latest_telemetry.json."
    },
    {
      "id": "no_policy_consumption_telemetry",
      "severity": "high",
      "description": "Upstream logs prove bot activity but do not expose policy_active, active_modulation_ids, consumed axes, manager snapshots, macro evidence counters, or explicit failure reasons."
    },
    {
      "id": "race_selection_not_cli_controlled",
      "severity": "medium",
      "description": "Non-ladder main.cpp hardcodes CreateParticipant(sc2::Race::Random), so per-race smoke requires a source patch or ladder harness that can select race."
    },
    {
      "id": "combat_depth_is_attack_limit_based",
      "severity": "medium",
      "description": "The base Strategy sends all combat units to the enemy start when m_units.size() reaches m_attack_limit. It lacks MicroMachine-style squad roles, combat simulation, target-priority hooks, and fine tactical managers."
    },
    {
      "id": "same_environment_strength_unproven",
      "severity": "medium",
      "description": "The local Acropolis run completed but lost to CheatInsane Rush at frame 8548. This is insufficient to claim stronger baseline performance than MicroMachine."
    }
  ],
  "central_polling_hook": {
    "source_path": "src/Dispatcher.cpp",
    "function": "Dispatcher::OnStep()",
    "anchor": "before plugin OnStep loop or before Builder::OnStep",
    "reason": "Dispatcher owns the per-frame lifecycle and can load a bounded blackboard once before Strategy, economy, production, and plugin decisions consume it."
